diff --git a/chrome/browser/ui/stead/brain/brain_console.mojom b/chrome/browser/ui/stead/brain/brain_console.mojom
new file mode 100644
index 0000000000000..b0bf93ec80ec
--- /dev/null
+++ b/chrome/browser/ui/stead/brain/brain_console.mojom
@@ -0,0 +1,79 @@
+// Copyright 2026 The Stead Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+module stead.mojom;
+
+// WebUI-facing brain event envelope. The browser keeps lifecycle/process
+// ownership; payload_json is the exact secret-redacted JSON event emitted by
+// the bundled stead-brain helper.
+struct BrainEvent {
+  string type;
+  string request_id;
+  string session_id;
+  string payload_json;
+};
+
+struct BrainResult {
+  bool ok;
+  string request_id;
+  string code;
+  string message;
+};
+
+struct BrainTabContext {
+  int32 tab_id;
+  string url;
+  string title;
+};
+
+struct BrainModelSelection {
+  string provider;
+  string model;
+};
+
+enum BrainPermissionMode {
+  kAsk,
+  kRead,
+  kFull,
+};
+
+interface BrainObserver {
+  OnBrainEvent(BrainEvent event);
+};
+
+// WebUI-facing surface for sessions/model auth. It intentionally exposes no
+// AgentControl methods; browser actions must go through the helper's tool-call
+// path and the browser-side broker.
+interface BrainConsole {
+  AddObserver(pending_remote<BrainObserver> observer);
+
+  // Starts the bundled helper lazily and sends the initialize frame.
+  Initialize() => (BrainResult result);
+  ShutdownBrain() => (BrainResult result);
+
+  CreateSession(string? title, string origin_surface)
+      => (BrainResult result);
+  ListSessions() => (BrainResult result);
+  LoadSession(string session_id) => (BrainResult result);
+  GetPermissionMode() => (BrainPermissionMode permission_mode);
+  SetPermissionMode(BrainPermissionMode permission_mode) => ();
+  SendMessage(string session_id, string text, array<BrainTabContext> tab_contexts,
+      BrainModelSelection? model, string reasoning_effort,
+      BrainPermissionMode permission_mode)
+      => (BrainResult result);
+  CancelTurn(string session_id) => (BrainResult result);
+
+  ListProviderAuth() => (BrainResult result);
+  ListModels() => (BrainResult result);
+  StartProviderOAuth(string provider) => (BrainResult result);
+  ImportCodexAuth(string? path) => (BrainResult result);
+  ClearProviderCredential(string provider) => (BrainResult result);
+
+  // API-key entry is a temporary dev/product surface until the provider
+  // settings UI swaps storage to Keychain. Secrets go only to the helper stdin;
+  // they are never echoed back through BrainEvent.
+  SetProviderApiKey(string provider, string api_key) => (BrainResult result);
+  RespondToUserPrompt(string session_id, string tool_call_id,
+      string response_json, bool cancelled) => (BrainResult result);
+};
