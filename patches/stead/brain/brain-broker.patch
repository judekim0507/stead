+mojom::BrainResultPtr SteadBrainService::MakeResult(bool ok,
+                                                   std::string request_id,
+                                                   std::string code,
+                                                   std::string message) {
+  auto result = mojom::BrainResult::New();
+  result->ok = ok;
+  result->request_id = std::move(request_id);
+  result->code = std::move(code);
+  result->message = std::move(message);
+  return result;
+}
+
+void SteadBrainService::OnBrainLine(std::string line) {
+  std::optional<base::DictValue> event =
+      base::JSONReader::ReadDict(line, base::JSON_PARSE_RFC);
+  if (!event) {
+    base::DictValue error;
+    error.Set("type", "error");
+    error.Set("code", "malformed_brain_json");
+    error.Set("message", "stead-brain emitted malformed JSON.");
+    EmitEvent(error);
+    return;
+  }
+  if (const std::string* type = event->FindString("type");
+      type && *type == "ready") {
+    initialized_ = true;
+  }
+  EmitEvent(*event);
+  if (const std::string* type = event->FindString("type");
+      type && *type == "tool_call") {
+    HandleToolCall(*event);
+  }
+}
+
+void SteadBrainService::OnBrainPipeClosed() {
+  if (!process_.IsValid()) {
+    return;
+  }
+  process_.Close();
+  stdin_write_.reset();
+  initialized_ = false;
+  base::DictValue event;
+  event.Set("type", "error");
+  event.Set("code", "brain_exited");
+  event.Set("message", "stead-brain helper exited.");
+  EmitEvent(event);
+}
+
+void SteadBrainService::EmitEvent(const base::DictValue& event) {
+  auto out = mojom::BrainEvent::New();
+  out->type = OptionalString(event, "type");
+  out->request_id = OptionalString(event, "request_id");
+  out->session_id = OptionalString(event, "session_id");
+  out->payload_json = base::WriteJson(event).value_or("{}");
+  for (auto& observer : observers_) {
+    observer->OnBrainEvent(out.Clone());
+  }
+}
+
+void SteadBrainService::HandleToolCall(const base::DictValue& event) {
+  std::string session_id = OptionalString(event, "session_id");
+  std::string tool_call_id = OptionalString(event, "tool_call_id");
+  std::string tool_name = OptionalString(event, "name");
+  if (session_id.empty() || tool_call_id.empty()) {
+    return;
+  }
+  if (tool_name == "ask_user") {
+    pending_user_prompts_.insert(UserPromptKey(session_id, tool_call_id));
+    return;
+  }
+  const base::DictValue* args = event.FindDict("arguments");
+  base::DictValue empty_args;
+  const base::DictValue& arguments = args ? *args : empty_args;
+
+  SteadAgentControlService* control =
+      profile_ ? SteadAgentControlServiceFactory::GetForProfile(profile_)
+               : nullptr;
+  if (!control) {
+    SendToolError(session_id, tool_call_id,
+                  "Browser control service is not available.");
+    return;
+  }
+
+  auto action_done = [](base::WeakPtr<SteadBrainService> service,
+                        std::string session_id, std::string tool_call_id,
+                        mojom::ActionResultPtr result) {
+    if (!service) {
+      return;
+    }
+    if (!result) {
+      service->SendToolError(session_id, tool_call_id,
+                             "Browser action returned no result.");
+      return;
+    }
+    base::DictValue content;
+    content.Set("result", ActionResultToDict(*result));
+    std::optional<std::string> error;
+    if (!result->ok) {
+      error = result->message;
+    }
+    service->SendToolResult(session_id, tool_call_id, result->ok,
+                            std::move(content), std::move(error),
+                            /*tainted=*/false);
+  };
+
+  if (tool_name == "browser.list_tabs") {
+    control->ListTabs(base::BindOnce(
+        [](base::WeakPtr<SteadBrainService> service, std::string session_id,
+           std::string tool_call_id, std::vector<mojom::TabInfoPtr> tabs) {
+          if (!service) {
+            return;
+          }
+          base::ListValue list;
+          for (const mojom::TabInfoPtr& tab : tabs) {
+            if (tab) {
+              list.Append(TabInfoToDict(*tab));
+            }
+          }
+          base::DictValue content;
+          content.Set("tabs", std::move(list));
+          service->SendToolResult(session_id, tool_call_id, true,
+                                  std::move(content), std::nullopt,
+                                  /*tainted=*/false);
+        },
+        weak_factory_.GetWeakPtr(), session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.snapshot") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    if (!tab_id) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.snapshot requires integer tab_id.");
+      return;
+    }
+    control->GetSnapshot(
+        *tab_id, ParseSnapshotOptions(arguments),
+        base::BindOnce(
+            [](base::WeakPtr<SteadBrainService> service,
+               std::string session_id, std::string tool_call_id,
+               mojom::ActionResultPtr result, mojom::SnapshotPtr snapshot) {
+              if (!service) {
+                return;
+              }
+              if (!result) {
+                service->SendToolError(session_id, tool_call_id,
+                                       "Snapshot returned no result.");
+                return;
+              }
+              base::DictValue content;
+              content.Set("result", ActionResultToDict(*result));
+              if (snapshot) {
+                content.Set("snapshot", SnapshotToDict(*snapshot));
+              }
+              std::optional<std::string> error;
+              if (!result->ok) {
+                error = result->message;
+              }
+              service->SendToolResult(session_id, tool_call_id, result->ok,
+                                      std::move(content), std::move(error),
+                                      /*tainted=*/false);
+            },
+            weak_factory_.GetWeakPtr(), session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.navigate") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    const std::string* url = arguments.FindString("url");
+    if (!tab_id || !url) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.navigate requires tab_id and url.");
+      return;
+    }
+    control->Navigate(*tab_id, GURL(*url),
+                      base::BindOnce(action_done, weak_factory_.GetWeakPtr(),
+                                     session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.open_tab") {
+    const std::string* url = arguments.FindString("url");
+    if (!url) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.open_tab requires url.");
+      return;
+    }
+    const bool agent_owned =
+        arguments.FindBool("agent_owned").value_or(true);
+    control->OpenTab(
+        GURL(*url), agent_owned,
+        base::BindOnce(
+            [](base::WeakPtr<SteadBrainService> service,
+               std::string session_id, std::string tool_call_id,
+               mojom::ActionResultPtr result, int32_t tab_id) {
+              if (!service) {
+                return;
+              }
+              if (!result) {
+                service->SendToolError(session_id, tool_call_id,
+                                       "OpenTab returned no result.");
+                return;
+              }
+              base::DictValue content;
+              content.Set("result", ActionResultToDict(*result));
+              content.Set("tab_id", tab_id);
+              std::optional<std::string> error;
+              if (!result->ok) {
+                error = result->message;
+              }
+              service->SendToolResult(session_id, tool_call_id, result->ok,
+                                      std::move(content), std::move(error),
+                                      /*tainted=*/false);
+            },
+            weak_factory_.GetWeakPtr(), session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.close_tab") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    if (!tab_id) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.close_tab requires integer tab_id.");
+      return;
+    }
+    control->CloseTab(*tab_id,
+                      base::BindOnce(action_done, weak_factory_.GetWeakPtr(),
+                                     session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.probe_node") {
+    mojom::NodeRefPtr ref = ParseNodeRefArg(arguments);
+    if (!ref) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.probe_node requires ref { frame, ax_node_id }.");
+      return;
+    }
+    control->ProbeNode(
+        std::move(ref),
+        base::BindOnce(
+            [](base::WeakPtr<SteadBrainService> service,
+               std::string session_id, std::string tool_call_id,
+               mojom::ReadResultPtr result, mojom::NodeProbePtr probe) {
+              if (!service) {
+                return;
+              }
+              if (!result) {
+                service->SendToolError(session_id, tool_call_id,
+                                       "ProbeNode returned no result.");
+                return;
+              }
+              base::DictValue content;
+              content.Set("result", ReadResultToDict(*result));
+              if (probe) {
+                content.Set("probe", NodeProbeToDict(*probe));
+              }
+              std::optional<std::string> error;
+              if (!result->ok) {
+                error = result->message;
+              }
+              service->SendToolResult(session_id, tool_call_id, result->ok,
+                                      std::move(content), std::move(error),
+                                      /*tainted=*/false);
+            },
+            weak_factory_.GetWeakPtr(), session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.screenshot") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    if (!tab_id) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.screenshot requires integer tab_id.");
+      return;
+    }
+    mojom::NodeRefPtr ref;
+    if (arguments.FindDict("ref")) {
+      ref = ParseNodeRefArg(arguments);
+      if (!ref) {
+        SendToolError(session_id, tool_call_id,
+                      "browser.screenshot ref was invalid.");
+        return;
+      }
+    }
+    control->Screenshot(
+        *tab_id, std::move(ref),
+        base::BindOnce(
+            [](base::WeakPtr<SteadBrainService> service,
+               std::string session_id, std::string tool_call_id,
+               mojom::ReadResultPtr result,
+               std::optional<mojo_base::BigBuffer> png) {
+              if (!service) {
+                return;
+              }
+              if (!result) {
+                service->SendToolError(session_id, tool_call_id,
+                                       "Screenshot returned no result.");
+                return;
+              }
+              base::DictValue content;
+              content.Set("result", ReadResultToDict(*result));
+              if (result->ok && png) {
+                content.Set("image_bytes",
+                            base::NumberToString(png->size()));
+                if (png->size() <= kMaxBrainImageBytes) {
+                  content.Set("mime_type", "image/png");
+                  content.Set("image_base64",
+                              base::Base64Encode(base::span(*png)));
+                  content.Set("image_included", true);
+                } else {
+                  content.Set("image_omitted", true);
+                  content.Set("reason",
+                              "Screenshot exceeded the brain stdio image cap.");
+                }
+              } else {
+                content.Set("image_omitted", true);
+                if (result->ok) {
+                  content.Set("reason", "Screenshot returned no PNG payload.");
+                }
+              }
+              std::optional<std::string> error;
+              if (!result->ok) {
+                error = result->message;
+              }
+              service->SendToolResult(session_id, tool_call_id, result->ok,
+                                      std::move(content), std::move(error),
+                                      /*tainted=*/false);
+            },
+            weak_factory_.GetWeakPtr(), session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.eval") {
+    mojom::FrameRefPtr frame = ParseFrameRefArg(arguments);
+    const std::string* js = arguments.FindString("js");
+    if (!frame || !js) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.eval requires frame and js.");
+      return;
+    }
+    control->Eval(
+        std::move(frame), *js,
+        base::BindOnce(
+            [](base::WeakPtr<SteadBrainService> service,
+               std::string session_id, std::string tool_call_id,
+               mojom::ActionResultPtr result,
+               const std::optional<std::string>& json_result) {
+              if (!service) {
+                return;
+              }
+              if (!result) {
+                service->SendToolError(session_id, tool_call_id,
+                                       "Eval returned no result.");
+                return;
+              }
+              base::DictValue content;
+              content.Set("result", ActionResultToDict(*result));
+              if (json_result) {
+                content.Set("json_result", *json_result);
+              }
+              std::optional<std::string> error;
+              if (!result->ok) {
+                error = result->message;
+              }
+              service->SendToolResult(session_id, tool_call_id, result->ok,
+                                      std::move(content), std::move(error),
+                                      /*tainted=*/false);
+            },
+            weak_factory_.GetWeakPtr(), session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.key") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    const std::string* key = arguments.FindString("key");
+    if (!tab_id || !key) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.key requires tab_id and key.");
+      return;
+    }
+    const int32_t modifiers = FindInt32(arguments, "modifiers").value_or(0);
+    control->Key(*tab_id, *key, modifiers,
+                 base::BindOnce(action_done, weak_factory_.GetWeakPtr(),
+                                session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.scroll") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    std::optional<int32_t> dx = FindInt32(arguments, "dx");
+    std::optional<int32_t> dy = FindInt32(arguments, "dy");
+    if (!tab_id || !dx || !dy) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.scroll requires tab_id, dx, and dy.");
+      return;
+    }
+    control->Scroll(*tab_id, *dx, *dy,
+                    base::BindOnce(action_done, weak_factory_.GetWeakPtr(),
+                                   session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.mouse_move" || tool_name == "browser.mouse_down" ||
+      tool_name == "browser.mouse_up" || tool_name == "browser.mouse_click") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    std::optional<gfx::Point> point = ParsePoint(arguments, "point");
+    if (!tab_id || !point) {
+      SendToolError(session_id, tool_call_id,
+                    "Mouse tool requires tab_id and point {x,y}.");
+      return;
+    }
+    const int32_t button = FindInt32(arguments, "button").value_or(0);
+    const int32_t click_count =
+        FindInt32(arguments, "click_count").value_or(1);
+    auto callback = base::BindOnce(action_done, weak_factory_.GetWeakPtr(),
+                                  session_id, tool_call_id);
+    if (tool_name == "browser.mouse_move") {
+      control->MouseMove(*tab_id, *point, std::move(callback));
+    } else if (tool_name == "browser.mouse_down") {
+      control->MouseDown(*tab_id, *point, button, click_count,
+                         std::move(callback));
+    } else if (tool_name == "browser.mouse_up") {
+      control->MouseUp(*tab_id, *point, button, click_count,
+                       std::move(callback));
+    } else {
+      control->MouseClick(*tab_id, *point, button, click_count,
+                          std::move(callback));
+    }
+    return;
+  }
+
+  if (tool_name == "browser.mouse_drag") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    std::optional<gfx::Point> from = ParsePoint(arguments, "from");
+    std::optional<gfx::Point> to = ParsePoint(arguments, "to");
+    if (!tab_id || !from || !to) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.mouse_drag requires tab_id, from, and to.");
+      return;
+    }
+    const int32_t button = FindInt32(arguments, "button").value_or(0);
+    const int32_t steps = FindInt32(arguments, "steps").value_or(8);
+    control->MouseDrag(*tab_id, *from, *to, button, steps,
+                       base::BindOnce(action_done, weak_factory_.GetWeakPtr(),
+                                      session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.handle_dialog") {
+    const std::string* handle = arguments.FindString("handle");
+    if (!handle) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.handle_dialog requires handle.");
+      return;
+    }
+    const bool accept = arguments.FindBool("accept").value_or(true);
+    control->HandleDialog(
+        *handle, accept, OptionalString(arguments, "prompt_text"),
+        base::BindOnce(action_done, weak_factory_.GetWeakPtr(), session_id,
+                       tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.handle_file_chooser") {
+    const std::string* handle = arguments.FindString("handle");
+    if (!handle) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.handle_file_chooser requires handle.");
+      return;
+    }
+    control->HandleFileChooser(
+        *handle, ParseStringList(arguments, "paths"),
+        base::BindOnce(action_done, weak_factory_.GetWeakPtr(), session_id,
+                       tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.click" || tool_name == "browser.focus" ||
+      tool_name == "browser.scroll_into_view" ||
+      tool_name == "browser.fill") {
+    mojom::NodeRefPtr ref = ParseNodeRefArg(arguments);
+    if (!ref) {
+      SendToolError(session_id, tool_call_id,
+                    "Node action requires ref { frame, ax_node_id }.");
+      return;
+    }
+    auto callback = base::BindOnce(action_done, weak_factory_.GetWeakPtr(),
+                                  session_id, tool_call_id);
+    if (tool_name == "browser.click") {
+      control->Click(std::move(ref), std::move(callback));
+    } else if (tool_name == "browser.focus") {
+      control->Focus(std::move(ref), std::move(callback));
+    } else if (tool_name == "browser.scroll_into_view") {
+      control->ScrollIntoView(std::move(ref), std::move(callback));
+    } else {
+      const std::string* value = arguments.FindString("value");
+      if (!value) {
+        value = arguments.FindString("text");
+      }
+      if (!value) {
+        SendToolError(session_id, tool_call_id,
+                      "browser.fill requires value or text.");
+        return;
+      }
+      control->Fill(std::move(ref), *value, std::move(callback));
+    }
+    return;
+  }
+
+  if (tool_name == "browser.mark_credential_injection") {
+    mojom::FrameRefPtr frame = ParseFrameRefArg(arguments);
+    if (!frame) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.mark_credential_injection requires frame.");
+      return;
+    }
+    control->MarkCredentialInjection(
+        std::move(frame),
+        base::BindOnce(action_done, weak_factory_.GetWeakPtr(), session_id,
+                       tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.list_credentials") {
+    std::optional<int32_t> tab_id = FindInt32(arguments, "tab_id");
+    const std::string* origin = arguments.FindString("origin");
+    if (!tab_id || !origin) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.list_credentials requires tab_id and origin.");
+      return;
+    }
+    control->ListCredentials(
+        *tab_id, url::Origin::Create(GURL(*origin)),
+        CredentialUsePolicyForSession(session_id),
+        base::BindOnce(
+            [](base::WeakPtr<SteadBrainService> service,
+               std::string session_id, std::string tool_call_id,
+               mojom::ReadResultPtr result,
+               std::vector<mojom::CredentialRefPtr> credentials) {
+              if (!service) {
+                return;
+              }
+              if (!result) {
+                service->SendToolError(session_id, tool_call_id,
+                                       "ListCredentials returned no result.");
+                return;
+              }
+              base::ListValue list;
+              for (const mojom::CredentialRefPtr& credential : credentials) {
+                if (credential) {
+                  list.Append(CredentialRefToDict(*credential));
+                }
+              }
+              base::DictValue content;
+              content.Set("result", ReadResultToDict(*result));
+              content.Set("credentials", std::move(list));
+              std::optional<std::string> error;
+              if (!result->ok) {
+                error = result->message;
+              }
+              service->SendToolResult(session_id, tool_call_id, result->ok,
+                                      std::move(content), std::move(error),
+                                      /*tainted=*/false);
+            },
+            weak_factory_.GetWeakPtr(), session_id, tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.fill_credential") {
+    const base::DictValue* credential_dict = arguments.FindDict("credential");
+    const base::DictValue* username_dict =
+        arguments.FindDict("username_field");
+    const base::DictValue* password_dict =
+        arguments.FindDict("password_field");
+    mojom::CredentialRefPtr credential =
+        credential_dict ? ParseCredentialRef(*credential_dict) : nullptr;
+    mojom::NodeRefPtr username =
+        username_dict ? ParseNodeRef(*username_dict) : nullptr;
+    mojom::NodeRefPtr password =
+        password_dict ? ParseNodeRef(*password_dict) : nullptr;
+    if (!credential || !username || !password) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.fill_credential requires credential, "
+                    "username_field, and password_field.");
+      return;
+    }
+    control->FillCredential(
+        std::move(credential), std::move(username), std::move(password),
+        CredentialUsePolicyForSession(session_id),
+        base::BindOnce(action_done, weak_factory_.GetWeakPtr(), session_id,
+                       tool_call_id));
+    return;
+  }
+
+  if (tool_name == "browser.fill_totp") {
+    const base::DictValue* credential_dict = arguments.FindDict("credential");
+    mojom::CredentialRefPtr credential =
+        credential_dict ? ParseCredentialRef(*credential_dict) : nullptr;
+    const base::DictValue* field_dict = arguments.FindDict("field");
+    mojom::NodeRefPtr field =
+        field_dict ? ParseNodeRef(*field_dict) : ParseNodeRefArg(arguments);
+    if (!credential || !field) {
+      SendToolError(session_id, tool_call_id,
+                    "browser.fill_totp requires credential and field ref.");
+      return;
+    }
+    control->FillTotp(std::move(credential), std::move(field),
+                      CredentialUsePolicyForSession(session_id),
+                      base::BindOnce(action_done, weak_factory_.GetWeakPtr(),
+                                     session_id, tool_call_id));
+    return;
+  }
+
+  SendToolUnavailableResult(session_id, tool_call_id, tool_name);
+}
+
+void SteadBrainService::SendToolResult(
+    const std::string& session_id,
+    const std::string& tool_call_id,
+    bool ok,
+    base::DictValue content,
+    std::optional<std::string> error,
+    bool tainted) {
+  base::DictValue request = MakeRequest("tool_result", NextRequestId());
+  request.Set("session_id", session_id);
+  request.Set("tool_call_id", tool_call_id);
+  base::DictValue result;
+  result.Set("ok", ok);
+  result.Set("content", std::move(content));
+  if (error) {
+    result.Set("error", *error);
+  }
+  result.Set("tainted", tainted);
+  request.Set("result", std::move(result));
+  SendRequest(std::move(request));
+}
+
+void SteadBrainService::SendToolError(const std::string& session_id,
+                                      const std::string& tool_call_id,
+                                      std::string message) {
+  SendToolResult(session_id, tool_call_id, false, EmptyDict(),
+                 std::move(message), /*tainted=*/false);
+}
+
+void SteadBrainService::SendToolUnavailableResult(
+    const std::string& session_id,
+    const std::string& tool_call_id,
+    const std::string& tool_name) {
+  SendToolError(session_id, tool_call_id,
+                base::StrCat({"Browser tool is not wired yet: ", tool_name}));
+}
+
+std::string SteadBrainService::UserPromptKey(
+    const std::string& session_id,
+    const std::string& tool_call_id) const {
+  return base::StrCat({session_id, ":", tool_call_id});
+}
+
+mojom::BrainPermissionMode SteadBrainService::PermissionModeForSession(
+    const std::string& session_id) const {
+  auto it = session_permission_modes_.find(session_id);
+  return it == session_permission_modes_.end() ? mojom::BrainPermissionMode::kRead
+                                               : it->second;
+}
+
+mojom::CredentialUsePolicy SteadBrainService::CredentialUsePolicyForSession(
+    const std::string& session_id) const {
+  return CredentialUsePolicyForPermissionMode(PermissionModeForSession(session_id));
+}
