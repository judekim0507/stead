+std::string SteadBrainService::NextRequestId() {
+  return base::StringPrintf("browser_%lld",
+                            static_cast<long long>(next_request_id_++));
+}
+
+mojom::BrainResultPtr SteadBrainService::SendRequest(base::DictValue request) {
+  std::string error_message;
+  std::string request_id = OptionalString(request, "request_id");
+  if (!EnsureStarted(&error_message)) {
+    return MakeResult(false, std::move(request_id), "brain_unavailable",
+                      std::move(error_message));
+  }
+  std::optional<std::string> json = base::WriteJson(request);
+  if (!json) {
+    return MakeResult(false, std::move(request_id), "json_encode_failed",
+                      "Could not encode brain request.");
+  }
+  json->push_back('\n');
+  if (!WriteLine(*json)) {
+    StopHelper();
+    return MakeResult(false, std::move(request_id), "brain_write_failed",
+                      "Could not write to stead-brain helper.");
+  }
+  return MakeResult(true, std::move(request_id), "accepted",
+                    "Request sent to stead-brain.");
+}
+
+bool SteadBrainService::WriteLine(std::string_view line) {
+  return stdin_write_.is_valid() &&
+         base::WriteFileDescriptor(stdin_write_.get(), line);
+}
