@@ -0,0 +1,1438 @@
+// Copyright 2026 The Stead Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/stead/brain/stead_brain_service.h"
+
+#include <fcntl.h>
+#include <unistd.h>
+
+#include <optional>
+#include <string>
+#include <string_view>
+#include <utility>
+#include <vector>
+
+#include "base/base64.h"
+#include "base/command_line.h"
+#include "base/files/file_util.h"
+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "base/path_service.h"
+#include "base/posix/eintr_wrapper.h"
+#include "base/process/launch.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/strcat.h"
+#include "base/strings/stringprintf.h"
+#include "base/task/sequenced_task_runner.h"
+#include "base/task/thread_pool.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/stead/agent_control/stead_agent_control_service.h"
+#include "chrome/browser/ui/stead/agent_control/stead_agent_control_service_factory.h"
+#include "components/prefs/pref_service.h"
+#include "ui/gfx/geometry/point.h"
+#include "ui/gfx/geometry/rect.h"
+#include "url/gurl.h"
+#include "url/origin.h"
+
+namespace stead {
+namespace {
+
+constexpr int kProtocolVersion = 1;
+constexpr size_t kMaxBrainLineBytes = 4 * 1024 * 1024;
+constexpr size_t kMaxBrainImageBytes = 2 * 1024 * 1024;
+constexpr char kLastPermissionModePref[] = "stead.last_permission_mode";
+
+std::string OptionalString(const base::DictValue& dict, std::string_view key) {
+  const std::string* value = dict.FindString(key);
+  return value ? *value : std::string();
+}
+
+base::DictValue EmptyDict() {
+  return base::DictValue();
+}
+
+std::optional<int32_t> FindInt32(const base::DictValue& dict,
+                                 std::string_view key);
+
+base::DictValue ActionResultToDict(const mojom::ActionResult& result) {
+  base::DictValue out;
+  out.Set("action_id", result.action_id);
+  out.Set("ok", result.ok);
+  out.Set("code", result.code);
+  out.Set("message", result.message);
+  out.Set("stale", result.stale);
+  out.Set("needs_snapshot", result.needs_snapshot);
+  out.Set("needs_confirmation", result.needs_confirmation);
+  out.Set("target_missing", result.target_missing);
+  out.Set("blocked_by", result.blocked_by);
+  out.Set("new_generation", static_cast<int>(result.new_generation));
+  return out;
+}
+
+base::DictValue ReadResultToDict(const mojom::ReadResult& result) {
+  base::DictValue out;
+  out.Set("ok", result.ok);
+  out.Set("code", result.code);
+  out.Set("message", result.message);
+  out.Set("blocked_by", result.blocked_by);
+  return out;
+}
+
+base::DictValue FrameRefToDict(const mojom::FrameRef& frame) {
+  base::DictValue out;
+  out.Set("tab_id", frame.tab_id);
+  out.Set("frame_token", frame.frame_token);
+  out.Set("snapshot_generation", static_cast<int>(frame.snapshot_generation));
+  return out;
+}
+
+base::DictValue NodeRefToDict(const mojom::NodeRef& ref) {
+  base::DictValue out;
+  if (ref.frame) {
+    out.Set("frame", FrameRefToDict(*ref.frame));
+  }
+  out.Set("ax_node_id", ref.ax_node_id);
+  return out;
+}
+
+base::DictValue AxNodeToDict(const mojom::AxNode& node) {
+  base::DictValue out;
+  if (node.ref) {
+    out.Set("ref", NodeRefToDict(*node.ref));
+  }
+  out.Set("role", node.role);
+  out.Set("name", node.name);
+  out.Set("has_value", node.has_value);
+  if (node.has_value) {
+    out.Set("value", node.value);
+  }
+  out.Set("has_checked", node.has_checked);
+  if (node.has_checked) {
+    out.Set("checked", node.checked);
+  }
+  out.Set("clickable", node.clickable);
+  out.Set("editable", node.editable);
+  out.Set("focused", node.focused);
+  out.Set("disabled", node.disabled);
+  out.Set("has_bounds", node.has_bounds);
+  if (node.has_bounds) {
+    base::DictValue bounds;
+    bounds.Set("x", node.bounds.x());
+    bounds.Set("y", node.bounds.y());
+    bounds.Set("width", node.bounds.width());
+    bounds.Set("height", node.bounds.height());
+    out.Set("bounds", std::move(bounds));
+  }
+  base::ListValue children;
+  for (const mojom::AxNodePtr& child : node.children) {
+    if (child) {
+      children.Append(AxNodeToDict(*child));
+    }
+  }
+  out.Set("children", std::move(children));
+  return out;
+}
+
+base::DictValue SnapshotToDict(const mojom::Snapshot& snapshot) {
+  base::DictValue out;
+  out.Set("tab_id", snapshot.tab_id);
+  out.Set("url", snapshot.url);
+  out.Set("title", snapshot.title);
+  out.Set("generation", static_cast<int>(snapshot.generation));
+  out.Set("node_count", static_cast<int>(snapshot.node_count));
+  out.Set("truncated", snapshot.truncated);
+  out.Set("capture_time_us", base::NumberToString(snapshot.capture_time_us));
+  if (snapshot.root) {
+    out.Set("root", AxNodeToDict(*snapshot.root));
+  }
+  return out;
+}
+
+base::DictValue TabInfoToDict(const mojom::TabInfo& tab) {
+  base::DictValue out;
+  out.Set("tab_id", tab.tab_id);
+  out.Set("url", tab.url);
+  out.Set("title", tab.title);
+  out.Set("active", tab.active);
+  out.Set("likely_authenticated", tab.likely_authenticated);
+  return out;
+}
+
+base::DictValue RectToDict(const gfx::Rect& rect) {
+  base::DictValue out;
+  out.Set("x", rect.x());
+  out.Set("y", rect.y());
+  out.Set("width", rect.width());
+  out.Set("height", rect.height());
+  return out;
+}
+
+base::DictValue NodeProbeToDict(const mojom::NodeProbe& probe) {
+  base::DictValue out;
+  out.Set("found", probe.found);
+  out.Set("target_matched", probe.target_matched);
+  out.Set("occluded", probe.occluded);
+  out.Set("visible", probe.visible);
+  out.Set("disabled", probe.disabled);
+  out.Set("editable", probe.editable);
+  out.Set("tag_name", probe.tag_name);
+  out.Set("id", probe.id);
+  out.Set("class_name", probe.class_name);
+  out.Set("name_attr", probe.name_attr);
+  out.Set("type_attr", probe.type_attr);
+  out.Set("role_attr", probe.role_attr);
+  out.Set("aria_label", probe.aria_label);
+  out.Set("display", probe.display);
+  out.Set("visibility", probe.visibility);
+  out.Set("pointer_events", probe.pointer_events);
+  out.Set("cursor", probe.cursor);
+  out.Set("opacity", probe.opacity);
+  out.Set("client_rect", RectToDict(probe.client_rect));
+  base::ListValue stack;
+  for (const std::string& entry : probe.hit_test_stack) {
+    stack.Append(entry);
+  }
+  out.Set("hit_test_stack", std::move(stack));
+  return out;
+}
+
+base::DictValue CredentialRefToDict(const mojom::CredentialRef& credential) {
+  base::DictValue out;
+  out.Set("handle", credential.opaque_handle);
+  out.Set("label", credential.label);
+  out.Set("source", credential.source);
+  out.Set("has_totp", credential.has_totp);
+  out.Set("has_passkey", credential.has_passkey);
+  return out;
+}
+
+mojom::CredentialRefPtr ParseCredentialRef(const base::DictValue& dict) {
+  const std::string* handle = dict.FindString("handle");
+  if (!handle || handle->empty()) {
+    return nullptr;
+  }
+  auto credential = mojom::CredentialRef::New();
+  credential->opaque_handle = *handle;
+  credential->label = OptionalString(dict, "label");
+  credential->source = OptionalString(dict, "source");
+  credential->has_totp = dict.FindBool("has_totp").value_or(false);
+  credential->has_passkey = dict.FindBool("has_passkey").value_or(false);
+  return credential;
+}
+
+std::optional<gfx::Point> ParsePoint(const base::DictValue& args,
+                                     std::string_view key) {
+  const base::DictValue* dict = args.FindDict(key);
+  if (!dict) {
+    dict = &args;
+  }
+  std::optional<int32_t> x = FindInt32(*dict, "x");
+  std::optional<int32_t> y = FindInt32(*dict, "y");
+  if (!x || !y) {
+    return std::nullopt;
+  }
+  return gfx::Point(*x, *y);
+}
+
+std::vector<std::string> ParseStringList(const base::DictValue& args,
+                                         std::string_view key) {
+  std::vector<std::string> out;
+  const base::ListValue* list = args.FindList(key);
+  if (!list) {
+    return out;
+  }
+  for (const base::Value& value : *list) {
+    if (value.is_string()) {
+      out.push_back(value.GetString());
+    }
+  }
+  return out;
+}
+
+std::optional<int32_t> FindInt32(const base::DictValue& dict,
+                                 std::string_view key) {
+  std::optional<int> value = dict.FindInt(key);
+  if (!value) {
+    return std::nullopt;
+  }
+  return static_cast<int32_t>(*value);
+}
+
+mojom::FrameRefPtr ParseFrameRef(const base::DictValue& dict) {
+  std::optional<int32_t> tab_id = FindInt32(dict, "tab_id");
+  const std::string* frame_token = dict.FindString("frame_token");
+  std::optional<int32_t> generation = FindInt32(dict, "snapshot_generation");
+  if (!tab_id || !frame_token || !generation || *generation < 0) {
+    return nullptr;
+  }
+  return mojom::FrameRef::New(*tab_id, *frame_token,
+                              static_cast<uint32_t>(*generation));
+}
+
+mojom::NodeRefPtr ParseNodeRef(const base::DictValue& dict) {
+  const base::DictValue* frame_dict = dict.FindDict("frame");
+  std::optional<int32_t> ax_node_id = FindInt32(dict, "ax_node_id");
+  if (!frame_dict || !ax_node_id) {
+    return nullptr;
+  }
+  mojom::FrameRefPtr frame = ParseFrameRef(*frame_dict);
+  if (!frame) {
+    return nullptr;
+  }
+  return mojom::NodeRef::New(std::move(frame), *ax_node_id);
+}
+
+mojom::NodeRefPtr ParseNodeRefArg(const base::DictValue& args) {
+  if (const base::DictValue* ref = args.FindDict("ref")) {
+    return ParseNodeRef(*ref);
+  }
+  return ParseNodeRef(args);
+}
+
+mojom::FrameRefPtr ParseFrameRefArg(const base::DictValue& args) {
+  if (const base::DictValue* frame = args.FindDict("frame")) {
+    return ParseFrameRef(*frame);
+  }
+  return ParseFrameRef(args);
+}
+
+mojom::SnapshotOptionsPtr ParseSnapshotOptions(const base::DictValue& args) {
+  auto options = mojom::SnapshotOptions::New();
+  options->max_nodes = 0;
+  options->include_bounds = true;
+  options->include_values = true;
+  if (std::optional<int32_t> max_nodes = FindInt32(args, "max_nodes");
+      max_nodes && *max_nodes > 0) {
+    options->max_nodes = static_cast<uint32_t>(*max_nodes);
+  }
+  if (std::optional<bool> include_bounds = args.FindBool("include_bounds")) {
+    options->include_bounds = *include_bounds;
+  }
+  if (std::optional<bool> include_values = args.FindBool("include_values")) {
+    options->include_values = *include_values;
+  }
+  return options;
+}
+
+const char* PermissionModeToProtocolString(
+    mojom::BrainPermissionMode permission_mode) {
+  switch (permission_mode) {
+    case mojom::BrainPermissionMode::kAsk:
+      return "ask";
+    case mojom::BrainPermissionMode::kRead:
+      return "read";
+    case mojom::BrainPermissionMode::kFull:
+      return "full";
+  }
+  return "read";
+}
+
+mojom::BrainPermissionMode PermissionModeFromProtocolString(
+    std::string_view permission_mode) {
+  if (permission_mode == "read") {
+    return mojom::BrainPermissionMode::kRead;
+  }
+  if (permission_mode == "full") {
+    return mojom::BrainPermissionMode::kFull;
+  }
+  return mojom::BrainPermissionMode::kAsk;
+}
+
+mojom::CredentialUsePolicy CredentialUsePolicyForPermissionMode(
+    mojom::BrainPermissionMode permission_mode) {
+  return permission_mode == mojom::BrainPermissionMode::kAsk
+             ? mojom::CredentialUsePolicy::kAskForApproval
+             : mojom::CredentialUsePolicy::kPreauthorized;
+}
