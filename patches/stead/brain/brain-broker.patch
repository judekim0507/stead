+void SteadBrainService::RespondToUserPrompt(
+    const std::string& session_id,
+    const std::string& tool_call_id,
+    const std::string& response_json,
+    bool cancelled,
+    RespondToUserPromptCallback callback) {
+  const std::string request_id = NextRequestId();
+  const std::string key = UserPromptKey(session_id, tool_call_id);
+  auto it = pending_user_prompts_.find(key);
+  if (it == pending_user_prompts_.end()) {
+    std::move(callback).Run(MakeResult(
+        false, request_id, "prompt_not_pending",
+        "No pending ask_user prompt matched that session/tool id."));
+    return;
+  }
+  pending_user_prompts_.erase(it);
+
+  if (cancelled) {
+    SendToolResult(session_id, tool_call_id, false, EmptyDict(),
+                   "User cancelled the prompt.", /*tainted=*/false);
+    std::move(callback).Run(MakeResult(true, request_id, "accepted",
+                                       "Prompt cancellation sent."));
+    return;
+  }
+
+  if (response_json.size() > kMaxBrainLineBytes) {
+    pending_user_prompts_.insert(key);
+    std::move(callback).Run(MakeResult(false, request_id,
+                                       "prompt_response_too_large",
+                                       "Prompt response JSON was too large."));
+    return;
+  }
+  std::optional<base::DictValue> content =
+      base::JSONReader::ReadDict(response_json, base::JSON_PARSE_RFC);
+  if (!content) {
+    std::move(callback).Run(MakeResult(
+        false, request_id, "invalid_prompt_response",
+        "Prompt response_json must be a JSON object."));
+    pending_user_prompts_.insert(key);
+    return;
+  }
+  SendToolResult(session_id, tool_call_id, true, std::move(*content),
+                 std::nullopt, /*tainted=*/false);
+  std::move(callback).Run(MakeResult(true, request_id, "accepted",
+                                     "Prompt response sent."));
+}
+
+void SteadBrainService::ReadStdoutLoop(
+    base::ScopedFD stdout_fd,
+    scoped_refptr<base::SequencedTaskRunner> ui_task_runner,
+    base::WeakPtr<SteadBrainService> weak_service) {
+  std::string pending;
+  char buffer[4096];
+  for (;;) {
+    ssize_t n = HANDLE_EINTR(read(stdout_fd.get(), buffer, sizeof(buffer)));
+    if (n <= 0) {
+      break;
+    }
+    pending.append(buffer, static_cast<size_t>(n));
+    if (pending.size() > kMaxBrainLineBytes) {
+      pending.clear();
+    }
+    for (;;) {
+      size_t newline = pending.find('\n');
+      if (newline == std::string::npos) {
+        break;
+      }
+      std::string line = pending.substr(0, newline);
+      pending.erase(0, newline + 1);
+      ui_task_runner->PostTask(
+          FROM_HERE, base::BindOnce(&SteadBrainService::OnBrainLine,
+                                    weak_service, std::move(line)));
+    }
+  }
+  ui_task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(&SteadBrainService::OnBrainPipeClosed, weak_service));
+}
+
+bool SteadBrainService::EnsureStarted(std::string* error_message) {
+  if (process_.IsValid() && stdin_write_.is_valid()) {
+    return true;
+  }
+  return LaunchHelper(error_message);
+}
+
+bool SteadBrainService::LaunchHelper(std::string* error_message) {
+  base::FilePath helper = ResolveHelperPath();
+  if (helper.empty()) {
+    *error_message = "Could not resolve stead-brain helper path.";
+    return false;
+  }
+  if (!base::PathExists(helper)) {
+    *error_message = "stead-brain helper was not found at " +
+                     helper.AsUTF8Unsafe() + ".";
+    return false;
+  }
+
+  base::ScopedFD child_stdin;
+  base::ScopedFD parent_stdin;
+  base::ScopedFD parent_stdout;
+  base::ScopedFD child_stdout;
+  if (!base::CreatePipe(&child_stdin, &parent_stdin) ||
+      !base::CreatePipe(&parent_stdout, &child_stdout)) {
+    *error_message = "Could not create stead-brain stdio pipes.";
+    return false;
+  }
+
+  base::LaunchOptions options;
+  options.fds_to_remap.emplace_back(child_stdin.get(), STDIN_FILENO);
+  options.fds_to_remap.emplace_back(child_stdout.get(), STDOUT_FILENO);
+
+  base::CommandLine command(helper);
+  process_ = base::LaunchProcess(command, options);
+  if (!process_.IsValid()) {
+    *error_message = "Could not launch stead-brain helper.";
+    return false;
+  }
+
+  child_stdin.reset();
+  child_stdout.reset();
+  stdin_write_ = std::move(parent_stdin);
+  initialized_ = false;
+
+  scoped_refptr<base::SequencedTaskRunner> ui_task_runner =
+      base::SequencedTaskRunner::GetCurrentDefault();
+  base::ThreadPool::PostTask(
+      FROM_HERE, {base::MayBlock(), base::TaskShutdownBehavior::SKIP_ON_SHUTDOWN},
+      base::BindOnce(&SteadBrainService::ReadStdoutLoop, std::move(parent_stdout),
+                     std::move(ui_task_runner), weak_factory_.GetWeakPtr()));
+  return true;
+}
+
+void SteadBrainService::StopHelper() {
+  initialized_ = false;
+  pending_user_prompts_.clear();
+  stdin_write_.reset();
+  if (process_.IsValid()) {
+    process_.Terminate(0, /*wait=*/false);
+    process_.Close();
+  }
+}
+
+base::FilePath SteadBrainService::ResolveHelperPath() const {
+  base::FilePath exe_dir;
+  if (!base::PathService::Get(base::DIR_EXE, &exe_dir)) {
+    return base::FilePath();
+  }
+  return exe_dir.Append("stead-brain");
+}
