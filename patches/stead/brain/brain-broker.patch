+// Copyright 2026 The Stead Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/stead/brain/stead_brain_service_factory.h"
+
+#include <memory>
+#include <utility>
+
+#include "base/no_destructor.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/profiles/profile_selections.h"
+#include "chrome/browser/ui/stead/brain/stead_brain_service.h"
+#include "components/keyed_service/core/keyed_service.h"
+
+namespace stead {
+
+// static
+SteadBrainService* SteadBrainServiceFactory::GetForProfile(Profile* profile) {
+  if (!profile) {
+    return nullptr;
+  }
+  return static_cast<SteadBrainService*>(
+      GetInstance()->GetServiceForBrowserContext(profile, /*create=*/true));
+}
+
+// static
+SteadBrainServiceFactory* SteadBrainServiceFactory::GetInstance() {
+  static base::NoDestructor<SteadBrainServiceFactory> instance;
+  return instance.get();
+}
+
+// static
+void SteadBrainServiceFactory::BindBrainConsole(
+    Profile* profile,
+    mojo::PendingReceiver<mojom::BrainConsole> receiver) {
+  SteadBrainService* service = GetForProfile(profile);
+  if (!service) {
+    return;
+  }
+  service->Bind(std::move(receiver));
+}
+
+SteadBrainServiceFactory::SteadBrainServiceFactory()
+    : ProfileKeyedServiceFactory("SteadBrainService",
+                                 ProfileSelections::BuildForRegularProfile()) {}
+
+SteadBrainServiceFactory::~SteadBrainServiceFactory() = default;
+
+std::unique_ptr<KeyedService>
+SteadBrainServiceFactory::BuildServiceInstanceForBrowserContext(
+    content::BrowserContext* context) const {
+  Profile* profile = Profile::FromBrowserContext(context);
+  if (!profile) {
+    return nullptr;
+  }
+  return std::make_unique<SteadBrainService>(profile);
+}
+
+}  // namespace stead
