+base::DictValue SteadBrainService::MakeRequest(std::string_view type,
+                                               const std::string& request_id) {
+  base::DictValue request;
+  request.Set("protocol_version", kProtocolVersion);
+  request.Set("request_id", request_id);
+  request.Set("type", type);
+  return request;
+}
