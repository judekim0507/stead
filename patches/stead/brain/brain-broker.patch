+namespace stead {
+
+class SteadBrainService : public KeyedService, public mojom::BrainConsole {
+ public:
+  explicit SteadBrainService(Profile* profile);
+  SteadBrainService(const SteadBrainService&) = delete;
+  SteadBrainService& operator=(const SteadBrainService&) = delete;
+  ~SteadBrainService() override;
+
+  void Bind(mojo::PendingReceiver<mojom::BrainConsole> receiver);
+
+  // KeyedService:
+  void Shutdown() override;
+
+  // mojom::BrainConsole:
+  void AddObserver(mojo::PendingRemote<mojom::BrainObserver> observer) override;
+  void Initialize(InitializeCallback callback) override;
+  void ShutdownBrain(ShutdownBrainCallback callback) override;
+  void CreateSession(const std::optional<std::string>& title,
+                     const std::string& origin_surface,
+                     CreateSessionCallback callback) override;
+  void ListSessions(ListSessionsCallback callback) override;
+  void LoadSession(const std::string& session_id,
+                   LoadSessionCallback callback) override;
+  void GetPermissionMode(GetPermissionModeCallback callback) override;
+  void SetPermissionMode(mojom::BrainPermissionMode permission_mode,
+                         SetPermissionModeCallback callback) override;
+  void SendMessage(const std::string& session_id,
+                   const std::string& text,
+                   std::vector<mojom::BrainTabContextPtr> tab_contexts,
+                   mojom::BrainModelSelectionPtr model,
+                   const std::string& reasoning_effort,
+                   mojom::BrainPermissionMode permission_mode,
+                   SendMessageCallback callback) override;
+  void CancelTurn(const std::string& session_id,
+                  CancelTurnCallback callback) override;
+  void ListProviderAuth(ListProviderAuthCallback callback) override;
+  void ListModels(ListModelsCallback callback) override;
+  void StartProviderOAuth(const std::string& provider,
+                          StartProviderOAuthCallback callback) override;
+  void ImportCodexAuth(const std::optional<std::string>& path,
+                       ImportCodexAuthCallback callback) override;
+  void ClearProviderCredential(const std::string& provider,
+                               ClearProviderCredentialCallback callback) override;
+  void SetProviderApiKey(const std::string& provider,
+                         const std::string& api_key,
+                         SetProviderApiKeyCallback callback) override;
+  void RespondToUserPrompt(const std::string& session_id,
+                           const std::string& tool_call_id,
+                           const std::string& response_json,
+                           bool cancelled,
+                           RespondToUserPromptCallback callback) override;
+
+ private:
+  static void ReadStdoutLoop(
+      base::ScopedFD stdout_fd,
+      scoped_refptr<base::SequencedTaskRunner> ui_task_runner,
+      base::WeakPtr<SteadBrainService> weak_service);
+
+  bool EnsureStarted(std::string* error_message);
+  bool LaunchHelper(std::string* error_message);
+  void StopHelper();
+  base::FilePath ResolveHelperPath() const;
+
+  std::string NextRequestId();
+  mojom::BrainResultPtr SendRequest(base::DictValue request);
+  bool WriteLine(std::string_view line);
+  void SendInitializeIfNeeded();
+  base::DictValue MakeRequest(std::string_view type, const std::string& request_id);
+  mojom::BrainResultPtr MakeResult(bool ok,
+                                   std::string request_id,
+                                   std::string code,
+                                   std::string message);
+
+  void OnBrainLine(std::string line);
+  void OnBrainPipeClosed();
+  void EmitEvent(const base::DictValue& event);
+  void HandleToolCall(const base::DictValue& event);
+  void SendToolResult(const std::string& session_id,
+                      const std::string& tool_call_id,
+                      bool ok,
+                      base::DictValue content,
+                      std::optional<std::string> error,
+                      bool tainted);
+  void SendToolError(const std::string& session_id,
+                     const std::string& tool_call_id,
+                     std::string message);
+  void SendToolUnavailableResult(const std::string& session_id,
+                                 const std::string& tool_call_id,
+                                 const std::string& tool_name);
+  std::string UserPromptKey(const std::string& session_id,
+                            const std::string& tool_call_id) const;
+  mojom::BrainPermissionMode PermissionModeForSession(
+      const std::string& session_id) const;
+  mojom::CredentialUsePolicy CredentialUsePolicyForSession(
+      const std::string& session_id) const;
+
+  raw_ptr<Profile> profile_;
+  mojo::ReceiverSet<mojom::BrainConsole> receivers_;
+  mojo::RemoteSet<mojom::BrainObserver> observers_;
+
+  base::Process process_;
+  base::ScopedFD stdin_write_;
+  bool initialized_ = false;
+  int64_t next_request_id_ = 1;
+  std::set<std::string> pending_user_prompts_;
+  base::flat_map<std::string, mojom::BrainPermissionMode>
+      session_permission_modes_;
+
+  base::WeakPtrFactory<SteadBrainService> weak_factory_{this};
+};
+
