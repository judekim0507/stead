+void SteadBrainService::SendMessage(const std::string& session_id,
+                                    const std::string& text,
+                                    std::vector<mojom::BrainTabContextPtr> tab_contexts,
+                                    mojom::BrainModelSelectionPtr model,
+                                    const std::string& reasoning_effort,
+                                    mojom::BrainPermissionMode permission_mode,
+                                    SendMessageCallback callback) {
+  const std::string request_id = NextRequestId();
+  base::DictValue request = MakeRequest("send_message", request_id);
+  request.Set("session_id", session_id);
+  request.Set("text", text);
+  request.Set("permission_mode",
+              PermissionModeToProtocolString(permission_mode));
+  request.Set("reasoning_effort", reasoning_effort);
+  profile_->GetPrefs()->SetString(kLastPermissionModePref,
+                                  PermissionModeToProtocolString(permission_mode));
+  session_permission_modes_[session_id] = permission_mode;
+  if (!tab_contexts.empty()) {
+    base::ListValue tabs;
+    for (const auto& tab_context : tab_contexts) {
+      base::DictValue tab;
+      tab.Set("tab_id", tab_context->tab_id);
+      tab.Set("url", tab_context->url);
+      tab.Set("title", tab_context->title);
+      tabs.Append(std::move(tab));
+    }
+    request.Set("tab_contexts", std::move(tabs));
+  }
+  if (model) {
+    base::DictValue selection;
+    selection.Set("provider", model->provider);
+    selection.Set("model", model->model);
+    request.Set("model", std::move(selection));
+  }
+  mojom::BrainResultPtr result = SendRequest(std::move(request));
+  if (result->ok) {
+    // Local lifecycle event: every WebUI surface attached to this profile can
+    // create the same live turn immediately, without polling session storage.
+    base::DictValue event;
+    event.Set("type", "turn_started");
+    event.Set("request_id", request_id);
+    event.Set("session_id", session_id);
+    event.Set("text", text);
+    event.Set("permission_mode", PermissionModeToProtocolString(permission_mode));
+    event.Set("reasoning_effort", reasoning_effort);
+    if (!tab_contexts.empty()) {
+      base::ListValue tabs;
+      for (const auto& tab_context : tab_contexts) {
+        base::DictValue tab;
+        tab.Set("tab_id", tab_context->tab_id);
+        tab.Set("url", tab_context->url);
+        tab.Set("title", tab_context->title);
+        tabs.Append(std::move(tab));
+      }
+      event.Set("tab_contexts", std::move(tabs));
+    }
+    if (model) {
+      base::DictValue selection;
+      selection.Set("provider", model->provider);
+      selection.Set("model", model->model);
+      event.Set("model", std::move(selection));
+    }
+    EmitEvent(event);
+  }
+  std::move(callback).Run(std::move(result));
+}
