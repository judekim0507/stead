+#ifndef CHROME_BROWSER_UI_WEBUI_STEAD_NEWTAB_STEAD_NEWTAB_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_STEAD_NEWTAB_STEAD_NEWTAB_UI_H_
+
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+
+class SteadNewTabUI;
+
+// Stead's new tab page. search.cc points the browser's new-tab URL here
+// (replacing Chrome's NTP), and because GetNewTabPageURL() returns this URL,
+// it is recognized as the NTP (empty omnibox etc.).
+class SteadNewTabUIConfig : public content::DefaultWebUIConfig<SteadNewTabUI> {
+ public:
+  SteadNewTabUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kSteadNewTabHost) {}
+};
+
+// Serves the shared Stead WebUI SPA bundle, opened at the /new-tab route.
+class SteadNewTabUI : public content::WebUIController {
+ public:
+  explicit SteadNewTabUI(content::WebUI* web_ui);
+
+  SteadNewTabUI(const SteadNewTabUI&) = delete;
+  SteadNewTabUI& operator=(const SteadNewTabUI&) = delete;
+  ~SteadNewTabUI() override;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_STEAD_NEWTAB_STEAD_NEWTAB_UI_H_
