+
+void ReadingListSidePanelCoordinator::OnTabStripModelChanged(
+    TabStripModel* tab_strip_model,
+    const TabStripModelChange& change,
+    const TabStripSelectionChange& selection) {
+  if (!selection.active_tab_changed()) {
+    return;
+  }
+  SidePanelUI* side_panel_ui = interface_->GetFeatures().side_panel_ui();
+  const SidePanelEntry::Key key(SidePanelEntry::Id::kReadingList);
+  if (selection.old_contents) {
+    const SessionID old_id =
+        sessions::SessionTabHelper::IdForTab(selection.old_contents);
+    if (old_id.is_valid()) {
+      open_by_tab_[old_id.id()] = side_panel_ui->IsSidePanelEntryShowing(key);
+    }
+  }
+  auto next = open_by_tab_.end();
+  if (selection.new_contents) {
+    const SessionID new_id =
+        sessions::SessionTabHelper::IdForTab(selection.new_contents);
+    if (new_id.is_valid()) {
+      next = open_by_tab_.find(new_id.id());
+    }
+  }
+  const bool should_show =
+      next != open_by_tab_.end() && next->second;
+  const bool is_showing = side_panel_ui->IsSidePanelEntryShowing(key);
+  if (should_show && !is_showing) {
+    side_panel_ui->Show(key);
+  } else if (!should_show && is_showing) {
+    side_panel_ui->Close();
+  }
+}
 
