+#include "chrome/browser/ui/views/side_panel/stead_sidebar/stead_sidebar_side_panel_web_view.h"
+
+#include <memory>
+
+#include "base/functional/callback_helpers.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/webui/top_chrome/webui_contents_wrapper.h"
+#include "chrome/common/webui_url_constants.h"
+#include "chrome/grit/generated_resources.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+#include "url/gurl.h"
+
+using SidePanelWebUIViewT_SteadSidebarUI = SidePanelWebUIViewT<SteadSidebarUI>;
+BEGIN_TEMPLATE_METADATA(SidePanelWebUIViewT_SteadSidebarUI, SidePanelWebUIViewT)
+END_METADATA
+
+SteadSidebarSidePanelWebView::SteadSidebarSidePanelWebView(
+    Profile* profile,
+    SidePanelEntryScope& scope,
+    base::RepeatingClosure close_cb)
+    : SidePanelWebUIViewT(
+          scope,
+          // No per-tab URL syncing; the Stead UI drives itself.
+          base::DoNothing(),
+          close_cb,
+          std::make_unique<WebUIContentsWrapperT<SteadSidebarUI>>(
+              GURL(chrome::kSteadSidebarURL),
+              profile,
+              // "Ask Stead" (added in patches/stead/sidebar/ask-stead-button).
+              IDS_STEAD_SIDEBAR_TITLE,
+              /*esc_closes_ui=*/false)) {
+  // The prebuilt Svelte app has no Chromium page-handler handshake. Mark the
+  // bundled WebUI available once its native host is attached so the side-panel
+  // entry waiter can reveal it instead of leaving it hidden at 0x0.
+  ShowUI();
+}
+
+SteadSidebarSidePanelWebView::~SteadSidebarSidePanelWebView() = default;
+
+BEGIN_METADATA(SteadSidebarSidePanelWebView)
+END_METADATA
