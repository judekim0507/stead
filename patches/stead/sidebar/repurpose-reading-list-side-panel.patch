+#define CHROME_BROWSER_UI_VIEWS_SIDE_PANEL_STEAD_SIDEBAR_STEAD_SIDEBAR_SIDE_PANEL_WEB_VIEW_H_
+
+#include "base/functional/callback_forward.h"
+#include "chrome/browser/ui/views/side_panel/side_panel_web_ui_view.h"
+#include "chrome/browser/ui/webui/side_panel/stead_sidebar/stead_sidebar_ui.h"
+#include "ui/base/metadata/metadata_header_macros.h"
+
+class Profile;
+class SidePanelEntryScope;
+
+// Side panel container that hosts the Stead agent sidebar WebUI
+// (chrome://sidebar). Mirrors ReadLaterSidePanelWebView but without the
+// reading-list/tab-strip plumbing, since the Stead UI manages its own state.
+class SteadSidebarSidePanelWebView
+    : public SidePanelWebUIViewT<SteadSidebarUI> {
+  using SidePanelWebUIViewT_SteadSidebarUI = SidePanelWebUIViewT<SteadSidebarUI>;
+  METADATA_HEADER(SteadSidebarSidePanelWebView,
+                  SidePanelWebUIViewT_SteadSidebarUI)
+
+ public:
+  SteadSidebarSidePanelWebView(Profile* profile,
+                               SidePanelEntryScope& scope,
+                               base::RepeatingClosure close_cb);
+  SteadSidebarSidePanelWebView(const SteadSidebarSidePanelWebView&) = delete;
+  SteadSidebarSidePanelWebView& operator=(
+      const SteadSidebarSidePanelWebView&) = delete;
+  ~SteadSidebarSidePanelWebView() override;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_SIDE_PANEL_STEAD_SIDEBAR_STEAD_SIDEBAR_SIDE_PANEL_WEB_VIEW_H_
