+#ifndef CHROME_BROWSER_UI_WEBUI_SIDE_PANEL_STEAD_SIDEBAR_STEAD_SIDEBAR_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_SIDE_PANEL_STEAD_SIDEBAR_STEAD_SIDEBAR_UI_H_
+
+#include <string>
+#include <string_view>
+
+#include "base/values.h"
+#include "chrome/browser/ui/webui/top_chrome/top_chrome_web_ui_controller.h"
+#include "chrome/browser/ui/webui/top_chrome/top_chrome_webui_config.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/common/url_constants.h"
+
+class SteadSidebarUI;
+
+// Top Chrome WebUI config for the Stead agent side panel. The host carries the
+// ".top-chrome" suffix that the side-panel contents wrapper expects.
+class SteadSidebarUIConfig
+    : public DefaultTopChromeWebUIConfig<SteadSidebarUI> {
+ public:
+  SteadSidebarUIConfig()
+      : DefaultTopChromeWebUIConfig(content::kChromeUIScheme,
+                                    chrome::kSteadSidebarHost) {}
+};
+
+// Hosts the Stead agent sidebar: a prebuilt SvelteKit SPA packed into
+// stead_sidebar_resources.pak and served from this WebUIController's data
+// source. A TopChromeWebUIController so it can live in the side panel via
+// WebUIContentsWrapperT (mirrors ReadingListUI).
+class SteadSidebarUI : public TopChromeWebUIController {
+ public:
+  explicit SteadSidebarUI(content::WebUI* web_ui);
+
+  SteadSidebarUI(const SteadSidebarUI&) = delete;
+  SteadSidebarUI& operator=(const SteadSidebarUI&) = delete;
+  ~SteadSidebarUI() override;
+
+  static constexpr std::string_view GetWebUIName() { return "SteadSidebar"; }
+
+ private:
+  void HandleClose(const base::ListValue&);
+  void HandleOpenFullChat(const base::ListValue& args);
+  void HandleOpenAiSettings(const base::ListValue& args);
+
+  WEB_UI_CONTROLLER_TYPE_DECL();
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SIDE_PANEL_STEAD_SIDEBAR_STEAD_SIDEBAR_UI_H_
diff --git a/chrome/browser/ui/webui/side_panel/stead_sidebar/stead_sidebar_ui.cc b/chrome/browser/ui/webui/side_panel/stead_sidebar/stead_sidebar_ui.cc
new file mode 100644
--- /dev/null
+++ b/chrome/browser/ui/webui/side_panel/stead_sidebar/stead_sidebar_ui.cc
@@ -0,0 +1,193 @@
+// Copyright 2026 The Stead Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/side_panel/stead_sidebar/stead_sidebar_ui.h"
+
+#include <memory>
+
+#include "base/functional/bind.h"
+#include "base/strings/escape.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/browser_finder.h"
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/navigator/browser_navigator.h"
+#include "chrome/browser/ui/navigator/browser_navigator_params.h"
+#include "chrome/browser/ui/tab_contents/tab_contents_iterator.h"
+#include "chrome/browser/ui/tabs/tab_strip_model.h"
+#include "chrome/browser/ui/webui/favicon_source.h"
+#include "chrome/common/webui_url_constants.h"
+#include "chrome/grit/stead_sidebar_resources.h"
+#include "chrome/grit/stead_sidebar_resources_map.h"
+#include "components/favicon_base/favicon_url_parser.h"
+#include "components/tabs/public/tab_interface.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/url_data_source.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "net/base/url_util.h"
+#include "services/network/public/mojom/content_security_policy.mojom.h"
+#include "ui/base/base_window.h"
+#include "ui/webui/webui_util.h"
+
+namespace {
+
+bool IsSteadChatSession(const GURL& url, const std::string& session_id) {
+  const GURL chat_url(chrome::kSteadChatURL);
+  if (url.scheme() != chat_url.scheme() || url.host() != chat_url.host() ||
+      url.path() != chat_url.path()) {
+    return false;
+  }
+
+  std::string open_session_id;
+  return net::GetValueForKeyInQuery(url, "session", &open_session_id) &&
+         open_session_id == session_id;
+}
+
+tabs::TabInterface* FindOpenSteadChat(Profile* profile,
+                                      const std::string& session_id) {
+  tabs::TabInterface* open_chat = nullptr;
+  tabs::ForEachTabInterface([&](tabs::TabInterface* tab) {
+    BrowserWindowInterface* window = tab->GetBrowserWindowInterface();
+    content::WebContents* contents = tab->GetContents();
+    if (window && contents && window->GetProfile() == profile &&
+        IsSteadChatSession(contents->GetVisibleURL(), session_id)) {
+      open_chat = tab;
+    }
+    return open_chat == nullptr;
+  });
+  return open_chat;
+}
+
+void ActivateAsHumanTab(tabs::TabInterface* tab) {
+  BrowserWindowInterface* window = tab->GetBrowserWindowInterface();
+  if (!window) {
+    return;
+  }
+
+  TabStripModel* tab_strip = window->GetTabStripModel();
+  const int index = tab_strip ? tab_strip->GetIndexOfTab(tab)
+                              : TabStripModel::kNoTab;
+  if (index == TabStripModel::kNoTab) {
+    return;
+  }
+
+  // A user-triggered chat tab never belongs in Stead's agent tab group. This
+  // also repairs chat tabs created by older builds that inherited the group.
+  if (tab_strip->GetTabGroupForTab(index)) {
+    tab_strip->RemoveFromGroup({index});
+  }
+  tab_strip->ActivateTabAt(index);
+  window->GetWindow()->Activate();
+}
+
+}  // namespace
+
+SteadSidebarUI::SteadSidebarUI(content::WebUI* web_ui)
+    : TopChromeWebUIController(web_ui, /*enable_chrome_send=*/true) {
+  web_ui->RegisterMessageCallback(
+      "closeSteadSidebar",
+      base::BindRepeating(&SteadSidebarUI::HandleClose,
+                          base::Unretained(this)));
+  web_ui->RegisterMessageCallback(
+      "openSteadFullChat",
+      base::BindRepeating(&SteadSidebarUI::HandleOpenFullChat,
+                          base::Unretained(this)));
+  web_ui->RegisterMessageCallback(
+      "openSteadAiSettings",
+      base::BindRepeating(&SteadSidebarUI::HandleOpenAiSettings,
+                          base::Unretained(this)));
+
+  Profile* profile = Profile::FromWebUI(web_ui);
+  content::URLDataSource::Add(
+      profile, std::make_unique<FaviconSource>(
+                   profile, chrome::FaviconUrlFormat::kFavicon2));
+  content::WebUIDataSource* source = content::WebUIDataSource::CreateAndAdd(
+      profile, chrome::kSteadSidebarHost);
+
+  // Packs index.html + the hashed _app/* assets, and makes index.html the
+  // default resource so any in-app route the side panel opens (e.g.
+  // /ai-sidebar) falls back to the SPA shell and SvelteKit's router renders it.
+  webui::SetupWebUIDataSource(source, kSteadSidebarResources,
+                              IDR_STEAD_SIDEBAR_INDEX_HTML);
+
+  // The SvelteKit shell bootstraps with an inline <script> and the app uses
+  // inline style="" attributes throughout. Relax the default (very strict)
+  // WebUI CSP for this trusted, first-party bundle.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src chrome://resources 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::FontSrc, "font-src 'self';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ImgSrc,
+      "img-src 'self' data: chrome://resources chrome://theme chrome://favicon2;");
+
+  // Svelte hydration assigns innerHTML; Trusted Types would reject it.
+  source->DisableTrustedTypesCSP();
+}
+
+SteadSidebarUI::~SteadSidebarUI() = default;
+
+void SteadSidebarUI::HandleClose(const base::ListValue&) {
+  if (embedder()) {
+    embedder()->CloseUI();
+  }
+}
+
+void SteadSidebarUI::HandleOpenFullChat(const base::ListValue& args) {
+  Profile* profile = Profile::FromWebUI(web_ui());
+  Browser* browser = chrome::FindBrowserWithProfile(profile);
+  if (!browser) {
+    return;
+  }
+
+  std::string session_id;
+  if (!args.empty() && args[0].is_string()) {
+    session_id = args[0].GetString();
+  }
+  if (!session_id.empty()) {
+    if (tabs::TabInterface* open_chat =
+            FindOpenSteadChat(profile, session_id)) {
+      ActivateAsHumanTab(open_chat);
+      return;
+    }
+  }
+
+  std::string url = std::string(chrome::kSteadChatURL) + "?source=sidebar";
+  if (!session_id.empty()) {
+    url.append("&session=");
+    url.append(base::EscapeQueryParamValue(session_id, true));
+  }
+
+  NavigateParams params(browser, GURL(url), ui::PAGE_TRANSITION_LINK);
+  params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  Navigate(&params);
+
+  if (params.navigated_or_inserted_contents) {
+    tabs::TabInterface* new_tab = tabs::TabInterface::GetFromContents(
+        params.navigated_or_inserted_contents);
+    if (new_tab) {
+      ActivateAsHumanTab(new_tab);
+    }
+  }
+}
+
+void SteadSidebarUI::HandleOpenAiSettings(const base::ListValue&) {
+  Browser* browser =
+      chrome::FindBrowserWithProfile(Profile::FromWebUI(web_ui()));
+  if (!browser) {
+    return;
+  }
+
+  NavigateParams params(browser, GURL("chrome://chat/ai-settings"),
+                        ui::PAGE_TRANSITION_LINK);
+  params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  Navigate(&params);
+}
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SteadSidebarUI)
diff --git a/chrome/browser/resources/stead_sidebar/BUILD.gn b/chrome/browser/resources/stead_sidebar/BUILD.gn
new file mode 100644
--- /dev/null
+++ b/chrome/browser/resources/stead_sidebar/BUILD.gn
@@ -0,0 +1,81 @@
+# Copyright 2026 The Stead Authors
+# You can use, redistribute, and/or modify this source code under
+# the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+import("//tools/grit/preprocess_if_expr.gni")
+import("//tools/grit/grit_rule.gni")
+import("//tools/typescript/ts_library.gni")
+import("//tools/typescript/webui_path_mappings.gni")
+
+# Compile the generated Stead Mojo WebUI TypeScript bindings into the
+# *.mojom-webui.js modules dynamically imported by the prebuilt Svelte bundle.
+stead_mojo_ts_files = [
+  "chrome/browser/ui/stead/agent_control/agent_control.mojom-webui.ts",
+  "chrome/browser/ui/stead/brain/brain_console.mojom-webui.ts",
+]
+
+preprocess_if_expr("copy_mojo_ts") {
+  visibility = [ ":build_ts" ]
+  in_folder = root_gen_dir
+  out_folder = "$target_gen_dir/preprocessed"
+  in_files = stead_mojo_ts_files
+  deps = [
+    "//chrome/browser/ui/stead/agent_control:mojo_bindings_ts__generator",
+    "//chrome/browser/ui/stead/brain:mojo_bindings_ts__generator",
+  ]
+}
+
+webui_path_mappings("build_path_map") {
+  visibility = [ ":build_ts" ]
+  ts_deps = [ "//ui/webui/resources/mojo:build_ts" ]
+  webui_context_type = "trusted"
+}
+
+ts_library("build_ts") {
+  root_dir = "$target_gen_dir/preprocessed"
+  out_dir = "$target_gen_dir/tsc"
+  in_files = stead_mojo_ts_files
+  deps = [ "//ui/webui/resources/mojo:build_ts" ]
+  definitions = [
+    "//tools/typescript/definitions/pending.d.ts",
+  ]
+  path_mappings_file = "$target_gen_dir/path_mappings_build_path_map.json"
+  extra_deps = [
+    ":build_path_map",
+    ":copy_mojo_ts",
+  ]
+}
+
+stead_mojo_js_outputs = [
+  "$target_gen_dir/tsc/chrome/browser/ui/stead/agent_control/agent_control.mojom-webui.js",
+  "$target_gen_dir/tsc/chrome/browser/ui/stead/brain/brain_console.mojom-webui.js",
+]
+
+group("build_mojo_js") {
+  public_deps = [ ":build_ts" ]
+  data = stead_mojo_js_outputs
+}
+
+# Packs the prebuilt Stead sidebar SPA into stead_sidebar_resources.pak.
+#
+# The bundle (index.html + _app/*) and the stead_sidebar_resources.grd that
+# lists it are copied into this directory before `gn gen` by
+# resources/stead/install_sidebar_to_tree.sh (driven from build.sh / dev.sh).
+# The generated .grd also directly includes the Mojo JS emitted by build_ts so
+# chat/sidebar/newtab can import the native Mojo modules from the WebUI root.
+# Because the .grd, Mojo JS, and hash-named inputs are generated, GN can't
+# discover them at analyze time.
+grit("resources") {
+  source = "stead_sidebar_resources.grd"
+  enable_input_discovery_for_gn_analyze = false
+  deps = [ ":build_mojo_js" ]
+  inputs = stead_mojo_js_outputs
+  defines = []
+  outputs = [
+    "grit/stead_sidebar_resources.h",
+    "grit/stead_sidebar_resources_map.cc",
+    "grit/stead_sidebar_resources_map.h",
+    "stead_sidebar_resources.pak",
+  ]
+  output_dir = "$root_gen_dir/chrome"
+}
