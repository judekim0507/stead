+#ifndef CHROME_BROWSER_UI_WEBUI_STEAD_CHAT_STEAD_CHAT_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_STEAD_CHAT_STEAD_CHAT_UI_H_
+
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+
+class SteadChatUI;
+
+// Full-page WebUI config for the Stead chat surface (chrome://chat, shown as
+// stead://chat). A normal page/tab WebUI -- DefaultWebUIConfig, unlike the
+// side panel's TopChrome config.
+class SteadChatUIConfig : public content::DefaultWebUIConfig<SteadChatUI> {
+ public:
+  SteadChatUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme, chrome::kSteadChatHost) {}
+};
+
+// Full-page Stead chat. Serves the same SvelteKit SPA bundle as the sidebar
+// (stead_sidebar_resources.pak), opened at the /ai-chat route.
+class SteadChatUI : public content::WebUIController {
+ public:
+  explicit SteadChatUI(content::WebUI* web_ui);
+
+  SteadChatUI(const SteadChatUI&) = delete;
+  SteadChatUI& operator=(const SteadChatUI&) = delete;
+  ~SteadChatUI() override;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_STEAD_CHAT_STEAD_CHAT_UI_H_
