+void SteadAgentControlService::HandleFileChooser(
+    const std::string& handle,
+    const std::vector<std::string>& paths,
+    HandleFileChooserCallback callback) {
+  const int32_t action_id = NextActionId();
+  const std::string operation = "HandleFileChooser";
+  const auto active_file_chooser = active_file_choosers_.find(handle);
+  const int32_t tab_id = active_file_chooser == active_file_choosers_.end()
+                             ? 0
+                             : active_file_chooser->second.tab_id;
+  const mojom::ActionClass action_class =
+      paths.empty() ? mojom::ActionClass::kNavigation
+                    : mojom::ActionClass::kFileAccess;
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result));
+  };
+
+  if (active_file_chooser == active_file_choosers_.end()) {
+    finish(MakeResult(action_id, false, kFileChooserMissing,
+                      "File chooser handle was not active.",
+                      /*stale=*/false, /*needs_snapshot=*/true,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true, "file_chooser"));
+    return;
+  }
+
+  if (paths.size() > kMaxFileChooserFiles) {
+    finish(MakeResult(action_id, false, kFileChooserTooManyFiles,
+                      "File chooser selection exceeded the broker file cap.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false, "file_chooser"));
+    return;
+  }
+
+  std::vector<base::FilePath> file_paths;
+  file_paths.reserve(paths.size());
+  for (const std::string& path : paths) {
+    if (path.empty()) {
+      finish(MakeResult(action_id, false, kFileChooserInvalidSelection,
+                        "File chooser path was empty.",
+                        /*stale=*/false, /*needs_snapshot=*/false,
+                        /*needs_confirmation=*/false,
+                        /*target_missing=*/false, "file_chooser"));
+      return;
+    }
+    if (path.size() > kMaxFileChooserPathBytes) {
+      finish(MakeResult(action_id, false, kFileChooserPathTooLarge,
+                        "File chooser path exceeded the broker input cap.",
+                        /*stale=*/false, /*needs_snapshot=*/false,
+                        /*needs_confirmation=*/false,
+                        /*target_missing=*/false, "file_chooser"));
+      return;
+    }
+    file_paths.push_back(base::FilePath::FromUTF8Unsafe(path));
+  }
+
+  mojom::ActionResultPtr gate =
+      MaybeGateAction(action_id, tab_id, action_class, operation,
+                      FileChooserApprovalScope(handle, paths));
+  if (gate) {
+    finish(std::move(gate));
+    return;
+  }
+
+  pending_action_by_tab_[tab_id] = action_id;
+  SchedulePendingActionClear(tab_id, action_id);
+  mojom::ActionResultPtr result = browser_control_->HandleFileChooser(
+      active_file_chooser->second.helper, tab_id, action_id, file_paths);
+  if (!result->ok) {
+    pending_action_by_tab_.erase(tab_id);
+  }
+  finish(std::move(result));
+}
