+void SteadAgentControlService::ClearTaintForFrame(
+    int32_t tab_id,
+    const std::string& frame_token) {
+  if (frame_token.empty()) {
+    return;
+  }
+  secret_tainted_frames_.erase(FrameTaintKey(tab_id, frame_token));
+}
+
+void SteadAgentControlService::ClearTaintForTab(int32_t tab_id) {
+  const std::string prefix = std::to_string(tab_id) + "|";
+  std::vector<std::string> taints_to_clear;
+  for (const std::string& key : secret_tainted_frames_) {
+    if (key.rfind(prefix, 0) == 0) {
+      taints_to_clear.push_back(key);
+    }
+  }
+  for (const std::string& key : taints_to_clear) {
+    secret_tainted_frames_.erase(key);
+  }
+}
