+
+gfx::Size BoundedScreenshotOutputSize(const gfx::Size& view_size) {
+  if (view_size.IsEmpty()) {
+    return gfx::Size();
+  }
+
+  const int max_side = std::max(view_size.width(), view_size.height());
+  if (max_side <= kMaxScreenshotDimension) {
+    return gfx::Size();
+  }
+
+  return gfx::Size(
+      std::max(1, view_size.width() * kMaxScreenshotDimension / max_side),
+      std::max(1, view_size.height() * kMaxScreenshotDimension / max_side));
+}
+
+std::optional<gfx::Rect> TransformFrameRectToRootView(
+    content::RenderFrameHost* frame,
+    const gfx::Rect& frame_rect) {
+  if (!frame || frame_rect.IsEmpty()) {
+    return std::nullopt;
+  }
+
+  content::RenderWidgetHostView* frame_view = frame->GetView();
+  if (!frame_view) {
+    return std::nullopt;
+  }
+
+  const auto transform_point = [frame_view](float x, float y) {
+    return frame_view->TransformPointToRootCoordSpaceF(gfx::PointF(x, y));
+  };
+  const gfx::PointF top_left =
+      transform_point(frame_rect.x(), frame_rect.y());
+  const gfx::PointF top_right =
+      transform_point(frame_rect.right(), frame_rect.y());
+  const gfx::PointF bottom_left =
+      transform_point(frame_rect.x(), frame_rect.bottom());
+  const gfx::PointF bottom_right =
+      transform_point(frame_rect.right(), frame_rect.bottom());
+
+  const float min_x = std::min(
+      {top_left.x(), top_right.x(), bottom_left.x(), bottom_right.x()});
+  const float min_y = std::min(
+      {top_left.y(), top_right.y(), bottom_left.y(), bottom_right.y()});
+  const float max_x = std::max(
+      {top_left.x(), top_right.x(), bottom_left.x(), bottom_right.x()});
+  const float max_y = std::max(
+      {top_left.y(), top_right.y(), bottom_left.y(), bottom_right.y()});
+  if (max_x <= min_x || max_y <= min_y) {
+    return std::nullopt;
+  }
+
+  return gfx::ToEnclosingRect(
+      gfx::RectF(min_x, min_y, max_x - min_x, max_y - min_y));
+}
