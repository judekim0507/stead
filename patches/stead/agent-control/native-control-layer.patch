+
+content::WebContents*
+SteadAgentControlService::PrivateBrowserControl::FindTabById(int32_t tab_id) {
+  for (BrowserWindowInterface* window : GetAllBrowserWindowInterfaces()) {
+    if (!window || !SameProfile(window->GetProfile(), broker_->profile_)) {
+      continue;
+    }
+
+    TabStripModel* tab_strip = window->GetTabStripModel();
+    if (!tab_strip) {
+      continue;
+    }
+
+    for (int index = 0; index < tab_strip->count(); ++index) {
+      content::WebContents* contents = tab_strip->GetWebContentsAt(index);
+      if (!contents) {
+        continue;
+      }
+
+      sessions::SessionID current_id =
+          sessions::SessionTabHelper::IdForTab(contents);
+      if (current_id.is_valid() && current_id.id() == tab_id) {
+        EnsureTabObserved(contents, tab_id);
+        return contents;
+      }
+    }
+  }
+
+  return nullptr;
+}
+
+void SteadAgentControlService::PrivateBrowserControl::EnsureTabObserved(
+    content::WebContents* web_contents,
+    int32_t tab_id) {
+  if (!web_contents) {
+    return;
+  }
+
+  if (!observed_tabs_.contains(tab_id)) {
+    observed_tabs_[tab_id] =
+        std::make_unique<ObservedTab>(this, web_contents, tab_id);
+  }
+  EnsureAccessibilityMode(web_contents, tab_id);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::EnsureAccessibilityMode(
+    content::WebContents* web_contents,
+    int32_t tab_id) {
+  if (!web_contents || scoped_ax_modes_.contains(tab_id)) {
+    return;
+  }
+
+  scoped_ax_modes_[tab_id] =
+      content::BrowserAccessibilityState::GetInstance()
+          ->CreateScopedModeForWebContents(web_contents, ui::kAXModeBasic);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::ClearTabState(
+    int32_t tab_id) {
+  snapshot_generations_.erase(tab_id);
+  snapshot_indexes_.erase(tab_id);
+  scoped_ax_modes_.erase(tab_id);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::ForgetObservedTab(
+    int32_t tab_id) {
+  observed_tabs_.erase(tab_id);
+}
+
+mojom::AxNodePtr SteadAgentControlService::PrivateBrowserControl::BuildAxNode(
+    const ui::AXTree& tree,
+    ui::AXNode* node,
+    int32_t tab_id,
+    const std::string& frame_token,
+    uint32_t generation,
+    SnapshotBuildState* state) const {
+  if (!node || !state || node->IsInvisibleOrIgnored()) {
+    return nullptr;
+  }
+
+  if (!state->ReserveNode()) {
+    return nullptr;
+  }
+  state->node_ids.insert(node->id());
+
+  const ui::AXNodeData& data = node->data();
+
+  auto out = mojom::AxNode::New();
+  out->ref = mojom::NodeRef::New(
+      mojom::FrameRef::New(tab_id, frame_token, generation), node->id());
+  out->role = ui::ToString(node->GetRole());
+  out->name = data.GetStringAttribute(ax::mojom::StringAttribute::kName);
+  out->has_value = state->include_values &&
+                   data.HasStringAttribute(ax::mojom::StringAttribute::kValue) &&
+                   !data.IsPasswordField();
+  out->value = out->has_value
+                   ? data.GetStringAttribute(ax::mojom::StringAttribute::kValue)
+                   : std::string();
+  out->clickable = data.IsClickable();
+  out->editable = data.IsTextField();
+  out->focused = tree.data().focus_id == node->id();
+  out->disabled =
+      data.GetRestriction() == ax::mojom::Restriction::kDisabled;
+
+  const ax::mojom::CheckedState checked_state = data.GetCheckedState();
+  out->has_checked = checked_state != ax::mojom::CheckedState::kNone;
+  out->checked = out->has_checked ? ui::ToString(checked_state) : std::string();
+
+  out->bounds = state->include_bounds
+                    ? gfx::ToEnclosingRect(data.relative_bounds.bounds)
+                    : gfx::Rect();
+  out->has_bounds = state->include_bounds && !out->bounds.IsEmpty();
+
+  for (ui::AXNode* child : node->children()) {
+    mojom::AxNodePtr child_out =
+        BuildAxNode(tree, child, tab_id, frame_token, generation, state);
+    if (child_out) {
+      out->children.push_back(std::move(child_out));
+    }
+  }
+
+  return out;
+}
+
+mojom::ActionResultPtr SteadAgentControlService::PerformAccessibilityAction(
+    mojom::NodeRefPtr ref,
+    ax::mojom::Action action,
+    const std::string& value) {
+  const int32_t action_id = NextActionId();
+  const int32_t tab_id = ref && ref->frame ? ref->frame->tab_id : 0;
+  const mojom::ActionClass action_class = mojom::ActionClass::kFormEntry;
+  const std::string operation = ui::ToString(action);
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    return result;
+  };
+
+  if (!ref || !ref->frame) {
+    return finish(MakeResult(action_id, false, kTargetMissing,
+                             "Target ref was empty.",
+                             /*stale=*/false, /*needs_snapshot=*/false,
+                             /*needs_confirmation=*/false,
+                             /*target_missing=*/true));
+  }
+
+  mojom::ActionResultPtr gate =
+      MaybeGateAction(action_id, tab_id, action_class, operation);
+  if (gate) {
+    return finish(std::move(gate));
+  }
+
+  mojom::ActionResultPtr result =
+      browser_control_->DispatchAccessibilityAction(*ref, action_id, action,
+                                                    value);
+  if (result->ok) {
+    content::WebContents* web_contents = browser_control_->FindTabById(tab_id);
+    pending_action_by_tab_[tab_id] = action_id;
+    EmitEvent(mojom::ControlEventType::kActionDispatched, tab_id,
+              ref->frame->frame_token, action_id, WebContentsUrl(web_contents),
+              WebContentsTitle(web_contents), kAccessibilityActionAccepted,
+              operation);
+  }
+
+  return finish(std::move(result));
+}
+
+void SteadAgentControlService::OnNavigationCommitted(
+    int32_t tab_id,
+    content::NavigationHandle* navigation_handle) {
+  if (!navigation_handle) {
+    return;
+  }
+
+  std::string frame_token;
+  content::RenderFrameHost* frame = navigation_handle->GetRenderFrameHost();
+  if (frame) {
+    frame_token = frame->GetAXTreeID().ToString();
+  }
+
+  const int32_t originating_action_id = TakePendingActionForTab(tab_id);
+  content::WebContents* web_contents = browser_control_->FindTabById(tab_id);
+  EmitEvent(mojom::ControlEventType::kNavigated, tab_id, frame_token,
+            originating_action_id, navigation_handle->GetURL().spec(),
+            WebContentsTitle(web_contents),
+            navigation_handle->IsInPrimaryMainFrame() ? "primary_frame"
+                                                      : "subframe",
+            navigation_handle->IsErrorPage() ? "error_page" : std::string());
+}
+
+void SteadAgentControlService::OnTabClosed(int32_t tab_id) {
+  pending_action_by_tab_.erase(tab_id);
+  ClearApprovalGrantsForTab(tab_id);
+  browser_control_->ClearTabState(tab_id);
+  EmitEvent(mojom::ControlEventType::kTabClosed, tab_id, std::string(),
+            kNoOriginatingAction, std::string(), std::string(), "tab_closed",
+            std::string());
+}
+
+void SteadAgentControlService::ScheduleForgetObservedTab(int32_t tab_id) {
+  base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE, base::BindOnce(&SteadAgentControlService::ForgetObservedTab,
+                                weak_factory_.GetWeakPtr(), tab_id));
+}
+
+void SteadAgentControlService::ForgetObservedTab(int32_t tab_id) {
+  browser_control_->ForgetObservedTab(tab_id);
+}
+
+int32_t SteadAgentControlService::TakePendingActionForTab(int32_t tab_id) {
+  const auto pending_action = pending_action_by_tab_.find(tab_id);
+  if (pending_action == pending_action_by_tab_.end()) {
+    return kNoOriginatingAction;
+  }
+
+  const int32_t action_id = pending_action->second;
+  pending_action_by_tab_.erase(pending_action);
+  return action_id;
+}
+
+void SteadAgentControlService::EmitEvent(
+    mojom::ControlEventType type,
+    int32_t tab_id,
+    const std::string& frame_token,
+    int32_t originating_action_id,
+    const std::string& url,
+    const std::string& title,
+    const std::string& code,
+    const std::string& message) {
+  const int32_t event_id = next_event_id_++;
+  const uint64_t sequence = next_event_sequence_++;
+
+  for (auto& observer : observers_) {
+    auto meta =
+        mojom::EventMeta::New(event_id, sequence, tab_id, frame_token,
+                              originating_action_id);
+    auto event = mojom::ControlEvent::New(std::move(meta), type, url, title,
+                                          code, message);
+    observer->OnEvent(std::move(event));
+  }
+}
+
+bool SteadAgentControlService::PrivateBrowserControl::IsStaleFrame(
+    const mojom::FrameRef& frame_ref,
+    content::WebContents* web_contents) const {
+  if (frame_ref.snapshot_generation !=
+      CurrentSnapshotGeneration(frame_ref.tab_id)) {
+    return true;
+  }
+
+  return frame_ref.frame_token != CurrentMainFrameToken(web_contents);
+}
+
+bool SteadAgentControlService::PrivateBrowserControl::SnapshotIndexContains(
+    const mojom::NodeRef& ref) const {
+  if (!ref.frame) {
+    return false;
+  }
+
+  const auto index = snapshot_indexes_.find(ref.frame->tab_id);
+  if (index == snapshot_indexes_.end() || !index->second) {
+    return false;
+  }
+
+  return index->second->generation == ref.frame->snapshot_generation &&
+         index->second->frame_token == ref.frame->frame_token &&
+         index->second->node_ids.contains(ref.ax_node_id);
+}
+
+bool SteadAgentControlService::PrivateBrowserControl::CurrentTreeContainsNode(
+    content::WebContents* web_contents,
+    const mojom::NodeRef& ref) const {
+  if (!web_contents || !ref.frame) {
+    return false;
+  }
+
+  ui::AXTreeUpdate update =
+      web_contents->RequestAXTreeSnapshotWithinBrowserProcess();
+  ui::AXTree tree;
+  if (!tree.Unserialize(update) || !tree.root()) {
+    return false;
+  }
+
+  return tree.GetFromId(ref.ax_node_id) != nullptr;
+}
+
+mojom::ActionResultPtr SteadAgentControlService::MaybeGateAction(
+    int32_t action_id,
+    int32_t tab_id,
+    mojom::ActionClass action_class,
+    const std::string& operation) {
+  const bool requires_confirmation =
+      action_class == mojom::ActionClass::kDestructive ||
+      action_class == mojom::ActionClass::kPayment ||
+      action_class == mojom::ActionClass::kCredential ||
+      action_class == mojom::ActionClass::kFileAccess ||
+      action_class == mojom::ActionClass::kRawInput ||
+      action_class == mojom::ActionClass::kEval;
+
+  if (!requires_confirmation) {
+    return nullptr;
+  }
+
+  if (ConsumeApprovalGrant(tab_id, action_class, operation)) {
+    return nullptr;
+  }
+
+  auto stored_request = mojom::ConfirmationRequest::New(
+      action_id, tab_id, action_class, operation,
+      "High-risk action requires confirmation.");
+  auto outbound_request = mojom::ConfirmationRequest::New(
+      action_id, tab_id, action_class, operation,
+      "High-risk action requires confirmation.");
+  pending_confirmations_[action_id] = std::move(stored_request);
+  NotifyConfirmation(std::move(outbound_request));
+
+  return MakeResult(action_id, false, "needs_confirmation",
+                    "Action requires confirmation.",
+                    /*stale=*/false, /*needs_snapshot=*/false,
+                    /*needs_confirmation=*/true, /*target_missing=*/false,
+                    "confirmation");
+}
+
+void SteadAgentControlService::RecordAudit(
+    const mojom::ActionResult& result,
+    int32_t tab_id,
+    mojom::ActionClass action_class,
+    const std::string& operation) {
+  auto entry = mojom::AuditEntry::New(
+      result.action_id, next_audit_sequence_++, tab_id, action_class, operation,
+      result.code, result.message, result.ok);
+
+  for (auto& observer : console_observers_) {
+    observer->OnAuditEntry(CloneAuditEntry(*entry));
+  }
+
+  audit_log_.push_back(std::move(entry));
+  while (audit_log_.size() > kMaxAuditEntries) {
+    audit_log_.pop_front();
+  }
+}
+
+void SteadAgentControlService::NotifyConfirmation(
+    mojom::ConfirmationRequestPtr request) {
+  if (!request) {
+    return;
+  }
+
+  for (auto& observer : console_observers_) {
+    observer->OnConfirmation(mojom::ConfirmationRequest::New(
+        request->action_id, request->tab_id, request->action_class,
+        request->operation, request->reason));
+  }
+}
+
+mojom::AuditEntryPtr SteadAgentControlService::CloneAuditEntry(
+    const mojom::AuditEntry& entry) const {
+  return mojom::AuditEntry::New(entry.action_id, entry.sequence, entry.tab_id,
+                                entry.action_class, entry.operation,
+                                entry.code, entry.message, entry.ok);
+}
+
+bool SteadAgentControlService::ConsumeApprovalGrant(
+    int32_t tab_id,
+    mojom::ActionClass action_class,
+    const std::string& operation) {
+  for (auto grant = approval_grants_.begin(); grant != approval_grants_.end();
+       ++grant) {
+    if (grant->tab_id == tab_id && grant->action_class == action_class &&
+        grant->operation == operation) {
+      approval_grants_.erase(grant);
+      return true;
+    }
+  }
+
+  return false;
+}
+
+void SteadAgentControlService::ClearApprovalGrantsForTab(int32_t tab_id) {
+  for (auto grant = approval_grants_.begin(); grant != approval_grants_.end();) {
+    if (grant->tab_id == tab_id) {
+      grant = approval_grants_.erase(grant);
+    } else {
+      ++grant;
+    }
+  }
+}
+
+uint32_t SteadAgentControlService::PrivateBrowserControl::CurrentSnapshotGeneration(
+    int32_t tab_id) const {
+  const auto generation = snapshot_generations_.find(tab_id);
+  if (generation == snapshot_generations_.end()) {
+    return 0;
+  }
+  return generation->second;
+}
+
+uint32_t SteadAgentControlService::PrivateBrowserControl::BumpSnapshotGeneration(
+    int32_t tab_id) {
+  uint32_t& generation = snapshot_generations_[tab_id];
+  ++generation;
+  return generation;
+}
+
+int32_t SteadAgentControlService::NextActionId() {
+  return next_action_id_++;
+}
+
+mojom::ActionResultPtr SteadAgentControlService::MakeResult(
+    int32_t action_id,
+    bool ok,
+    const std::string& code,
+    const std::string& message,
+    bool stale,
+    bool needs_snapshot,
+    bool needs_confirmation,
+    bool target_missing,
+    const std::string& blocked_by,
+    uint32_t new_generation) const {
+  return mojom::ActionResult::New(action_id, ok, code, message, stale,
+                                  needs_snapshot, needs_confirmation,
+                                  target_missing, blocked_by, new_generation);
+}
+
