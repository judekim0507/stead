+
+void SteadAgentControlService::GetAuditLog(uint32_t max_entries,
+                                           GetAuditLogCallback callback) {
+  const size_t requested =
+      max_entries == 0 ? audit_log_.size() : static_cast<size_t>(max_entries);
+  const size_t count = std::min(requested, audit_log_.size());
+  std::vector<mojom::AuditEntryPtr> entries;
+  entries.reserve(count);
+
+  const size_t start = audit_log_.size() - count;
+  for (size_t i = start; i < audit_log_.size(); ++i) {
+    entries.push_back(CloneAuditEntry(*audit_log_[i]));
+  }
+
+  std::move(callback).Run(std::move(entries));
+}
+
+void SteadAgentControlService::RespondToConfirmation(int32_t action_id,
+                                                     bool approve) {
+  const auto request = pending_confirmations_.find(action_id);
+  if (request == pending_confirmations_.end()) {
+    return;
+  }
+
+  // The MVP records the decision and unblocks future retries. The original
+  // action is not replayed because refs may be stale by the time approval lands.
+  auto result = MakeResult(action_id, approve, approve ? "approved" : "denied",
+                           approve ? "Confirmation approved."
+                                   : "Confirmation denied.",
+                           /*stale=*/false, /*needs_snapshot=*/approve,
+                           /*needs_confirmation=*/false,
+                           /*target_missing=*/false);
+  if (approve) {
+    approval_grants_.push_back({request->second->tab_id,
+                                request->second->action_class,
+                                request->second->operation});
+  }
+  RecordAudit(*result, request->second->tab_id, request->second->action_class,
+              request->second->operation);
+  pending_confirmations_.erase(request);
+}
+
+void SteadAgentControlService::Cancel(int32_t tab_id) {
+  pending_action_by_tab_.erase(tab_id);
+  ClearApprovalGrantsForTab(tab_id);
+  for (auto& observer : console_observers_) {
+    observer->OnCancelled(tab_id);
+  }
+}
+
+void SteadAgentControlService::ListTabs(ListTabsCallback callback) {
+  std::move(callback).Run(browser_control_->ListTabs());
+}
+
+std::vector<mojom::TabInfoPtr>
+SteadAgentControlService::PrivateBrowserControl::ListTabs() {
+  std::vector<mojom::TabInfoPtr> tabs;
+
+  for (BrowserWindowInterface* window : GetAllBrowserWindowInterfaces()) {
+    if (!window || !SameProfile(window->GetProfile(), broker_->profile_)) {
+      continue;
+    }
+
+    TabStripModel* tab_strip = window->GetTabStripModel();
+    if (!tab_strip) {
+      continue;
+    }
+
+    content::WebContents* active_contents = tab_strip->GetActiveWebContents();
+    for (int index = 0; index < tab_strip->count(); ++index) {
+      content::WebContents* contents = tab_strip->GetWebContentsAt(index);
+      if (!contents) {
+        continue;
+      }
+
+      sessions::SessionID tab_id =
+          sessions::SessionTabHelper::IdForTab(contents);
+      if (!tab_id.is_valid()) {
+        continue;
+      }
+
+      EnsureTabObserved(contents, tab_id.id());
+
+      auto tab = mojom::TabInfo::New();
+      tab->tab_id = tab_id.id();
+      tab->url = WebContentsUrl(contents);
+      tab->title = WebContentsTitle(contents);
+      tab->active = contents == active_contents;
+      tab->likely_authenticated = false;
+      tabs.push_back(std::move(tab));
+    }
+  }
+
+  return tabs;
+}
+
+void SteadAgentControlService::GetSnapshot(
+    int32_t tab_id,
+    mojom::SnapshotOptionsPtr options,
+    GetSnapshotCallback callback) {
+  browser_control_->GetSnapshot(tab_id, NextActionId(), std::move(options),
+                                std::move(callback));
+}
+
+void SteadAgentControlService::PrivateBrowserControl::GetSnapshot(
+    int32_t tab_id,
+    int32_t action_id,
+    mojom::SnapshotOptionsPtr options,
+    SteadAgentControlService::GetSnapshotCallback callback) {
+  const base::TimeTicks start_time = base::TimeTicks::Now();
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kTabMissing,
+                            "Tab was not found.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/true),
+        nullptr);
+    return;
+  }
+
+  EnsureAccessibilityMode(web_contents, tab_id);
+
+  ui::AXTreeUpdate update =
+      web_contents->RequestAXTreeSnapshotWithinBrowserProcess();
+  ui::AXTree tree;
+  if (!tree.Unserialize(update) || !tree.root()) {
+    const size_t max_nodes =
+        options && options->max_nodes != 0 ? options->max_nodes
+                                           : kDefaultMaxSnapshotNodes;
+    web_contents->RequestAXTreeSnapshot(
+        base::BindOnce(&PrivateBrowserControl::CompleteSnapshotFromUpdate,
+                       weak_factory_.GetWeakPtr(), tab_id, action_id,
+                       std::move(options), start_time, std::move(callback)),
+        ui::kAXModeBasic, max_nodes, kColdSnapshotTimeout,
+        content::WebContents::AXTreeSnapshotPolicy::kAll);
+    return;
+  }
+
+  CompleteSnapshotFromUpdate(tab_id, action_id, std::move(options), start_time,
+                             std::move(callback), update);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::CompleteSnapshotFromUpdate(
+    int32_t tab_id,
+    int32_t action_id,
+    mojom::SnapshotOptionsPtr options,
+    base::TimeTicks start_time,
+    SteadAgentControlService::GetSnapshotCallback callback,
+    ui::AXTreeUpdate& update) {
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kTabMissing,
+                            "Tab was not found.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/true),
+        nullptr);
+    return;
+  }
+
+  ui::AXTree tree;
+  if (!tree.Unserialize(update) || !tree.root()) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kSnapshotUnavailable,
+                            "Accessibility snapshot was unavailable.",
+                            /*stale=*/false, /*needs_snapshot=*/true,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false),
+        nullptr);
+    return;
+  }
+
+  const uint32_t generation = BumpSnapshotGeneration(tab_id);
+  const std::string frame_token = CurrentMainFrameToken(web_contents);
+  SnapshotBuildState build_state;
+  if (options) {
+    build_state.max_nodes =
+        options->max_nodes == 0 ? kDefaultMaxSnapshotNodes : options->max_nodes;
+    build_state.include_bounds = options->include_bounds;
+    build_state.include_values = options->include_values;
+  }
+  mojom::AxNodePtr root =
+      BuildAxNode(tree, tree.root(), tab_id, frame_token, generation,
+                  &build_state);
+  if (!root) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kSnapshotUnavailable,
+                            "Accessibility snapshot root was filtered out.",
+                            /*stale=*/false, /*needs_snapshot=*/true,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false),
+        nullptr);
+    return;
+  }
+
+  auto snapshot = mojom::Snapshot::New();
+  snapshot->tab_id = tab_id;
+  snapshot->url = WebContentsUrl(web_contents);
+  snapshot->title = WebContentsTitle(web_contents);
+  snapshot->generation = generation;
+  snapshot->node_count = build_state.node_count;
+  snapshot->truncated = build_state.truncated;
+  snapshot->capture_time_us =
+      static_cast<uint64_t>((base::TimeTicks::Now() - start_time)
+                                .InMicroseconds());
+  snapshot->root = std::move(root);
+  auto snapshot_index = std::make_unique<SnapshotIndex>();
+  snapshot_index->generation = generation;
+  snapshot_index->frame_token = frame_token;
+  snapshot_index->node_ids = std::move(build_state.node_ids);
+  snapshot_indexes_[tab_id] = std::move(snapshot_index);
+
+  broker_->FinishSnapshot(
+      tab_id, std::move(callback),
+      broker_->MakeResult(action_id, true, kOk, "Snapshot captured.",
+                          /*stale=*/false, /*needs_snapshot=*/false,
+                          /*needs_confirmation=*/false,
+                          /*target_missing=*/false,
+                          /*blocked_by=*/std::string(), generation),
+      std::move(snapshot));
+}
+
+void SteadAgentControlService::FinishSnapshot(
+    int32_t tab_id,
+    GetSnapshotCallback callback,
+    mojom::ActionResultPtr result,
+    mojom::SnapshotPtr snapshot) {
+  RecordAudit(*result, tab_id, mojom::ActionClass::kReadOnly, "GetSnapshot");
+  std::move(callback).Run(std::move(result), std::move(snapshot));
+}
