+
+std::vector<std::string> DictStringList(const base::DictValue& dict,
+                                        std::string_view key) {
+  std::vector<std::string> values;
+  const base::ListValue* list = dict.FindList(key);
+  if (!list) {
+    return values;
+  }
+
+  for (const base::Value& item : *list) {
+    const std::string* value = item.GetIfString();
+    if (value) {
+      values.push_back(*value);
+    }
+  }
+  return values;
+}
