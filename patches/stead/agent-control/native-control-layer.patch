+void SteadAgentControlService::OnFileChooserClosed(
+    FileSelectHelper* helper,
+    bool files_selected) {
+  std::string handle;
+  int32_t tab_id = 0;
+  std::string mode;
+  std::string frame_token;
+  const auto active_file_chooser =
+      active_file_chooser_by_helper_.find(helper);
+  if (active_file_chooser != active_file_chooser_by_helper_.end()) {
+    handle = active_file_chooser->second;
+    const auto chooser = active_file_choosers_.find(handle);
+    if (chooser != active_file_choosers_.end()) {
+      tab_id = chooser->second.tab_id;
