+void SteadAgentControlService::GetSnapshot(
+    int32_t tab_id,
+    mojom::SnapshotOptionsPtr options,
+    GetSnapshotCallback callback) {
+  const TabEventState event_state = browser_control_->GetTabEventState(tab_id);
+  if (event_state.found && IsAnyFrameTainted(tab_id)) {
+    if (!options) {
+      options = mojom::SnapshotOptions::New(
+          /*max_nodes=*/0, /*include_bounds=*/true,
+          /*include_values=*/false);
+    } else {
+      options->include_values = false;
+    }
+  }
+  browser_control_->GetSnapshot(tab_id, NextActionId(),
+                                CancelEpochForTab(tab_id),
+                                std::move(options), std::move(callback));
+}
+
+void SteadAgentControlService::ProbeNode(mojom::NodeRefPtr ref,
+                                         ProbeNodeCallback callback) {
+  const int32_t action_id = NextActionId();
+  const int32_t tab_id = ref && ref->frame ? ref->frame->tab_id : 0;
+  if (ref && ref->frame && IsFrameTainted(*ref->frame)) {
+    FinishProbeNode(tab_id, action_id, std::move(callback),
+                    MakeReadResult(false, kSecretTainted,
+                                   "Frame is secret-tainted.",
+                                   "secret_taint"),
+                    nullptr);
+    return;
+  }
+  browser_control_->ProbeNode(std::move(ref), action_id,
+                              CancelEpochForTab(tab_id), std::move(callback));
+}
+
+void SteadAgentControlService::PrivateBrowserControl::GetSnapshot(
+    int32_t tab_id,
+    int32_t action_id,
+    uint64_t cancel_epoch,
+    mojom::SnapshotOptionsPtr options,
+    SteadAgentControlService::GetSnapshotCallback callback) {
+  const base::TimeTicks start_time = base::TimeTicks::Now();
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kTabMissing,
+                            "Tab was not found.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/true),
+        nullptr);
+    return;
+  }
+
+  EnsureAccessibilityMode(web_contents, tab_id);
+
+  if (mojom::SnapshotPtr snapshot =
+          BuildSnapshotFromBrowserTrees(web_contents, tab_id, options,
+                                        start_time)) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, true, kOk, "Snapshot captured.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false,
+                            /*blocked_by=*/std::string(),
+                            snapshot->generation),
+        std::move(snapshot));
+    return;
+  }
+
+  const size_t max_nodes =
+      options && options->max_nodes != 0 ? options->max_nodes
+                                         : kDefaultMaxSnapshotNodes;
+  web_contents->RequestAXTreeSnapshot(
+      base::BindOnce(&PrivateBrowserControl::CompleteSnapshotAfterWarmup,
+                     weak_factory_.GetWeakPtr(), tab_id, action_id,
+                     cancel_epoch, std::move(options), start_time,
+                     std::move(callback)),
+      ui::kAXModeBasic, max_nodes, kColdSnapshotTimeout,
+      content::WebContents::AXTreeSnapshotPolicy::kAll);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::ProbeNode(
+    mojom::NodeRefPtr ref,
+    int32_t action_id,
+    uint64_t cancel_epoch,
+    SteadAgentControlService::ProbeNodeCallback callback) {
+  const int32_t tab_id = ref && ref->frame ? ref->frame->tab_id : 0;
+  if (!ref || !ref->frame) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kTargetMissing, "Node ref was missing."),
+        nullptr);
+    return;
+  }
+
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kTabMissing, "Tab was not found."), nullptr);
+    return;
+  }
+
+  if (IsStaleFrame(*ref->frame, web_contents)) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kStaleRef,
+                       "Target ref is from an old snapshot."),
+        nullptr);
+    return;
+  }
+
+  if (!SnapshotIndexContains(*ref)) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kTargetMissing,
+                       "Target node is not present in the latest snapshot."),
+        nullptr);
+    return;
+  }
+
+  if (!CurrentTreeContainsNode(web_contents, *ref)) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kTargetMissing,
+                       "Target node is not present in the current AX tree."),
+        nullptr);
+    return;
+  }
+
+  const NodeSemanticData* node_data = SnapshotNodeDataForRef(*ref);
+  if (!node_data || (!node_data->has_bounds && !HasDomProbeHints(*node_data))) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kProbeHintsMissing,
+                       "Target node has no usable probe hints.",
+                       "hints"),
+        nullptr);
+    return;
+  }
+
+  content::RenderFrameHost* frame = FindFrameForRef(web_contents, *ref->frame);
+  if (!frame) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kProbeUnavailable,
+                       "Target frame was not available.", "frame"),
+        nullptr);
+    return;
+  }
+
+  frame->ExecuteJavaScriptInIsolatedWorld(
+      BuildProbeScript(*node_data),
+      base::BindOnce(&PrivateBrowserControl::CompleteProbeNode,
+                     weak_factory_.GetWeakPtr(), tab_id, action_id,
+                     cancel_epoch, ref->frame->frame_token,
+                     std::move(callback)),
+      kSteadProbeWorldId);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::Screenshot(
+    int32_t tab_id,
+    int32_t action_id,
+    uint64_t cancel_epoch,
+    mojom::NodeRefPtr ref,
+    SteadAgentControlService::ScreenshotCallback callback) {
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    broker_->FinishScreenshot(tab_id, action_id, std::move(callback),
+                              MakeReadResult(false, kTabMissing,
+                                             "Tab was not found.", "tab"),
+                              std::nullopt);
+    return;
+  }
+
+  content::RenderWidgetHostView* view =
+      web_contents->GetRenderWidgetHostView();
+  if (!view) {
+    broker_->FinishScreenshot(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kSurfaceUnavailable,
+                       "Render widget view was not available.", "surface"),
+        std::nullopt);
+    return;
+  }
+
+  if (!view->IsSurfaceAvailableForCopy()) {
+    broker_->FinishScreenshot(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kSurfaceUnavailable,
+                       "Surface was not ready for copy.", "surface"),
+        std::nullopt);
+    return;
+  }
+
+  gfx::Rect source_rect;
+  std::string taint_frame_token;
+  if (ref) {
+    if (!ref->frame || ref->frame->tab_id != tab_id) {
+      broker_->FinishScreenshot(
+          tab_id, action_id, std::move(callback),
+          MakeReadResult(false, kInvalidRef,
+                         "Node ref did not belong to this tab.", "ref"),
+          std::nullopt);
+      return;
+    }
+
+    if (IsStaleFrame(*ref->frame, web_contents)) {
+      broker_->FinishScreenshot(
+          tab_id, action_id, std::move(callback),
+          MakeReadResult(false, kStaleRef,
+                         "Target ref is from an old snapshot.", "stale"),
+          std::nullopt);
+      return;
+    }
+
+    if (!SnapshotIndexContains(*ref) ||
+        !CurrentTreeContainsNode(web_contents, *ref)) {
+      broker_->FinishScreenshot(
+          tab_id, action_id, std::move(callback),
+          MakeReadResult(false, kTargetMissing,
+                         "Target node was not present.", "target"),
+          std::nullopt);
+      return;
+    }
+
+    content::RenderFrameHost* frame =
+        FindFrameForRef(web_contents, *ref->frame);
+    if (!frame) {
+      broker_->FinishScreenshot(
+          tab_id, action_id, std::move(callback),
+          MakeReadResult(false, kTargetMissing,
+                         "Target frame was not available.", "frame"),
+          std::nullopt);
+      return;
+    }
+
+    const NodeSemanticData* node_data = SnapshotNodeDataForRef(*ref);
+    if (!node_data || !node_data->has_bounds) {
+      broker_->FinishScreenshot(
+          tab_id, action_id, std::move(callback),
+          MakeReadResult(false, kProbeBoundsMissing,
+                         "Target node has no usable snapshot bounds.",
+                         "bounds"),
+          std::nullopt);
+      return;
+    }
+
+    std::optional<gfx::Rect> root_source_rect =
+        TransformFrameRectToRootView(frame, node_data->bounds);
+    if (!root_source_rect) {
+      broker_->FinishScreenshot(
+          tab_id, action_id, std::move(callback),
+          MakeReadResult(false, kScreenshotBoundsUnavailable,
+                         "Target node bounds could not be transformed to "
+                         "the root view.",
+                         "bounds"),
+          std::nullopt);
+      return;
+    }
+
+    source_rect = *root_source_rect;
+    source_rect.Intersect(gfx::Rect(view->GetVisibleViewportSize()));
+    if (source_rect.IsEmpty()) {
+      broker_->FinishScreenshot(
+          tab_id, action_id, std::move(callback),
+          MakeReadResult(false, kNodeOutsideViewport,
+                         "Target node is outside the visible viewport.",
+                         "viewport"),
+          std::nullopt);
+      return;
+    }
+    taint_frame_token = ref->frame->frame_token;
+  }
+
+  const gfx::Size copy_size =
+      source_rect.IsEmpty() ? view->GetVisibleViewportSize()
+                            : source_rect.size();
+  const gfx::Size output_size =
+      BoundedScreenshotOutputSize(copy_size);
+  view->CopyFromSurface(
+      source_rect, output_size, kScreenshotCopyTimeout,
+      base::BindPostTaskToCurrentDefault(base::BindOnce(
+          &PrivateBrowserControl::CompleteScreenshotCopy,
+          weak_factory_.GetWeakPtr(), tab_id, action_id,
+          cancel_epoch, taint_frame_token, std::move(callback))));
+}
+
+void SteadAgentControlService::PrivateBrowserControl::Eval(
+    mojom::FrameRefPtr frame_ref,
+    int32_t action_id,
+    uint64_t cancel_epoch,
+    const std::string& js,
+    SteadAgentControlService::EvalCallback callback) {
+  const int32_t tab_id = frame_ref ? frame_ref->tab_id : 0;
+  if (!frame_ref) {
+    broker_->FinishEval(
+        tab_id, action_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kTargetMissing,
+                            "Frame ref was missing.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/true),
+        std::nullopt);
+    return;
+  }
+
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    broker_->FinishEval(
+        tab_id, action_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kTabMissing,
+                            "Tab was not found.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/true),
+        std::nullopt);
+    return;
+  }
+
+  if (IsStaleFrame(*frame_ref, web_contents)) {
+    broker_->FinishEval(
+        tab_id, action_id, std::move(callback),
+        broker_->MakeResult(
+            action_id, false, kStaleRef,
+            "Target frame ref is from an old snapshot.",
+            /*stale=*/true, /*needs_snapshot=*/true,
+            /*needs_confirmation=*/false, /*target_missing=*/false,
+            /*blocked_by=*/std::string(), CurrentSnapshotGeneration(tab_id)),
+        std::nullopt);
+    return;
+  }
+
+  content::RenderFrameHost* frame =
+      FindFrameForRef(web_contents, *frame_ref);
+  if (!frame) {
+    broker_->FinishEval(
+        tab_id, action_id, std::move(callback),
+        broker_->MakeResult(
+            action_id, false, kTargetMissing,
+            "Target frame was not available for eval.",
+            /*stale=*/false, /*needs_snapshot=*/true,
+            /*needs_confirmation=*/false, /*target_missing=*/true,
+            /*blocked_by=*/"frame", CurrentSnapshotGeneration(tab_id)),
+        std::nullopt);
+    return;
+  }
+
+  frame->ExecuteJavaScriptInIsolatedWorld(
+      base::UTF8ToUTF16(js),
+      base::BindOnce(&PrivateBrowserControl::CompleteEval,
+                     weak_factory_.GetWeakPtr(), tab_id, action_id,
+                     cancel_epoch, frame_ref->frame_token,
+                     std::move(callback)),
+      kSteadEvalWorldId);
+}
