+std::string FileChooserApprovalScope(
+    const std::string& handle,
+    const std::vector<std::string>& paths) {
+  std::string material = handle;
+  for (const std::string& path : paths) {
+    material.push_back('\\0');
+    material.append(path);
+  }
+  const auto digest = crypto::hash::Sha256(material);
+  const std::string digest_hex =
+      base::HexEncodeLower(base::span<const uint8_t>(digest.data(),
+                                                     digest.size()));
+  return "HandleFileChooser|" + handle + "|" + std::to_string(paths.size()) +
+         "|" + digest_hex;
+}
