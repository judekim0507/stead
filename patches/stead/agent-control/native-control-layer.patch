+// Browser-resident broker implementation for Stead's control layer.
+//
+// This service intentionally exposes only semantic, ref-aware browser actions.
+// Synthetic input, renderer Eval, screenshot reads, and credential APIs should
+// be added here only after the broker policy/audit/taint path exists for them.
+class SteadAgentControlService : public mojom::AgentControl,
+                                public mojom::ControlConsole {
+ public:
+  explicit SteadAgentControlService(Profile* profile);
+  SteadAgentControlService(const SteadAgentControlService&) = delete;
+  SteadAgentControlService& operator=(const SteadAgentControlService&) = delete;
+  ~SteadAgentControlService() override;
+
+  void Bind(mojo::PendingReceiver<mojom::AgentControl> receiver);
+  void BindConsole(mojo::PendingReceiver<mojom::ControlConsole> receiver);
+
+  // mojom::AgentControl:
+  void Observe(mojo::PendingRemote<mojom::ControlObserver> observer) override;
+  void ListTabs(ListTabsCallback callback) override;
+  void GetSnapshot(int32_t tab_id,
+                   mojom::SnapshotOptionsPtr options,
+                   GetSnapshotCallback callback) override;
+  void Focus(mojom::NodeRefPtr ref, FocusCallback callback) override;
+  void Click(mojom::NodeRefPtr ref, ClickCallback callback) override;
+  void Fill(mojom::NodeRefPtr ref,
+            const std::string& value,
+            FillCallback callback) override;
+  void ScrollIntoView(mojom::NodeRefPtr ref,
+                      ScrollIntoViewCallback callback) override;
+
+  // mojom::ControlConsole:
+  void AddObserver(mojo::PendingRemote<mojom::ConsoleObserver> observer)
+      override;
+  void GetAuditLog(uint32_t max_entries, GetAuditLogCallback callback) override;
+  void RespondToConfirmation(int32_t action_id, bool approve) override;
+  void Cancel(int32_t tab_id) override;
+
+ private:
+  class PrivateBrowserControl;
+  class ObservedTab;
+  struct SnapshotBuildState;
+  struct SnapshotIndex;
