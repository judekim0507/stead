+bool IsHttpOrHttpsNavigation(const GURL& url) {
+  return url.SchemeIs(url::kHttpScheme) || url.SchemeIs(url::kHttpsScheme);
+}
+
+bool HostEqualsOrSubdomain(std::string_view host, std::string_view domain) {
+  if (host == domain) {
+    return true;
+  }
+  if (host.size() <= domain.size()) {
+    return false;
+  }
+  const size_t suffix_offset = host.size() - domain.size();
+  return host[suffix_offset - 1] == '.' &&
+         host.compare(suffix_offset, domain.size(), domain) == 0;
+}
+
+std::string AuthProviderHint(const GURL& url) {
+  const std::string host = LowerAscii(url.host());
+  if (HostEqualsOrSubdomain(host, "accounts.google.com")) {
+    return "google";
+  }
+  if (HostEqualsOrSubdomain(host, "login.microsoftonline.com") ||
+      HostEqualsOrSubdomain(host, "login.live.com")) {
+    return "microsoft";
+  }
+  if (HostEqualsOrSubdomain(host, "appleid.apple.com")) {
+    return "apple";
+  }
+  if (HostEqualsOrSubdomain(host, "github.com")) {
+    return "github";
+  }
+  if (HostEqualsOrSubdomain(host, "okta.com") ||
+      host.find(".okta.") != std::string::npos) {
+    return "okta";
+  }
+  if (HostEqualsOrSubdomain(host, "auth0.com") ||
+      host.find(".auth0.") != std::string::npos) {
+    return "auth0";
+  }
+  return std::string();
+}
+
+std::string AuthRedirectReason(const GURL& url) {
+  if (!url.is_valid() || !IsHttpOrHttpsNavigation(url)) {
+    return std::string();
+  }
+
+  const std::string host = LowerAscii(url.host());
+  const std::string path = LowerAscii(url.path());
+  const std::string query = LowerAscii(url.query());
+  if (!AuthProviderHint(url).empty()) {
+    return "identity_provider";
+  }
+  if (ContainsAny(path, {"/oauth", "/oauth2", "/authorize",
+                         "/connect/authorize", "/oidc"})) {
+    return "oauth";
+  }
+  if (ContainsAny(query, {"client_id=", "redirect_uri=", "response_type=code",
+                          "scope=openid"})) {
+    return "oauth";
+  }
+  if (ContainsAny(path, {"/saml", "/sso"})) {
+    return "saml";
+  }
+  if (ContainsAny(path, {"/login", "/signin", "/sign-in", "/auth/login",
+                         "/session/new", "/users/sign_in"})) {
+    return "login";
+  }
+  if (ContainsAny(host, {"login.", "signin.", "auth.", "sso."})) {
+    return "login";
+  }
+  return std::string();
+}
+
+mojom::AuthRedirectInfoPtr BuildAuthRedirectInfo(const GURL& url) {
+  const std::string reason = AuthRedirectReason(url);
+  if (reason.empty()) {
+    return nullptr;
+  }
+
+  auto info = mojom::AuthRedirectInfo::New();
+  info->origin = url::Origin::Create(url).Serialize();
+  info->provider_hint = AuthProviderHint(url);
+  info->reason = reason;
+  return info;
+}
