+// Copyright 2026 The Stead Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+module stead.mojom;
+
+import "ui/gfx/geometry/mojom/geometry.mojom";
+
+// Stable public frame identity for agent-facing refs.
+//
+// The MVP backs frame_token with the main frame's AXTreeID string and rejects
+// mismatches as stale. The contract is intentionally wider than the first
+// implementation so OOPIF routing can move to per-frame RFH tokens without
+// changing NodeRef.
+struct FrameRef {
+  int32 tab_id;
+  string frame_token;
+  uint32 snapshot_generation;
+};
+
+struct NodeRef {
+  FrameRef frame;
+  int32 ax_node_id;
+};
+
+struct AxNode {
+  NodeRef ref;
+
+  string role;
+  string name;
+
+  bool has_value;
+  string value;
+
+  bool has_checked;
+  string checked;
+
+  bool clickable;
+  bool editable;
+  bool focused;
+  bool disabled;
+
+  // AX relative bounds, not screen coordinates. Coordinate fallback must apply
+  // the AX tree/frame transform before using these for synthetic input.
+  bool has_bounds;
+  gfx.mojom.Rect bounds;
+
+  array<AxNode> children;
+};
+
+struct SnapshotOptions {
+  // 0 means the service default. The cap keeps very large AX trees bounded for
+  // model latency and IPC pressure.
+  uint32 max_nodes;
+  bool include_bounds;
+  bool include_values;
+};
+
+struct Snapshot {
+  int32 tab_id;
+  string url;
+  string title;
+  uint32 generation;
+  uint32 node_count;
+  bool truncated;
+  uint64 capture_time_us;
+  AxNode root;
+};
+
+struct TabInfo {
+  int32 tab_id;
+  string url;
+  string title;
+  bool active;
+
+  // Coarse hint only. The model never receives cookies, account labels,
+  // usernames, or credential metadata through tab listing.
+  bool likely_authenticated;
+};
+
+struct ActionResult {
+  int32 action_id;
+
+  // For actions, ok means the browser accepted the request for dispatch. It
+  // does not prove that page state changed; callers should observe events or
+  // re-snapshot when needs_snapshot is true.
+  bool ok;
+  string code;
+  string message;
+
+  bool stale;
+  bool needs_snapshot;
+  bool needs_confirmation;
+  bool target_missing;
+  string blocked_by;
+
+  uint32 new_generation;
+};
+
+enum ControlEventType {
+  kUnknown,
+  kNavigated,
+  kTabClosed,
+  kActionDispatched,
+};
+
+struct EventMeta {
+  int32 event_id;
+  uint64 sequence;
+  int32 tab_id;
+  string frame_token;
+  int32 originating_action_id;
+};
+
+struct ControlEvent {
+  EventMeta meta;
+  ControlEventType type;
+
+  string url;
+  string title;
+  string code;
+  string message;
+};
+
+interface ControlObserver {
+  OnEvent(ControlEvent event);
+};
+
+enum ActionClass {
+  kReadOnly,
+  kNavigation,
+  kFormEntry,
+  kDestructive,
+  kPayment,
+  kCredential,
+  kFileAccess,
+  kRawInput,
+  kEval,
+};
+
+struct AuditEntry {
+  int32 action_id;
+  uint64 sequence;
+  int32 tab_id;
+  ActionClass action_class;
+  string operation;
+  string code;
+  string message;
+  bool ok;
+};
+
+struct ConfirmationRequest {
+  int32 action_id;
+  int32 tab_id;
+  ActionClass action_class;
+  string operation;
+  string reason;
+};
+
+interface ConsoleObserver {
+  OnAuditEntry(AuditEntry entry);
+  OnConfirmation(ConfirmationRequest request);
+  OnCancelled(int32 tab_id);
+};
+
+// AgentControl is the broker-facing surface. Raw BrowserControl primitives stay
+// private to the broker; WebUI console surfaces must not bind this interface
+// directly unless they are acting as the broker.
+interface AgentControl {
+  Observe(pending_remote<ControlObserver> observer);
+
+  // Read-only perception.
+  ListTabs() => (array<TabInfo> tabs);
+  GetSnapshot(int32 tab_id, SnapshotOptions? options)
+      => (ActionResult result, Snapshot? snapshot);
+
+  // Semantic AX actions. These route through RenderFrameHost AX actions rather
+  // than synthetic input so the first implementation remains observable and
+  // ref/staleness-aware.
+  Focus(NodeRef ref) => (ActionResult result);
+  Click(NodeRef ref) => (ActionResult result);
+  Fill(NodeRef ref, string value) => (ActionResult result);
+  ScrollIntoView(NodeRef ref) => (ActionResult result);
+};
+
+// WebUI-facing console surface. It can observe, approve, audit, and cancel, but
+// it has no page-driving methods.
+interface ControlConsole {
+  AddObserver(pending_remote<ConsoleObserver> observer);
+  GetAuditLog(uint32 max_entries) => (array<AuditEntry> entries);
+  RespondToConfirmation(int32 action_id, bool approve);
+  Cancel(int32 tab_id);
+};
