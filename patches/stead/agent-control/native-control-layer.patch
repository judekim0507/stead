+std::string LowerAscii(std::string text) {
+  for (char& c : text) {
+    if (c >= 'A' && c <= 'Z') {
+      c = c - 'A' + 'a';
+    }
+  }
+  return text;
+}
+
+bool ContainsAny(std::string_view text,
+                 std::initializer_list<std::string_view> needles) {
+  for (std::string_view needle : needles) {
+    if (text.find(needle) != std::string_view::npos) {
+      return true;
+    }
+  }
+  return false;
+}
+
+std::string SemanticText(const NodeSemanticData& semantics) {
+  return LowerAscii(semantics.role + " " + semantics.name + " " +
+                    semantics.value + " " + semantics.html_tag + " " +
+                    semantics.html_id + " " + semantics.html_input_name + " " +
+                    semantics.class_name + " " + semantics.autocomplete + " " +
+                    semantics.input_type + " " + semantics.placeholder + " " +
+                    semantics.description + " " + semantics.tooltip);
+}
+
+std::string SensitiveFieldText(const ui::AXNodeData& data) {
+  return LowerAscii(
+      data.GetStringAttribute(ax::mojom::StringAttribute::kName) + " " +
+      data.GetStringAttribute(ax::mojom::StringAttribute::kHtmlTag) + " " +
+      data.GetStringAttribute(ax::mojom::StringAttribute::kHtmlId) + " " +
+      data.GetStringAttribute(ax::mojom::StringAttribute::kHtmlInputName) +
+      " " + data.GetStringAttribute(ax::mojom::StringAttribute::kClassName) +
+      " " + data.GetStringAttribute(ax::mojom::StringAttribute::kAutoComplete) +
+      " " + data.GetStringAttribute(ax::mojom::StringAttribute::kInputType) +
+      " " + data.GetStringAttribute(ax::mojom::StringAttribute::kPlaceholder) +
+      " " + data.GetStringAttribute(ax::mojom::StringAttribute::kDescription) +
+      " " + data.GetStringAttribute(ax::mojom::StringAttribute::kTooltip));
+}
+
+bool ShouldRedactSnapshotValue(const ui::AXNodeData& data) {
+  if (data.IsPasswordField()) {
+    return true;
+  }
+
+  const std::string text = SensitiveFieldText(data);
+  return ContainsAny(text, {"password", "passcode", "one-time code", "totp",
+                            "verification code", "2fa", "two factor",
+                            "card number", "credit card", "debit card",
+                            "cardholder", "cc-number", "cc-exp", "cc-csc",
+                            "cc-cvc", "cc-name", "ccmonth", "ccyear",
+                            "one-time-code", "expiration", "expiry", "cvv",
+                            "cvc", "security code", "routing number",
+                            "account number", "social security", "ssn"});
+}
+
+bool LooksCredentialRelated(const NodeSemanticData& semantics) {
+  if (semantics.password) {
+    return true;
+  }
+  const std::string text = SemanticText(semantics);
+  return ContainsAny(text, {"password", "passcode", "one-time code", "totp",
+                            "verification code", "2fa", "two factor",
+                            "security code", "credential", "login", "sign in"});
+}
+
+bool LooksPaymentRelated(const NodeSemanticData& semantics) {
+  const std::string text = SemanticText(semantics);
+  return ContainsAny(text, {"pay", "payment", "purchase", "checkout",
+                            "place order", "confirm order", "buy now",
+                            "subscribe", "billing", "card number",
+                            "credit card", "cvv", "cvc"});
+}
+
+bool LooksDestructive(const NodeSemanticData& semantics) {
+  const std::string text = SemanticText(semantics);
+  return ContainsAny(text, {"delete", "remove", "destroy", "deactivate",
+                            "close account", "cancel subscription",
+                            "cancel booking", "cancel reservation",
+                            "cancel flight", "unsubscribe", "reset"});
+}
+
+bool LooksLikeLink(const NodeSemanticData& semantics) {
+  const std::string role = LowerAscii(semantics.role);
+  return role.find("link") != std::string::npos;
+}
+
+bool HasDomProbeHints(const NodeSemanticData& semantics) {
+  if (!semantics.html_id.empty() || !semantics.html_input_name.empty()) {
+    return true;
+  }
+  return !semantics.html_tag.empty() && !semantics.class_name.empty();
+}
+
+std::string NodeApprovalScope(const mojom::NodeRef& ref,
+                              mojom::ActionClass action_class,
+                              std::string_view operation) {
+  if (!ref.frame) {
+    return std::string(operation);
+  }
+  return std::string(operation) + "|" +
+         std::to_string(static_cast<int>(action_class)) + "|" +
+         std::to_string(ref.frame->tab_id) + "|" + ref.frame->frame_token +
+         "|" + std::to_string(ref.frame->snapshot_generation) + "|" +
+         std::to_string(ref.ax_node_id);
+}
+
+std::string EvalApprovalScope(const mojom::FrameRef& frame,
+                              std::string_view js) {
+  const auto digest = crypto::hash::Sha256(js);
+  const std::string digest_hex =
+      base::HexEncodeLower(base::span<const uint8_t>(digest.data(),
+                                                     digest.size()));
+  return "Eval|" + std::to_string(frame.tab_id) + "|" + frame.frame_token +
+         "|" + std::to_string(frame.snapshot_generation) + "|" +
+         std::to_string(js.size()) + "|" + digest_hex;
+}
+
+std::string CredentialListApprovalScope(int32_t tab_id,
+                                        const url::Origin& origin) {
+  return "ListCredentials|" + std::to_string(tab_id) + "|" +
+         origin.Serialize();
+}
+
+std::string CredentialFillApprovalScope(std::string_view operation,
+                                        std::string_view handle,
+                                        const mojom::NodeRef& primary_ref,
+                                        const mojom::NodeRef* secondary_ref) {
+  std::string material = std::string(operation) + "|" + std::string(handle);
+  auto append_ref = [&material](const mojom::NodeRef& ref) {
+    material.push_back('|');
+    if (!ref.frame) {
+      material.append("missing-frame");
+      return;
+    }
+    material.append(std::to_string(ref.frame->tab_id));
+    material.push_back('|');
+    material.append(ref.frame->frame_token);
+    material.push_back('|');
+    material.append(std::to_string(ref.frame->snapshot_generation));
+    material.push_back('|');
+    material.append(std::to_string(ref.ax_node_id));
+  };
+  append_ref(primary_ref);
+  if (secondary_ref) {
+    append_ref(*secondary_ref);
+  }
+  const auto digest = crypto::hash::Sha256(material);
+  const std::string digest_hex =
+      base::HexEncodeLower(base::span<const uint8_t>(digest.data(),
+                                                     digest.size()));
+  const int32_t tab_id =
+      primary_ref.frame ? primary_ref.frame->tab_id : 0;
+  return std::string(operation) + "|" + std::to_string(tab_id) + "|" +
+         digest_hex;
+}
+
+bool CredentialPolicyRequiresConfirmation(
+    mojom::CredentialUsePolicy policy) {
+  return policy == mojom::CredentialUsePolicy::kAskForApproval;
+}
