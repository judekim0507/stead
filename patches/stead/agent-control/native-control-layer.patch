+void SteadAgentControlService::PrivateBrowserControl::ObserveTab(
+    content::WebContents* web_contents,
+    int32_t tab_id) {
+  EnsureTabObserved(web_contents, tab_id);
+}
+
+BrowserWindowInterface*
+SteadAgentControlService::PrivateBrowserControl::FindWindowForNewTab() {
+  BrowserWindowInterface* active_window =
+      GetLastActiveBrowserWindowInterfaceWithAnyProfile();
+  if (active_window && !active_window->IsDeleteScheduled() &&
+      SameProfile(active_window->GetProfile(), broker_->profile_) &&
+      active_window->GetTabStripModel()) {
+    return active_window;
+  }
+
+  for (BrowserWindowInterface* window : GetAllBrowserWindowInterfaces()) {
+    if (!window || window->IsDeleteScheduled() ||
+        !SameProfile(window->GetProfile(), broker_->profile_) ||
+        !window->GetTabStripModel()) {
+      continue;
+    }
+    return window;
+  }
+
+  return nullptr;
+}
