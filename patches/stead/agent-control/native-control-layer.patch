+class SteadAgentControlService::CredentialQuery
+    : public password_manager::PasswordStoreConsumer {
+ public:
+  CredentialQuery(base::WeakPtr<SteadAgentControlService> service,
+                  int32_t action_id,
+                  int32_t tab_id,
+                  const url::Origin& origin,
+                  ListCredentialsCallback callback)
+      : service_(service),
+        action_id_(action_id),
+        tab_id_(tab_id),
+        origin_(origin),
+        callback_(std::move(callback)) {}
+
+  CredentialQuery(const CredentialQuery&) = delete;
+  CredentialQuery& operator=(const CredentialQuery&) = delete;
+  ~CredentialQuery() override = default;
+
+  void Start(ChromePasswordManagerClient* client) {
+    if (!client || !origin_.GetURL().SchemeIsHTTPOrHTTPS()) {
+      Finish(/*backend_error=*/true,
+             "Password manager is unavailable for this origin.");
+      return;
+    }
+
+    profile_store_ = client->GetProfilePasswordStore();
+    account_store_ = client->GetAccountPasswordStore();
+    password_manager::PasswordFormDigest digest(
+        password_manager::PasswordForm::Scheme::kHtml, origin_.Serialize(),
+        origin_.GetURL());
+
+    if (profile_store_) {
+      ++pending_store_count_;
+      profile_store_->GetLogins(digest, weak_factory_.GetWeakPtr());
+    }
+    if (account_store_ && account_store_ != profile_store_) {
+      ++pending_store_count_;
+      account_store_->GetLogins(digest, weak_factory_.GetWeakPtr());
+    }
+
+    if (pending_store_count_ == 0) {
+      Finish(/*backend_error=*/true, "Password store was unavailable.");
+    }
+  }
+
+  void OnGetPasswordStoreResultsOrErrorFrom(
+      password_manager::PasswordStoreInterface* store,
+      password_manager::LoginsResultOrError results_or_error) override {
+    if (std::holds_alternative<password_manager::PasswordStoreBackendError>(
+            results_or_error)) {
+      saw_backend_error_ = true;
+    } else {
+      password_manager::LoginsResult results =
+          std::move(std::get<password_manager::LoginsResult>(
+              results_or_error));
+      for (password_manager::StoredCredential& credential : results) {
+        AddCredential(store, credential);
+      }
+    }
+
+    if (--pending_store_count_ == 0) {
+      Finish(saw_backend_error_ && credentials_.empty(),
+             "Password store query failed.");
+    }
+  }
+
+ private:
+  void AddCredential(password_manager::PasswordStoreInterface* /*store*/,
+                     const password_manager::StoredCredential& credential) {
+    if (credential.blocked_by_user || credential.password_value.empty()) {
+      return;
+    }
+    if (credential.scheme != password_manager::PasswordForm::Scheme::kHtml) {
+      return;
+    }
+    if (credential.signon_realm != origin_.Serialize()) {
+      return;
+    }
+
+    CachedCredential cached;
+    cached.origin = origin_.Serialize();
+    cached.source = "stead_vault";
+    cached.username_value = credential.username_value;
+    cached.password_value = credential.password_value;
+    credentials_.push_back(std::move(cached));
+  }
+
+  void Finish(bool backend_error, const std::string& error_message) {
+    if (!callback_) {
+      return;
+    }
+    if (service_) {
+      service_->CompleteCredentialQuery(
+          action_id_, tab_id_, std::move(callback_), std::move(credentials_),
+          backend_error, error_message);
+    }
+  }
+
+  base::WeakPtr<SteadAgentControlService> service_;
+  int32_t action_id_;
+  int32_t tab_id_;
+  url::Origin origin_;
+  ListCredentialsCallback callback_;
+  raw_ptr<password_manager::PasswordStoreInterface> profile_store_ = nullptr;
+  raw_ptr<password_manager::PasswordStoreInterface> account_store_ = nullptr;
+  int pending_store_count_ = 0;
+  bool saw_backend_error_ = false;
+  std::vector<CachedCredential> credentials_;
+  base::WeakPtrFactory<CredentialQuery> weak_factory_{this};
+};
