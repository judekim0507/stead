+KeyInfo MakeKeyInfo(ui::DomKey dom_key,
+                    ui::DomCode dom_code,
+                    ui::KeyboardCode key_code,
+                    bool send_char) {
+  return KeyInfo{dom_key, dom_code, key_code, send_char};
+}
+
+std::optional<KeyInfo> ResolveKeyInfo(const std::string& key) {
+  const std::string normalized = LowerAscii(key);
+  if (normalized == "enter") {
+    return MakeKeyInfo(ui::DomKey::ENTER, ui::DomCode::ENTER,
+                       ui::VKEY_RETURN, /*send_char=*/true);
+  }
+  if (normalized == "tab") {
+    return MakeKeyInfo(ui::DomKey::TAB, ui::DomCode::TAB, ui::VKEY_TAB,
+                       /*send_char=*/true);
+  }
+  if (normalized == "backspace") {
+    return MakeKeyInfo(ui::DomKey::BACKSPACE, ui::DomCode::BACKSPACE,
+                       ui::VKEY_BACK, /*send_char=*/true);
+  }
+  if (normalized == "escape" || normalized == "esc") {
+    return MakeKeyInfo(ui::DomKey::ESCAPE, ui::DomCode::ESCAPE,
+                       ui::VKEY_ESCAPE, /*send_char=*/false);
+  }
+  if (normalized == "delete") {
+    return MakeKeyInfo(ui::DomKey::DEL, ui::DomCode::DEL, ui::VKEY_DELETE,
+                       /*send_char=*/false);
+  }
+  if (normalized == "arrowleft" || normalized == "left") {
+    return MakeKeyInfo(ui::DomKey::ARROW_LEFT, ui::DomCode::ARROW_LEFT,
+                       ui::VKEY_LEFT, /*send_char=*/false);
+  }
+  if (normalized == "arrowright" || normalized == "right") {
+    return MakeKeyInfo(ui::DomKey::ARROW_RIGHT, ui::DomCode::ARROW_RIGHT,
+                       ui::VKEY_RIGHT, /*send_char=*/false);
+  }
+  if (normalized == "arrowup" || normalized == "up") {
+    return MakeKeyInfo(ui::DomKey::ARROW_UP, ui::DomCode::ARROW_UP,
+                       ui::VKEY_UP, /*send_char=*/false);
+  }
+  if (normalized == "arrowdown" || normalized == "down") {
+    return MakeKeyInfo(ui::DomKey::ARROW_DOWN, ui::DomCode::ARROW_DOWN,
+                       ui::VKEY_DOWN, /*send_char=*/false);
+  }
+  if (normalized == "home") {
+    return MakeKeyInfo(ui::DomKey::HOME, ui::DomCode::HOME, ui::VKEY_HOME,
+                       /*send_char=*/false);
+  }
+  if (normalized == "end") {
+    return MakeKeyInfo(ui::DomKey::END, ui::DomCode::END, ui::VKEY_END,
+                       /*send_char=*/false);
+  }
+  if (normalized == "pageup") {
+    return MakeKeyInfo(ui::DomKey::PAGE_UP, ui::DomCode::PAGE_UP,
+                       ui::VKEY_PRIOR, /*send_char=*/false);
+  }
+  if (normalized == "pagedown") {
+    return MakeKeyInfo(ui::DomKey::PAGE_DOWN, ui::DomCode::PAGE_DOWN,
+                       ui::VKEY_NEXT, /*send_char=*/false);
+  }
+  if (normalized == "space") {
+    return MakeKeyInfo(ui::DomKey::FromCharacter(' '), ui::DomCode::SPACE,
+                       ui::VKEY_SPACE, /*send_char=*/true);
+  }
+  if (normalized == "backslash") {
+    return MakeKeyInfo(ui::DomKey::FromCharacter('\\'),
+                       ui::DomCode::BACKSLASH, ui::VKEY_OEM_5,
+                       /*send_char=*/true);
+  }
+
+  if (key.size() != 1 || static_cast<unsigned char>(key[0]) > 0x7F) {
+    return std::nullopt;
+  }
+
+  const char16_t character = static_cast<unsigned char>(key[0]);
+  const ui::DomKey dom_key = ui::DomKey::FromCharacter(character);
+  const ui::DomCode dom_code = ui::UsLayoutDomKeyToDomCode(dom_key);
+  if (dom_code == ui::DomCode::NONE) {
+    return std::nullopt;
+  }
+
+  return MakeKeyInfo(dom_key, dom_code,
+                     ui::DomCodeToUsLayoutKeyboardCode(dom_code),
+                     /*send_char=*/true);
+}
+
+void PopulateNativeKeyEvent(const KeyInfo& key_info,
+                            input::NativeWebKeyboardEvent* event) {
+  event->dom_key = key_info.dom_key;
+  event->dom_code = static_cast<int>(key_info.dom_code);
+  event->native_key_code =
+      ui::KeycodeConverter::DomCodeToNativeKeycode(key_info.dom_code);
+  event->windows_key_code = key_info.key_code;
+  event->is_system_key = false;
+  event->skip_if_unhandled = true;
+  if ((event->GetType() == blink::WebInputEvent::Type::kChar ||
+       event->GetType() == blink::WebInputEvent::Type::kRawKeyDown) &&
+      key_info.dom_key.IsCharacter()) {
+    event->text[0] = key_info.dom_key.ToCharacter();
+    event->unmodified_text[0] = key_info.dom_key.ToCharacter();
+  }
+}
