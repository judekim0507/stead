+
+constexpr char kOk[] = "ok";
+constexpr char kTabMissing[] = "tab_missing";
+constexpr char kTargetMissing[] = "target_missing";
+constexpr char kStaleRef[] = "stale_ref";
+constexpr char kSnapshotUnavailable[] = "snapshot_unavailable";
+constexpr char kAccessibilityActionAccepted[] = "accessibility_action_accepted";
+constexpr int32_t kNoOriginatingAction = 0;
+constexpr uint32_t kDefaultMaxSnapshotNodes = 2000;
+constexpr size_t kMaxAuditEntries = 1000;
+constexpr base::TimeDelta kColdSnapshotTimeout = base::Milliseconds(800);
+
+bool SameProfile(Profile* lhs, Profile* rhs) {
+  if (!lhs || !rhs) {
+    return false;
+  }
+  return lhs->GetOriginalProfile() == rhs->GetOriginalProfile();
+}
+
+std::string WebContentsTitle(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return std::string();
+  }
+  return base::UTF16ToUTF8(web_contents->GetTitle());
+}
+
+std::string WebContentsUrl(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return std::string();
+  }
+  return web_contents->GetLastCommittedURL().spec();
+}
+
+std::string CurrentMainFrameToken(content::WebContents* web_contents) {
+  content::RenderFrameHost* frame =
+      web_contents ? web_contents->GetPrimaryMainFrame() : nullptr;
+  if (!frame) {
+    return std::string();
+  }
+  return frame->GetAXTreeID().ToString();
+}
+
+}  // namespace
+
+struct SteadAgentControlService::SnapshotBuildState {
+  uint32_t max_nodes = kDefaultMaxSnapshotNodes;
+  bool include_bounds = true;
+  bool include_values = true;
+  uint32_t node_count = 0;
+  bool truncated = false;
+  base::flat_set<int32_t> node_ids;
+
+  bool ReserveNode() {
+    if (node_count >= max_nodes) {
+      truncated = true;
+      return false;
+    }
+    ++node_count;
+    return true;
+  }
+};
+
+struct SteadAgentControlService::SnapshotIndex {
+  uint32_t generation = 0;
+  std::string frame_token;
+  base::flat_set<int32_t> node_ids;
+};
+
+class SteadAgentControlService::PrivateBrowserControl {
+ public:
+  explicit PrivateBrowserControl(SteadAgentControlService* broker)
+      : broker_(broker) {}
+
+  PrivateBrowserControl(const PrivateBrowserControl&) = delete;
+  PrivateBrowserControl& operator=(const PrivateBrowserControl&) = delete;
+  ~PrivateBrowserControl();
+
+  std::vector<mojom::TabInfoPtr> ListTabs();
+  void GetSnapshot(int32_t tab_id,
+                   int32_t action_id,
+                   mojom::SnapshotOptionsPtr options,
+                   SteadAgentControlService::GetSnapshotCallback callback);
+  content::WebContents* FindTabById(int32_t tab_id);
+  mojom::ActionResultPtr DispatchAccessibilityAction(
+      const mojom::NodeRef& ref,
+      int32_t action_id,
+      ax::mojom::Action action,
+      const std::string& value) {
+    content::WebContents* web_contents = FindTabById(ref.frame->tab_id);
+    if (!web_contents) {
+      return broker_->MakeResult(action_id, false, kTabMissing,
+                                 "Tab was not found.",
+                                 /*stale=*/false, /*needs_snapshot=*/false,
+                                 /*needs_confirmation=*/false,
+                                 /*target_missing=*/true);
+    }
+
+    if (IsStaleFrame(*ref.frame, web_contents)) {
+      return broker_->MakeResult(
+          action_id, false, kStaleRef, "Target ref is from an old snapshot.",
+          /*stale=*/true, /*needs_snapshot=*/true,
+          /*needs_confirmation=*/false, /*target_missing=*/false,
+          /*blocked_by=*/std::string(),
+          CurrentSnapshotGeneration(ref.frame->tab_id));
+    }
+
+    if (!SnapshotIndexContains(ref)) {
+      return broker_->MakeResult(
+          action_id, false, kTargetMissing,
+          "Target node is not present in the latest snapshot.",
+          /*stale=*/false, /*needs_snapshot=*/true,
+          /*needs_confirmation=*/false, /*target_missing=*/true,
+          /*blocked_by=*/std::string(),
+          CurrentSnapshotGeneration(ref.frame->tab_id));
+    }
+
+    if (!CurrentTreeContainsNode(web_contents, ref)) {
+      return broker_->MakeResult(
+          action_id, false, kTargetMissing,
+          "Target node is not present in the current AX tree.",
+          /*stale=*/false, /*needs_snapshot=*/true,
+          /*needs_confirmation=*/false, /*target_missing=*/true,
+          /*blocked_by=*/std::string(),
+          CurrentSnapshotGeneration(ref.frame->tab_id));
+    }
+
+    content::RenderFrameHost* frame = web_contents->GetPrimaryMainFrame();
+    if (!frame) {
+      return broker_->MakeResult(action_id, false, kTargetMissing,
+                                 "Primary frame was not available.",
+                                 /*stale=*/false, /*needs_snapshot=*/true,
+                                 /*needs_confirmation=*/false,
+                                 /*target_missing=*/true,
+                                 /*blocked_by=*/std::string(),
+                                 CurrentSnapshotGeneration(ref.frame->tab_id));
+    }
+
+    ui::AXActionData action_data;
+    action_data.action = action;
+    action_data.target_tree_id = frame->GetAXTreeID();
+    action_data.target_node_id = ref.ax_node_id;
+    action_data.value = value;
+    frame->AccessibilityPerformAction(action_data);
+
+    return broker_->MakeResult(
+        action_id, true, kAccessibilityActionAccepted,
+        "Accessibility action accepted for dispatch.",
+        /*stale=*/false, /*needs_snapshot=*/true,
+        /*needs_confirmation=*/false, /*target_missing=*/false,
+        /*blocked_by=*/std::string(),
+        CurrentSnapshotGeneration(ref.frame->tab_id));
+  }
+  void ClearTabState(int32_t tab_id);
+  void ForgetObservedTab(int32_t tab_id);
+  uint32_t CurrentSnapshotGeneration(int32_t tab_id) const;
+
+ private:
+  void EnsureTabObserved(content::WebContents* web_contents, int32_t tab_id);
+  void EnsureAccessibilityMode(content::WebContents* web_contents,
+                               int32_t tab_id);
+  mojom::AxNodePtr BuildAxNode(const ui::AXTree& tree,
+                               ui::AXNode* node,
+                               int32_t tab_id,
+                               const std::string& frame_token,
+                               uint32_t generation,
+                               SnapshotBuildState* state) const;
+  void CompleteSnapshotFromUpdate(
+      int32_t tab_id,
+      int32_t action_id,
+      mojom::SnapshotOptionsPtr options,
+      base::TimeTicks start_time,
+      SteadAgentControlService::GetSnapshotCallback callback,
+      ui::AXTreeUpdate& update);
+  bool IsStaleFrame(const mojom::FrameRef& frame_ref,
+                    content::WebContents* web_contents) const;
+  bool SnapshotIndexContains(const mojom::NodeRef& ref) const;
+  bool CurrentTreeContainsNode(content::WebContents* web_contents,
+                               const mojom::NodeRef& ref) const;
+  uint32_t BumpSnapshotGeneration(int32_t tab_id);
+
+  raw_ptr<SteadAgentControlService> broker_;
+  base::flat_map<int32_t, std::unique_ptr<content::ScopedAccessibilityMode>>
+      scoped_ax_modes_;
+  base::flat_map<int32_t, uint32_t> snapshot_generations_;
+  base::flat_map<int32_t, std::unique_ptr<ObservedTab>> observed_tabs_;
+  base::flat_map<int32_t, std::unique_ptr<SnapshotIndex>> snapshot_indexes_;
+  base::WeakPtrFactory<PrivateBrowserControl> weak_factory_{this};
+};
+
+class SteadAgentControlService::ObservedTab
+    : public content::WebContentsObserver {
+ public:
+  ObservedTab(SteadAgentControlService* owner,
+              content::WebContents* web_contents,
+              int32_t tab_id)
+      : content::WebContentsObserver(web_contents),
+        owner_(owner),
+        tab_id_(tab_id) {}
+
+  ObservedTab(const ObservedTab&) = delete;
+  ObservedTab& operator=(const ObservedTab&) = delete;
+  ~ObservedTab() override = default;
+
+  void DidFinishNavigation(
+      content::NavigationHandle* navigation_handle) override {
+    if (!owner_ || !navigation_handle || !navigation_handle->HasCommitted() ||
+        navigation_handle->IsSameDocument()) {
+      return;
+    }
+
+    owner_->OnNavigationCommitted(tab_id_, navigation_handle);
+  }
+
+  void WebContentsDestroyed() override {
+    if (!owner_) {
+      return;
+    }
+
+    owner_->OnTabClosed(tab_id_);
+    owner_->ScheduleForgetObservedTab(tab_id_);
+    owner_ = nullptr;
+  }
+
+ private:
+  raw_ptr<SteadAgentControlService> owner_;
+  int32_t tab_id_;
+};
