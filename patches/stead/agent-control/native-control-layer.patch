+void SteadAgentControlService::Cancel(int32_t tab_id) {
+  cancel_epochs_by_tab_[tab_id] = CancelEpochForTab(tab_id) + 1;
+  pending_action_by_tab_.erase(tab_id);
+  ClearApprovalGrantsForTab(tab_id);
+  ClearPendingConfirmationsForTab(tab_id);
+  for (auto& observer : console_observers_) {
+    observer->OnCancelled(tab_id);
+  }
+}
