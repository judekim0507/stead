+mojom::ActionResultPtr SteadAgentControlService::PrivateBrowserControl::Navigate(
+    int32_t tab_id,
+    int32_t action_id,
+    const GURL& target_url) {
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    return broker_->MakeResult(action_id, false, kTabMissing,
+                               "Tab was not found.",
+                               /*stale=*/false, /*needs_snapshot=*/false,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true);
+  }
+
+  content::NavigationController::LoadURLParams params(target_url);
+  params.transition_type = ui::PAGE_TRANSITION_TYPED;
+  web_contents->GetController().LoadURLWithParams(params);
+
+  return broker_->MakeResult(
+      action_id, true, kNavigationStarted, "Navigation was started.",
+      /*stale=*/false, /*needs_snapshot=*/true,
+      /*needs_confirmation=*/false, /*target_missing=*/false,
+      /*blocked_by=*/std::string(), CurrentSnapshotGeneration(tab_id));
+}
+
+mojom::ActionResultPtr SteadAgentControlService::PrivateBrowserControl::OpenTab(
+    int32_t action_id,
+    const GURL& target_url,
+    bool agent_owned,
+    int32_t* opened_tab_id) {
+  if (opened_tab_id) {
+    *opened_tab_id = 0;
+  }
+
+  BrowserWindowInterface* window = FindWindowForNewTab();
+  if (!window) {
+    return broker_->MakeResult(action_id, false, kWindowMissing,
+                               "No suitable browser window was found.",
+                               /*stale=*/false, /*needs_snapshot=*/false,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true);
+  }
+
+  content::OpenURLParams params(target_url, content::Referrer(),
+                                WindowOpenDisposition::NEW_FOREGROUND_TAB,
+                                ui::PAGE_TRANSITION_TYPED,
+                                /*is_renderer_initiated=*/false);
+  content::WebContents* opened = window->OpenURL(
+      params, /*navigation_handle_callback=*/{});
+  if (!opened) {
+    return broker_->MakeResult(action_id, false, kTabOpenFailed,
+                               "Tab could not be opened immediately.",
+                               /*stale=*/false, /*needs_snapshot=*/true,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true);
+  }
+
+  SessionID tab_id = sessions::SessionTabHelper::IdForTab(opened);
+  if (!tab_id.is_valid()) {
+    return broker_->MakeResult(action_id, false, kTabOpenFailed,
+                               "Opened tab did not have a valid session id.",
+                               /*stale=*/false, /*needs_snapshot=*/true,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true);
+  }
+
+  EnsureTabObserved(opened, tab_id.id());
+  if (opened_tab_id) {
+    *opened_tab_id = tab_id.id();
+  }
+
+  TabStripModel* tab_strip = window->GetTabStripModel();
+  if (agent_owned) {
+    agent_owned_tabs_.insert(tab_id.id());
+    if (tab_strip && tab_strip->SupportsTabGroups()) {
+      const int index = tab_strip->GetIndexOfWebContents(opened);
+      if (index != TabStripModel::kNoTab) {
+        const tab_groups::TabGroupId group_id =
+            tab_strip->AddToNewGroup({index});
+        tab_strip->ChangeTabGroupVisuals(
+            group_id, tab_groups::TabGroupVisualData(
+                          kAgentTabGroupTitle,
+                          tab_groups::TabGroupColorId::kCyan));
+      }
+    }
+  }
+
+  return broker_->MakeResult(
+      action_id, true, kTabOpened, "Tab was opened.",
+      /*stale=*/false, /*needs_snapshot=*/true,
+      /*needs_confirmation=*/false, /*target_missing=*/false,
+      /*blocked_by=*/std::string(), CurrentSnapshotGeneration(tab_id.id()));
+}
+
+mojom::ActionResultPtr SteadAgentControlService::PrivateBrowserControl::CloseTab(
+    int32_t tab_id,
+    int32_t action_id) {
+  for (BrowserWindowInterface* window : GetAllBrowserWindowInterfaces()) {
+    if (!window || !SameProfile(window->GetProfile(), broker_->profile_)) {
+      continue;
+    }
+
+    TabStripModel* tab_strip = window->GetTabStripModel();
+    if (!tab_strip) {
+      continue;
+    }
+
+    for (int index = 0; index < tab_strip->count(); ++index) {
+      content::WebContents* contents = tab_strip->GetWebContentsAt(index);
+      if (!contents) {
+        continue;
+      }
+
+      SessionID current_id =
+          sessions::SessionTabHelper::IdForTab(contents);
+      if (!current_id.is_valid() || current_id.id() != tab_id) {
+        continue;
+      }
+
+      tab_strip->CloseWebContentsAt(index,
+                                    CLOSE_USER_GESTURE |
+                                        CLOSE_CREATE_HISTORICAL_TAB);
+      return broker_->MakeResult(
+          action_id, true, kTabCloseAccepted, "Tab close was accepted.",
+          /*stale=*/false, /*needs_snapshot=*/true,
+          /*needs_confirmation=*/false, /*target_missing=*/false,
+          /*blocked_by=*/std::string(), CurrentSnapshotGeneration(tab_id));
+    }
+  }
+
+  return broker_->MakeResult(action_id, false, kTabMissing,
+                             "Tab was not found.",
+                             /*stale=*/false, /*needs_snapshot=*/false,
+                             /*needs_confirmation=*/false,
+                             /*target_missing=*/true);
+}
+
+mojom::ActionResultPtr
+SteadAgentControlService::PrivateBrowserControl::HandleDialog(
+    int32_t tab_id,
+    int32_t action_id,
+    bool accept,
+    const std::optional<std::u16string>& prompt_override) {
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    return broker_->MakeResult(action_id, false, kTabMissing,
+                               "Tab was not found.",
+                               /*stale=*/false, /*needs_snapshot=*/false,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true);
+  }
+
+  javascript_dialogs::TabModalDialogManager* manager =
+      javascript_dialogs::TabModalDialogManager::FromWebContents(web_contents);
+  if (!manager) {
+    return broker_->MakeResult(
+        action_id, false, kDialogMissing,
+        "No JavaScript dialog manager was attached to the tab.",
+        /*stale=*/false, /*needs_snapshot=*/true,
+        /*needs_confirmation=*/false, /*target_missing=*/true,
+        /*blocked_by=*/"dialog", CurrentSnapshotGeneration(tab_id));
+  }
+
+  const std::u16string* prompt_override_ptr =
+      prompt_override ? &*prompt_override : nullptr;
+  if (!manager->HandleJavaScriptDialog(web_contents, accept,
+                                       prompt_override_ptr)) {
+    return broker_->MakeResult(action_id, false, kDialogMissing,
+                               "No active JavaScript dialog was handled.",
+                               /*stale=*/false, /*needs_snapshot=*/true,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true,
+                               /*blocked_by=*/"dialog",
+                               CurrentSnapshotGeneration(tab_id));
+  }
+
+  return broker_->MakeResult(action_id, true, kDialogHandled,
+                             "JavaScript dialog was handled.",
+                             /*stale=*/false, /*needs_snapshot=*/true,
+                             /*needs_confirmation=*/false,
+                             /*target_missing=*/false,
+                             /*blocked_by=*/std::string(),
+                             CurrentSnapshotGeneration(tab_id));
+}
+
+mojom::ActionResultPtr
+SteadAgentControlService::PrivateBrowserControl::HandleFileChooser(
+    FileSelectHelper* helper,
+    int32_t tab_id,
+    int32_t action_id,
+    const std::vector<base::FilePath>& paths) {
+  if (!helper) {
+    return broker_->MakeResult(action_id, false, kFileChooserMissing,
+                               "File chooser handle was not active.",
+                               /*stale=*/false, /*needs_snapshot=*/true,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true,
+                               /*blocked_by=*/"file_chooser",
+                               CurrentSnapshotGeneration(tab_id));
+  }
+
+  const bool handled = paths.empty()
+                           ? helper->CancelFileSelectionForSteadAgent()
+                           : helper->SelectFilesForSteadAgent(paths);
+  if (!handled) {
+    return broker_->MakeResult(action_id, false,
+                               kFileChooserInvalidSelection,
+                               "File chooser rejected the supplied selection.",
+                               /*stale=*/false, /*needs_snapshot=*/true,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true,
+                               /*blocked_by=*/"file_chooser",
+                               CurrentSnapshotGeneration(tab_id));
+  }
+
+  return broker_->MakeResult(action_id, true, kFileChooserHandled,
+                             paths.empty() ? "File chooser was cancelled."
+                                           : "File chooser selection was "
+                                             "accepted for dispatch.",
+                             /*stale=*/false, /*needs_snapshot=*/true,
+                             /*needs_confirmation=*/false,
+                             /*target_missing=*/false,
+                             /*blocked_by=*/std::string(),
+                             CurrentSnapshotGeneration(tab_id));
+}
