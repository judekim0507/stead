+mojom::ActionResultPtr
+SteadAgentControlService::PrivateBrowserControl::MouseDrag(
+    int32_t tab_id,
+    int32_t action_id,
+    const gfx::Point& from,
+    const gfx::Point& to,
+    blink::WebMouseEvent::Button button,
+    int32_t steps) {
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    return broker_->MakeResult(action_id, false, kTabMissing,
+                               "Tab was not found.",
+                               /*stale=*/false, /*needs_snapshot=*/false,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true);
+  }
+
+  content::RenderWidgetHostView* view =
+      web_contents->GetRenderWidgetHostView();
+  if (!view || !view->GetRenderWidgetHost()) {
+    return broker_->MakeResult(
+        action_id, false, kSurfaceUnavailable,
+        "Render widget view was not available for input.",
+        /*stale=*/false, /*needs_snapshot=*/true,
+        /*needs_confirmation=*/false, /*target_missing=*/false,
+        /*blocked_by=*/"surface", CurrentSnapshotGeneration(tab_id));
+  }
+
+  const gfx::Size viewport_size = view->GetVisibleViewportSize();
+  if (!PointInViewport(from, viewport_size) ||
+      !PointInViewport(to, viewport_size)) {
+    return broker_->MakeResult(
+        action_id, false, kInvalidPoint,
+        "Drag endpoints must be inside the visible viewport.",
+        /*stale=*/false, /*needs_snapshot=*/false,
+        /*needs_confirmation=*/false, /*target_missing=*/false,
+        /*blocked_by=*/"viewport", CurrentSnapshotGeneration(tab_id));
+  }
+
+  const int32_t step_count = steps == 0 ? kDefaultDragSteps : steps;
+  view->Focus();
+  content::RenderWidgetHost* render_widget_host = view->GetRenderWidgetHost();
+  const gfx::Rect view_bounds = view->GetViewBounds();
+  blink::WebMouseEvent mouse_down = BuildMouseEvent(
+      blink::WebInputEvent::Type::kMouseDown, from, view_bounds, button,
+      /*click_count=*/1, MouseButtonDownModifier(button));
+  render_widget_host->ForwardMouseEvent(mouse_down);
+
+  const int button_down_modifier = MouseButtonDownModifier(button);
+  for (int32_t step = 1; step <= step_count; ++step) {
+    const gfx::Point point = InterpolatePoint(from, to, step, step_count);
+    blink::WebMouseEvent mouse_move = BuildMouseEvent(
+        blink::WebInputEvent::Type::kMouseMove, point, view_bounds,
+        blink::WebMouseEvent::Button::kNoButton, /*click_count=*/0,
+        button_down_modifier);
+    render_widget_host->ForwardMouseEvent(mouse_move);
+  }
+
+  blink::WebMouseEvent mouse_up = BuildMouseEvent(
+      blink::WebInputEvent::Type::kMouseUp, to, view_bounds, button,
+      /*click_count=*/1, button_down_modifier);
+  render_widget_host->ForwardMouseEvent(mouse_up);
+
+  return broker_->MakeResult(
+      action_id, true, kRawMouseDragAccepted,
+      "Raw mouse drag accepted for dispatch.",
+      /*stale=*/false, /*needs_snapshot=*/true,
+      /*needs_confirmation=*/false, /*target_missing=*/false,
+      /*blocked_by=*/std::string(), CurrentSnapshotGeneration(tab_id));
+}
