+void SteadAgentControlService::HandleDialog(
+    const std::string& handle,
+    bool accept,
+    const std::string& prompt_text,
+    HandleDialogCallback callback) {
+  const int32_t action_id = NextActionId();
+  const std::string operation = "HandleDialog";
+  const auto active_dialog = active_dialogs_.find(handle);
+  const int32_t tab_id = active_dialog == active_dialogs_.end()
+                             ? 0
+                             : active_dialog->second.tab_id;
+  const std::string dialog_type = active_dialog == active_dialogs_.end()
+                                      ? std::string()
+                                      : active_dialog->second.type;
+  const mojom::ActionClass action_class =
+      accept && dialog_type == "confirm"
+          ? mojom::ActionClass::kDestructive
+          : (accept && dialog_type == "prompt"
+                 ? mojom::ActionClass::kFormEntry
+                 : mojom::ActionClass::kNavigation);
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result));
+  };
+
+  if (active_dialog == active_dialogs_.end()) {
+    finish(MakeResult(action_id, false, kDialogMissing,
+                      "Dialog handle was not active.",
+                      /*stale=*/false, /*needs_snapshot=*/true,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true, "dialog"));
+    return;
+  }
+
+  if (prompt_text.size() > kMaxDialogPromptBytes) {
+    finish(MakeResult(action_id, false, kDialogPromptTooLarge,
+                      "Dialog prompt input exceeded the broker input cap.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false, "dialog"));
+    return;
+  }
+
+  mojom::ActionResultPtr gate = MaybeGateAction(
+      action_id, tab_id, action_class, operation,
+      DialogApprovalScope(handle, accept, dialog_type));
+  if (gate) {
+    finish(std::move(gate));
+    return;
+  }
+
+  std::optional<std::u16string> prompt_override;
+  if (accept && dialog_type == "prompt") {
+    prompt_override = base::UTF8ToUTF16(prompt_text);
+  }
+
+  pending_action_by_tab_[tab_id] = action_id;
+  SchedulePendingActionClear(tab_id, action_id);
+  mojom::ActionResultPtr result = browser_control_->HandleDialog(
+      tab_id, action_id, accept, prompt_override);
+  if (!result->ok) {
+    pending_action_by_tab_.erase(tab_id);
+  } else {
+    active_dialogs_.erase(handle);
+    active_dialog_by_tab_.erase(tab_id);
+  }
+  finish(std::move(result));
+}
