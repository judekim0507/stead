+bool SteadAgentControlService::IsFrameTainted(
+    int32_t tab_id,
+    const std::string& frame_token) const {
+  if (!secret_tainted_frames_.contains(FrameTaintKey(tab_id, frame_token))) {
+    return false;
+  }
+
+  content::RenderFrameHost* frame = RenderFrameHostForFrameToken(frame_token);
+  return frame && frame->IsActive();
+}
+
+bool SteadAgentControlService::IsFrameTainted(
+    const mojom::FrameRef& frame) const {
+  return IsFrameTainted(frame.tab_id, frame.frame_token);
+}
+
+bool SteadAgentControlService::IsAnyFrameTainted(int32_t tab_id) const {
+  const std::string prefix = std::to_string(tab_id) + "|";
+  for (const std::string& key : secret_tainted_frames_) {
+    if (key.rfind(prefix, 0) == 0 &&
+        IsFrameTainted(tab_id, key.substr(prefix.size()))) {
+      return true;
+    }
+  }
+  return false;
+}
+
+void SteadAgentControlService::MarkFrameTainted(
+    const mojom::FrameRef& frame) {
+  secret_tainted_frames_.insert(FrameTaintKey(frame.tab_id, frame.frame_token));
+}
