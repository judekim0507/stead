+void SteadAgentControlService::CompleteCredentialQuery(
+    int32_t action_id,
+    int32_t tab_id,
+    ListCredentialsCallback callback,
+    std::vector<CachedCredential> credentials,
+    bool backend_error,
+    const std::string& error_message) {
+  PurgeExpiredCredentialCache();
+
+  std::vector<mojom::CredentialRefPtr> refs;
+  mojom::ReadResultPtr result;
+  if (backend_error) {
+    result = MakeReadResult(false, kCredentialBackendUnavailable,
+                            error_message.empty()
+                                ? "Chromium password manager query failed."
+                                : error_message,
+                            "vault");
+  } else {
+    int label_index = 1;
+    for (CachedCredential& credential : credentials) {
+      const std::string source = credential.source.empty()
+                                     ? "stead_vault"
+                                     : credential.source;
+      const std::string username =
+          SnapshotString(base::UTF16ToUTF8(credential.username_value));
+      const std::string label =
+          username.empty() ? "Account " + std::to_string(label_index)
+                           : username;
+      const std::string handle = CacheCredential(std::move(credential));
+      refs.push_back(mojom::CredentialRef::New(
+          handle, label, source,
+          /*has_totp=*/false, /*has_passkey=*/false));
+      ++label_index;
+    }
+    result = MakeReadResult(true, kCredentialsListed,
+                            refs.empty() ? "No saved credentials found."
+                                         : "Saved credentials listed.",
+                            std::string());
+  }
+
+  mojom::ActionResultPtr audit_result = MakeResult(
+      action_id, result->ok, result->code, result->message,
+      /*stale=*/false, /*needs_snapshot=*/false,
+      /*needs_confirmation=*/false, /*target_missing=*/false,
+      result->blocked_by);
+  RecordAudit(*audit_result, tab_id, mojom::ActionClass::kCredential,
+              "ListCredentials");
+  credential_queries_.erase(action_id);
+  std::move(callback).Run(std::move(result), std::move(refs));
+}
+
+std::string SteadAgentControlService::CacheCredential(
+    CachedCredential credential) {
+  PurgeExpiredCredentialCache();
+  credential.created_at = base::TimeTicks::Now();
+  const std::string handle = base::UnguessableToken::Create().ToString();
+  credential_cache_[handle] = std::move(credential);
+  credential_cache_order_.push_back(handle);
+  while (credential_cache_.size() > kMaxCachedCredentials &&
+         !credential_cache_order_.empty()) {
+    credential_cache_.erase(credential_cache_order_.front());
+    credential_cache_order_.pop_front();
+  }
+  return handle;
+}
+
+const SteadAgentControlService::CachedCredential*
+SteadAgentControlService::FindCachedCredential(const std::string& handle) {
+  PurgeExpiredCredentialCache();
+  auto it = credential_cache_.find(handle);
+  return it == credential_cache_.end() ? nullptr : &it->second;
+}
+
+void SteadAgentControlService::PurgeExpiredCredentialCache() {
+  const base::TimeTicks now = base::TimeTicks::Now();
+  while (!credential_cache_order_.empty()) {
+    const std::string& handle = credential_cache_order_.front();
+    auto it = credential_cache_.find(handle);
+    if (it == credential_cache_.end()) {
+      credential_cache_order_.pop_front();
+      continue;
+    }
+    if (now - it->second.created_at <= kCredentialCacheTtl) {
+      break;
+    }
+    credential_cache_.erase(it);
+    credential_cache_order_.pop_front();
+  }
+}
+
+void SteadAgentControlService::ListCredentials(
+    int32_t tab_id,
+    const url::Origin& origin,
+    mojom::CredentialUsePolicy policy,
+    ListCredentialsCallback callback) {
+  const int32_t action_id = NextActionId();
+  const mojom::ActionClass action_class = mojom::ActionClass::kCredential;
+  const std::string operation = "ListCredentials";
+  std::vector<mojom::CredentialRefPtr> credentials;
+  mojom::ReadResultPtr result;
+
+  const TabEventState event_state = browser_control_->GetTabEventState(tab_id);
+  if (!event_state.found) {
+    result = MakeReadResult(false, kTabMissing, "Tab was not found.", "tab");
+  } else if (origin.opaque()) {
+    result = MakeReadResult(false, kInvalidUrl,
+                            "Credential origin must be tuple-origin scoped.",
+                            "origin");
+  } else if (!origin.GetURL().SchemeIsHTTPOrHTTPS()) {
+    result = MakeReadResult(false, kInvalidUrl,
+                            "Credential origin must be http(s).", "origin");
+  } else if (url::Origin::Create(GURL(event_state.url)).Serialize() !=
+             origin.Serialize()) {
+    result = MakeReadResult(false, kInvalidUrl,
+                            "Credential origin must match the target tab.",
+                            "origin");
+  } else {
+    mojom::ActionResultPtr gate = MaybeGateAction(
+        action_id, tab_id, action_class, operation,
+        CredentialListApprovalScope(tab_id, origin),
+        CredentialPolicyRequiresConfirmation(policy));
+    if (gate) {
+      result = MakeReadResult(false, gate->code, gate->message,
+                              gate->blocked_by);
+      RecordAudit(*gate, tab_id, action_class, operation);
+      std::move(callback).Run(std::move(result), std::move(credentials));
+      return;
+    }
+    ChromePasswordManagerClient* client =
+        browser_control_->PasswordManagerClientForTab(tab_id);
+    if (!client || (!client->GetProfilePasswordStore() &&
+                    !client->GetAccountPasswordStore())) {
+      result = MakeReadResult(false, kCredentialBackendUnavailable,
+                              "Chromium password manager was unavailable.",
+                              "vault");
+    } else {
+      auto query = std::make_unique<CredentialQuery>(
+          weak_factory_.GetWeakPtr(), action_id, tab_id, origin,
+          std::move(callback));
+      CredentialQuery* raw_query = query.get();
+      credential_queries_[action_id] = std::move(query);
+      raw_query->Start(client);
+      return;
+    }
+  }
+
+  mojom::ActionResultPtr audit_result = MakeResult(
+      action_id, result->ok, result->code, result->message,
+      /*stale=*/false, /*needs_snapshot=*/false,
+      /*needs_confirmation=*/false, /*target_missing=*/false,
+      result->blocked_by);
+  RecordAudit(*audit_result, tab_id, action_class, operation);
+  std::move(callback).Run(std::move(result), std::move(credentials));
+}
+
+void SteadAgentControlService::FillCredential(
+    mojom::CredentialRefPtr credential,
+    mojom::NodeRefPtr username_field,
+    mojom::NodeRefPtr password_field,
+    mojom::CredentialUsePolicy policy,
+    FillCredentialCallback callback) {
+  const int32_t action_id = NextActionId();
+  const int32_t tab_id =
+      password_field && password_field->frame
+          ? password_field->frame->tab_id
+          : (username_field && username_field->frame
+                 ? username_field->frame->tab_id
+                 : 0);
+  const mojom::ActionClass action_class = mojom::ActionClass::kCredential;
+  const std::string operation = "FillCredential";
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result));
+  };
+
+  if (!credential || credential->opaque_handle.empty()) {
+    finish(MakeResult(action_id, false, kTargetMissing,
+                      "Credential handle was missing.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false, "credential"));
+    return;
+  }
+
+  if (!username_field || !username_field->frame || !password_field ||
+      !password_field->frame) {
+    finish(MakeResult(action_id, false, kTargetMissing,
+                      "Credential target refs were missing.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true, "target"));
+    return;
+  }
+
+  if (username_field->frame->tab_id != password_field->frame->tab_id ||
+      username_field->frame->frame_token !=
+          password_field->frame->frame_token) {
+    finish(MakeResult(action_id, false, kInvalidRef,
+                      "Credential target refs must belong to the same frame.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true, "target"));
+    return;
+  }
+
+  mojom::ActionResultPtr gate = MaybeGateAction(
+      action_id, tab_id, action_class, operation,
+      CredentialFillApprovalScope(operation, credential->opaque_handle,
+                                  *username_field, password_field.get()),
+      CredentialPolicyRequiresConfirmation(policy));
+  if (gate) {
+    finish(std::move(gate));
+    return;
+  }
+
+  const CachedCredential* cached = FindCachedCredential(credential->opaque_handle);
+  if (!cached) {
+    finish(MakeResult(action_id, false, kCredentialMissing,
+                      "Credential handle was missing or expired.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false, "credential"));
+    return;
+  }
+
+  const TabEventState event_state = browser_control_->GetTabEventState(tab_id);
+  const url::Origin current_origin = url::Origin::Create(GURL(event_state.url));
+  if (current_origin.opaque() || current_origin.Serialize() != cached->origin) {
+    finish(MakeResult(action_id, false, kInvalidRef,
+                      "Credential origin did not match the target tab.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false, "origin"));
+    return;
+  }
+
+  const std::string username = base::UTF16ToUTF8(cached->username_value);
+  const std::string password = base::UTF16ToUTF8(cached->password_value);
+  credential_cache_.erase(credential->opaque_handle);
+  if (username.size() > kMaxFillValueBytes ||
+      password.size() > kMaxFillValueBytes) {
+    finish(MakeResult(action_id, false, kFillValueTooLarge,
+                      "Credential value exceeded the broker input cap.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false, "credential"));
+    return;
+  }
+
+  if (!username.empty()) {
+    mojom::ActionResultPtr username_result =
+        browser_control_->DispatchAccessibilityAction(
+            *username_field, action_id, ax::mojom::Action::kSetValue,
+            username);
+    if (!username_result->ok) {
+      finish(std::move(username_result));
+      return;
+    }
+  }
+
+  mojom::ActionResultPtr password_result =
+      browser_control_->DispatchAccessibilityAction(
+          *password_field, action_id, ax::mojom::Action::kSetValue,
+          password);
+  if (!password_result->ok) {
+    finish(std::move(password_result));
+    return;
+  }
+
+  MarkFrameTainted(*password_field->frame);
+  pending_action_by_tab_[tab_id] = action_id;
+  SchedulePendingActionClear(tab_id, action_id);
+  EmitEvent(mojom::ControlEventType::kActionDispatched, tab_id,
+            password_field->frame->frame_token, action_id, event_state.url,
+            event_state.title, kCredentialFilled, operation);
+
+  finish(MakeResult(action_id, true, kCredentialFilled,
+                    "Credential filled through Stead Vault.",
+                    /*stale=*/false, /*needs_snapshot=*/true,
+                    /*needs_confirmation=*/false,
+                    /*target_missing=*/false, std::string(),
+                    browser_control_->CurrentSnapshotGeneration(tab_id)));
+}
+
+void SteadAgentControlService::FillTotp(
+    mojom::CredentialRefPtr credential,
+    mojom::NodeRefPtr field,
+    mojom::CredentialUsePolicy policy,
+    FillTotpCallback callback) {
+  const int32_t action_id = NextActionId();
+  const int32_t tab_id = field && field->frame ? field->frame->tab_id : 0;
+  const mojom::ActionClass action_class = mojom::ActionClass::kCredential;
+  const std::string operation = "FillTotp";
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result));
+  };
+
+  if (!credential || credential->opaque_handle.empty()) {
+    finish(MakeResult(action_id, false, kTargetMissing,
+                      "Credential handle was missing.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false, "credential"));
+    return;
+  }
+
+  if (!field || !field->frame) {
+    finish(MakeResult(action_id, false, kTargetMissing,
+                      "TOTP target ref was missing.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true, "target"));
+    return;
+  }
+
+  mojom::ActionResultPtr gate = MaybeGateAction(
+      action_id, tab_id, action_class, operation,
+      CredentialFillApprovalScope(operation, credential->opaque_handle, *field,
+                                  /*secondary_ref=*/nullptr),
+      CredentialPolicyRequiresConfirmation(policy));
+  if (gate) {
+    finish(std::move(gate));
+    return;
+  }
+
+  finish(MakeResult(action_id, false, kCredentialBackendUnavailable,
+                    "Native TOTP backend is not wired yet.",
+                    /*stale=*/false, /*needs_snapshot=*/false,
+                    /*needs_confirmation=*/false,
+                    /*target_missing=*/false, "vault"));
+}
+
+content::WebContents*
+SteadAgentControlService::PrivateBrowserControl::FindTabById(int32_t tab_id) {
+  for (BrowserWindowInterface* window : GetAllBrowserWindowInterfaces()) {
+    if (!window || !SameProfile(window->GetProfile(), broker_->profile_)) {
+      continue;
+    }
+
+    TabStripModel* tab_strip = window->GetTabStripModel();
+    if (!tab_strip) {
+      continue;
+    }
+
+    for (int index = 0; index < tab_strip->count(); ++index) {
+      content::WebContents* contents = tab_strip->GetWebContentsAt(index);
+      if (!contents) {
+        continue;
+      }
+
+      SessionID current_id =
+          sessions::SessionTabHelper::IdForTab(contents);
+      if (current_id.is_valid() && current_id.id() == tab_id) {
+        EnsureTabObserved(contents, tab_id);
+        return contents;
+      }
+    }
+  }
+
+  return nullptr;
+}
+
+TabEventState SteadAgentControlService::PrivateBrowserControl::GetTabEventState(
+    int32_t tab_id) {
+  return BuildTabEventState(FindTabById(tab_id));
+}
+
+void SteadAgentControlService::PrivateBrowserControl::EnsureTabObserved(
+    content::WebContents* web_contents,
+    int32_t tab_id) {
+  if (!web_contents) {
+    return;
+  }
+
+  if (!observed_tabs_.contains(tab_id)) {
+    observed_tabs_[tab_id] =
+        std::make_unique<ObservedTab>(broker_, web_contents, tab_id);
+  }
+  EnsureAccessibilityMode(web_contents, tab_id);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::EnsureAccessibilityMode(
+    content::WebContents* web_contents,
+    int32_t tab_id) {
+  if (!web_contents || scoped_ax_modes_.contains(tab_id)) {
+    return;
+  }
+
+  scoped_ax_modes_[tab_id] =
+      content::BrowserAccessibilityState::GetInstance()
+          ->CreateScopedModeForWebContents(web_contents, ui::kAXModeBasic);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::ClearTabState(
+    int32_t tab_id) {
+  snapshot_generations_.erase(tab_id);
+  snapshot_indexes_.erase(tab_id);
+  scoped_ax_modes_.erase(tab_id);
+  agent_owned_tabs_.erase(tab_id);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::ForgetObservedTab(
+    int32_t tab_id) {
+  observed_tabs_.erase(tab_id);
+}
+
+void SteadAgentControlService::PrivateBrowserControl::InvalidateSnapshotForTab(
+    int32_t tab_id) {
+  ++snapshot_generations_[tab_id];
+  snapshot_indexes_.erase(tab_id);
+}
+
+bool SteadAgentControlService::PrivateBrowserControl::IsAgentOwnedTab(
+    int32_t tab_id) const {
+  return agent_owned_tabs_.contains(tab_id);
+}
