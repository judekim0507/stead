+mojom::ActionResultPtr SteadAgentControlService::PrivateBrowserControl::Scroll(
+    int32_t tab_id,
+    int32_t action_id,
+    int32_t dx,
+    int32_t dy) {
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    return broker_->MakeResult(action_id, false, kTabMissing,
+                               "Tab was not found.",
+                               /*stale=*/false, /*needs_snapshot=*/false,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true);
+  }
+
+  content::RenderWidgetHostView* view =
+      web_contents->GetRenderWidgetHostView();
+  if (!view || !view->GetRenderWidgetHost()) {
+    return broker_->MakeResult(
+        action_id, false, kSurfaceUnavailable,
+        "Render widget view was not available for wheel input.",
+        /*stale=*/false, /*needs_snapshot=*/true,
+        /*needs_confirmation=*/false, /*target_missing=*/false,
+        /*blocked_by=*/"surface", CurrentSnapshotGeneration(tab_id));
+  }
+
+  view->Focus();
+  content::RenderWidgetHost* render_widget_host = view->GetRenderWidgetHost();
+  const gfx::Size viewport_size = view->GetVisibleViewportSize();
+  if (viewport_size.IsEmpty()) {
+    return broker_->MakeResult(
+        action_id, false, kSurfaceUnavailable,
+        "Visible viewport was not available for wheel input.",
+        /*stale=*/false, /*needs_snapshot=*/true,
+        /*needs_confirmation=*/false, /*target_missing=*/false,
+        /*blocked_by=*/"viewport", CurrentSnapshotGeneration(tab_id));
+  }
+  const gfx::Point center(
+      viewport_size.width() / 2, viewport_size.height() / 2);
+  const gfx::Rect view_bounds = view->GetViewBounds();
+
+  blink::WebMouseWheelEvent wheel_event(
+      blink::WebInputEvent::Type::kMouseWheel,
+      blink::WebInputEvent::kNoModifiers, base::TimeTicks::Now());
+  wheel_event.SetPositionInWidget(center.x(), center.y());
+  wheel_event.SetPositionInScreen(view_bounds.x() + center.x(),
+                                  view_bounds.y() + center.y());
+  wheel_event.delta_units = ui::ScrollGranularity::kScrollByPixel;
+  wheel_event.delta_x = -static_cast<float>(dx);
+  wheel_event.delta_y = -static_cast<float>(dy);
+  wheel_event.wheel_ticks_x =
+      wheel_event.delta_x / ui::MouseWheelEvent::kWheelDelta;
+  wheel_event.wheel_ticks_y =
+      wheel_event.delta_y / ui::MouseWheelEvent::kWheelDelta;
+  wheel_event.phase = blink::WebMouseWheelEvent::kPhaseBegan;
+  render_widget_host->ForwardWheelEvent(wheel_event);
+  wheel_event.delta_x = 0;
+  wheel_event.delta_y = 0;
+  wheel_event.wheel_ticks_x = 0;
+  wheel_event.wheel_ticks_y = 0;
+  wheel_event.phase = blink::WebMouseWheelEvent::kPhaseEnded;
+  wheel_event.dispatch_type =
+      blink::WebInputEvent::DispatchType::kEventNonBlocking;
+  render_widget_host->ForwardWheelEvent(wheel_event);
+
+  return broker_->MakeResult(
+      action_id, true, kRawWheelEventAccepted,
+      "Raw wheel scroll accepted for dispatch.",
+      /*stale=*/false, /*needs_snapshot=*/true,
+      /*needs_confirmation=*/false, /*target_missing=*/false,
+      /*blocked_by=*/std::string(), CurrentSnapshotGeneration(tab_id));
+}
