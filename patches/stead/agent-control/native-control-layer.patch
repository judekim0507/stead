+void SteadAgentControlService::OnJavaScriptDialogClosed(
+    int32_t tab_id,
+    content::JavaScriptDialogType dialog_type,
+    javascript_dialogs::TabModalDialogManager::DismissalCause cause,
+    bool success) {
+  std::string handle;
+  std::string frame_token;
+  const auto active_dialog = active_dialog_by_tab_.find(tab_id);
+  if (active_dialog != active_dialog_by_tab_.end()) {
+    handle = active_dialog->second;
+    const auto dialog = active_dialogs_.find(handle);
+    if (dialog != active_dialogs_.end()) {
+      frame_token = dialog->second.frame_token;
+    }
+    active_dialogs_.erase(handle);
+    active_dialog_by_tab_.erase(active_dialog);
+  }
+
+  EmitDialogEvent(tab_id, frame_token,
+                  BuildClosedJavaScriptDialogInfo(handle, dialog_type, cause,
+                                                  success));
