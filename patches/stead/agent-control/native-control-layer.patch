+mojom::AxNodePtr SteadAgentControlService::PrivateBrowserControl::BuildAxNode(
+    const FrameSnapshotSource& source,
+    ui::AXNode* node,
+    int32_t tab_id,
+    uint32_t generation,
+    SnapshotBuildState* state) const {
+  if (!source.tree || !node || !state || node->IsInvisibleOrIgnored()) {
+    return nullptr;
+  }
+
+  if (!state->ReserveNode()) {
+    return nullptr;
+  }
+
+  const ui::AXNodeData& data = node->data();
+  const ui::AXTree& tree = *source.tree;
+  const std::string& frame_token = source.frame_token;
+  state->node_keys.insert(NodeIndexKey(frame_token, node->id()));
+
+  auto out = mojom::AxNode::New();
+  out->ref = mojom::NodeRef::New(
+      mojom::FrameRef::New(tab_id, frame_token, generation), node->id());
+  out->role = ui::ToString(node->GetRole());
+  out->name = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kName);
+  out->has_value = state->include_values &&
+                   data.HasStringAttribute(ax::mojom::StringAttribute::kValue) &&
+                   !ShouldRedactSnapshotValue(data);
+  out->value = out->has_value
+                   ? SnapshotStringAttribute(
+                         data, ax::mojom::StringAttribute::kValue)
+                   : std::string();
+  out->clickable = data.IsClickable();
+  out->editable = data.IsTextField();
+  out->focused = tree.data().focus_id == node->id();
+  out->disabled =
+      data.GetRestriction() == ax::mojom::Restriction::kDisabled;
+
+  const ax::mojom::CheckedState checked_state = data.GetCheckedState();
+  out->has_checked = checked_state != ax::mojom::CheckedState::kNone;
+  out->checked = out->has_checked ? ui::ToString(checked_state) : std::string();
+
+  bool offscreen = false;
+  out->bounds = state->include_bounds
+                    ? gfx::ToEnclosingRect(
+                          tree.GetTreeBounds(node, &offscreen,
+                                             /*clip_bounds=*/true))
+                    : gfx::Rect();
+  out->has_bounds = state->include_bounds && !out->bounds.IsEmpty();
+
+  NodeSemanticData semantics;
+  semantics.role = out->role;
+  semantics.name = out->name;
+  semantics.value = out->value;
+  semantics.clickable = out->clickable;
+  semantics.editable = out->editable;
+  semantics.disabled = out->disabled;
+  semantics.password = data.IsPasswordField();
+  semantics.has_bounds = out->has_bounds;
+  semantics.bounds = out->bounds;
+  semantics.html_tag = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kHtmlTag);
+  semantics.html_id = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kHtmlId);
+  semantics.html_input_name = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kHtmlInputName);
+  semantics.class_name = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kClassName);
+  semantics.autocomplete = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kAutoComplete);
+  semantics.input_type = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kInputType);
+  semantics.placeholder = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kPlaceholder);
+  semantics.description = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kDescription);
+  semantics.tooltip = SnapshotStringAttribute(
+      data, ax::mojom::StringAttribute::kTooltip);
+  state->node_semantics[NodeIndexKey(frame_token, node->id())] =
+      std::move(semantics);
+
+  const size_t child_count = node->GetUnignoredChildCountCrossingTreeBoundary();
+  for (size_t i = 0; i < child_count; ++i) {
+    ui::AXNode* child = node->GetUnignoredChildAtIndexCrossingTreeBoundary(i);
+    ui::AXTree* child_tree = child ? child->tree() : nullptr;
+    if (!child_tree) {
+      continue;
+    }
+
+    const std::string child_frame_token =
+        child_tree->GetAXTreeID().ToString();
+    const auto child_source = state->frame_sources.find(child_frame_token);
+    if (child_source == state->frame_sources.end()) {
+      continue;
+    }
+    if (child_frame_token != frame_token &&
+        !state->visited_frame_tokens.insert(child_frame_token).second) {
+      continue;
+    }
+
+    mojom::AxNodePtr child_out =
+        BuildAxNode(child_source->second, child, tab_id, generation, state);
+    if (child_out) {
+      out->children.push_back(std::move(child_out));
+    }
+  }
+
+  return out;
+}
+
+mojom::ActionResultPtr SteadAgentControlService::PerformAccessibilityAction(
+    mojom::NodeRefPtr ref,
+    ax::mojom::Action action,
+    const std::string& value) {
+  const int32_t action_id = NextActionId();
+  const int32_t tab_id = ref && ref->frame ? ref->frame->tab_id : 0;
+  mojom::ActionClass action_class = mojom::ActionClass::kFormEntry;
+  const std::string operation = ui::ToString(action);
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    return result;
+  };
+
+  if (!ref || !ref->frame) {
+    return finish(MakeResult(action_id, false, kTargetMissing,
+                             "Target ref was empty.",
+                             /*stale=*/false, /*needs_snapshot=*/false,
+                             /*needs_confirmation=*/false,
+                             /*target_missing=*/true));
+  }
+
+  if (action == ax::mojom::Action::kSetValue &&
+      value.size() > kMaxFillValueBytes) {
+    return finish(MakeResult(action_id, false, kFillValueTooLarge,
+                             "Fill value exceeded the broker input cap.",
+                             /*stale=*/false, /*needs_snapshot=*/false,
+                             /*needs_confirmation=*/false,
+                             /*target_missing=*/false));
+  }
+
+  action_class =
+      browser_control_->ClassifyAccessibilityAction(*ref, action, value);
+  mojom::ActionResultPtr gate =
+      MaybeGateAction(action_id, tab_id, action_class, operation,
+                      NodeApprovalScope(*ref, action_class, operation));
+  if (gate) {
+    return finish(std::move(gate));
+  }
+
+  mojom::ActionResultPtr result =
+      browser_control_->DispatchAccessibilityAction(*ref, action_id, action,
+                                                    value);
+  if (result->ok) {
+    if (action == ax::mojom::Action::kSetValue &&
+        (action_class == mojom::ActionClass::kCredential ||
+         action_class == mojom::ActionClass::kPayment)) {
+      MarkFrameTainted(*ref->frame);
+    }
+    const TabEventState event_state =
+        browser_control_->GetTabEventState(tab_id);
+    pending_action_by_tab_[tab_id] = action_id;
+    SchedulePendingActionClear(tab_id, action_id);
+    EmitEvent(mojom::ControlEventType::kActionDispatched, tab_id,
+              ref->frame->frame_token, action_id, event_state.url,
+              event_state.title, kAccessibilityActionAccepted, operation);
+  }
+
+  return finish(std::move(result));
+}
+
+void SteadAgentControlService::OnNavigationCommitted(
+    int32_t tab_id,
+    content::NavigationHandle* navigation_handle) {
+  if (!navigation_handle) {
+    return;
+  }
+  if (!navigation_handle->HasCommitted()) {
+    return;
+  }
+
+  const bool same_document = navigation_handle->IsSameDocument();
+  std::string frame_token;
+  content::RenderFrameHost* frame = navigation_handle->GetRenderFrameHost();
+  if (frame) {
+    frame_token = frame->GetAXTreeID().ToString();
+  }
+  browser_control_->InvalidateSnapshotForTab(tab_id);
+
+  const int32_t originating_action_id = PeekPendingActionForTab(tab_id);
+  const TabEventState event_state = browser_control_->GetTabEventState(tab_id);
+  const std::string navigation_code =
+      same_document ? "same_document"
+                    : (navigation_handle->IsInPrimaryMainFrame()
+                           ? "primary_frame"
+                           : "subframe");
+  EmitEvent(mojom::ControlEventType::kNavigated, tab_id, frame_token,
+            originating_action_id, navigation_handle->GetURL().spec(),
+            event_state.title, navigation_code,
+            navigation_handle->IsErrorPage() ? "error_page" : std::string());
+  if (!same_document && navigation_handle->IsInPrimaryMainFrame() &&
+      !navigation_handle->IsErrorPage()) {
+    EmitAuthRedirectEvent(tab_id, frame_token, originating_action_id,
+                          BuildAuthRedirectInfo(navigation_handle->GetURL()));
+  }
+}
