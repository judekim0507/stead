+void SteadAgentControlService::OnPopupOpened(
+    int32_t opener_tab_id,
+    content::WebContents* new_contents,
+    content::RenderFrameHost* source_render_frame_host,
+    const GURL& url) {
+  const int32_t originating_action_id = PeekPendingActionForTab(opener_tab_id);
+  int32_t new_tab_id = 0;
+  if (new_contents) {
+    SessionID session_id =
+        sessions::SessionTabHelper::IdForTab(new_contents);
+    if (session_id.is_valid()) {
+      new_tab_id = session_id.id();
+      browser_control_->ObserveTab(new_contents, new_tab_id);
+      if (originating_action_id != kNoOriginatingAction) {
+        pending_action_by_tab_[new_tab_id] = originating_action_id;
+        SchedulePendingActionClear(new_tab_id, originating_action_id);
+      }
+    }
+  }
+
+  std::string frame_token;
+  if (source_render_frame_host) {
+    frame_token = source_render_frame_host->GetAXTreeID().ToString();
+  }
+  const TabEventState event_state =
+      browser_control_->GetTabEventState(new_tab_id);
+  EmitEvent(mojom::ControlEventType::kPopup, opener_tab_id, frame_token,
+            originating_action_id, url.spec(), event_state.title,
+            kPopupOpened, std::string(), new_tab_id);
+}
+
+void SteadAgentControlService::OnTabClosed(int32_t tab_id) {
+  const int32_t originating_action_id = TakePendingActionForTab(tab_id);
+  ClearApprovalGrantsForTab(tab_id);
+  ClearPendingConfirmationsForTab(tab_id);
+  const auto active_dialog = active_dialog_by_tab_.find(tab_id);
+  if (active_dialog != active_dialog_by_tab_.end()) {
+    active_dialogs_.erase(active_dialog->second);
+    active_dialog_by_tab_.erase(active_dialog);
+  }
+  const auto active_file_chooser = active_file_chooser_by_tab_.find(tab_id);
+  if (active_file_chooser != active_file_chooser_by_tab_.end()) {
+    const auto chooser = active_file_choosers_.find(active_file_chooser->second);
+    if (chooser != active_file_choosers_.end()) {
+      active_file_chooser_by_helper_.erase(chooser->second.helper);
+      active_file_choosers_.erase(chooser);
+    }
+    active_file_chooser_by_tab_.erase(active_file_chooser);
+  }
+  ClearTaintForTab(tab_id);
+  cancel_epochs_by_tab_[tab_id] = CancelEpochForTab(tab_id) + 1;
+  browser_control_->ClearTabState(tab_id);
+  EmitEvent(mojom::ControlEventType::kTabClosed, tab_id, std::string(),
+            originating_action_id, std::string(), std::string(),
+            "tab_closed", std::string());
+}
