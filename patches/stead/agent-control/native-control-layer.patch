+int32_t SteadAgentControlService::FindTabIdForUrl(const GURL& url) {
+  if (!url.is_valid()) {
+    return 0;
+  }
+
+  int32_t unique_matching_tab_id = 0;
+  int32_t unique_pending_matching_tab_id = 0;
+  for (BrowserWindowInterface* window : GetAllBrowserWindowInterfaces()) {
+    if (!window || !SameProfile(window->GetProfile(), profile_) ||
+        !window->GetTabStripModel()) {
+      continue;
+    }
+
+    TabStripModel* tab_strip = window->GetTabStripModel();
+    for (int index = 0; index < tab_strip->count(); ++index) {
+      content::WebContents* contents = tab_strip->GetWebContentsAt(index);
+      if (!contents || contents->GetLastCommittedURL() != url) {
+        continue;
+      }
+      SessionID current_id =
+          sessions::SessionTabHelper::IdForTab(contents);
+      if (!current_id.is_valid()) {
+        continue;
+      }
+
+      const int32_t tab_id = current_id.id();
+      if (unique_matching_tab_id == 0) {
+        unique_matching_tab_id = tab_id;
+      } else if (unique_matching_tab_id != tab_id) {
+        unique_matching_tab_id = -1;
+      }
+
+      if (pending_action_by_tab_.contains(tab_id)) {
+        if (unique_pending_matching_tab_id == 0) {
+          unique_pending_matching_tab_id = tab_id;
+        } else if (unique_pending_matching_tab_id != tab_id) {
+          unique_pending_matching_tab_id = -1;
+        }
+      }
+    }
+  }
+
+  if (unique_pending_matching_tab_id > 0) {
+    return unique_pending_matching_tab_id;
+  }
+  if (unique_pending_matching_tab_id < 0) {
+    return 0;
+  }
+  if (unique_matching_tab_id > 0) {
+    return unique_matching_tab_id;
+  }
+  if (unique_matching_tab_id < 0) {
+    return 0;
+  }
+
+  return 0;
+}
