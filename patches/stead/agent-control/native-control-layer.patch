+void SteadAgentControlService::MarkCredentialInjection(
+    mojom::FrameRefPtr frame,
+    MarkCredentialInjectionCallback callback) {
+  const int32_t action_id = NextActionId();
+  const int32_t tab_id = frame ? frame->tab_id : 0;
+  const mojom::ActionClass action_class = mojom::ActionClass::kCredential;
+  const std::string operation = "MarkCredentialInjection";
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result));
+  };
+
+  if (!frame) {
+    finish(MakeResult(action_id, false, kTargetMissing,
+                      "Frame ref was missing.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true));
+    return;
+  }
+
+  const TabEventState event_state = browser_control_->GetTabEventState(tab_id);
+  if (!event_state.found) {
+    finish(MakeResult(action_id, false, kTabMissing, "Tab was not found.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true));
+    return;
+  }
+
+  const uint32_t current_generation =
+      browser_control_->CurrentSnapshotGeneration(tab_id);
+  if (!browser_control_->FrameRefIsCurrent(*frame)) {
+    finish(MakeResult(action_id, false, kStaleRef,
+                      "Frame ref is from an old snapshot.",
+                      /*stale=*/true, /*needs_snapshot=*/true,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false,
+                      /*blocked_by=*/std::string(), current_generation));
+    return;
+  }
+
+  MarkFrameTainted(*frame);
+  finish(MakeResult(action_id, true, kFrameTainted,
+                    "Frame marked secret-tainted.",
+                    /*stale=*/false, /*needs_snapshot=*/true,
+                    /*needs_confirmation=*/false,
+                    /*target_missing=*/false,
+                    /*blocked_by=*/std::string(), current_generation));
+}
