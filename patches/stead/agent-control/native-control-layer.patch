+class SteadAgentControlService::DownloadObserver
+    : public content::DownloadManager::Observer,
+      public download::DownloadItem::Observer {
+ public:
+  explicit DownloadObserver(SteadAgentControlService* owner) : owner_(owner) {
+    if (!owner_ || !owner_->profile_) {
+      return;
+    }
+    manager_ = owner_->profile_->GetDownloadManager();
+    if (manager_) {
+      manager_->AddObserver(this);
+    }
+  }
+
+  DownloadObserver(const DownloadObserver&) = delete;
+  DownloadObserver& operator=(const DownloadObserver&) = delete;
+
+  ~DownloadObserver() override { Shutdown(); }
+
+  void Shutdown() {
+    std::vector<download::DownloadItem*> items(observed_items_.begin(),
+                                               observed_items_.end());
+    for (download::DownloadItem* item : items) {
+      if (item) {
+        item->RemoveObserver(this);
+      }
+    }
+    observed_items_.clear();
+    download_contexts_.clear();
+    download_emissions_.clear();
+
+    if (manager_) {
+      manager_->RemoveObserver(this);
+      manager_ = nullptr;
+    }
+    owner_ = nullptr;
+  }
+
+  void OnDownloadCreated(content::DownloadManager* manager,
+                         download::DownloadItem* item) override {
+    if (!owner_ || !item) {
+      return;
+    }
+    DownloadContext context = ContextForItem(*item);
+    download_contexts_[item->GetId()] = context;
+    EmitDownloadIfNeeded(*item, context, /*force=*/true);
+    if (item->IsDone()) {
+      download_contexts_.erase(item->GetId());
+      download_emissions_.erase(item->GetId());
+      return;
+    }
+    observed_items_.insert(item);
+    item->AddObserver(this);
+  }
+
+  void ManagerGoingDown(content::DownloadManager* manager) override {
+    if (manager_ == manager) {
+      manager_ = nullptr;
+    }
+    observed_items_.clear();
+    download_contexts_.clear();
+    download_emissions_.clear();
+  }
+
+  void OnDownloadUpdated(download::DownloadItem* item) override {
+    if (!owner_ || !item) {
+      return;
+    }
+    DownloadContext context = ContextForItem(*item);
+    const auto stored = download_contexts_.find(item->GetId());
+    if (stored != download_contexts_.end()) {
+      context = stored->second;
+    } else {
+      download_contexts_[item->GetId()] = context;
+    }
+    EmitDownloadIfNeeded(*item, context, /*force=*/false);
+  }
+
+  void OnDownloadDestroyed(download::DownloadItem* item) override {
+    if (!item) {
+      return;
+    }
+    observed_items_.erase(item);
+    download_contexts_.erase(item->GetId());
+    download_emissions_.erase(item->GetId());
+  }
+
+ private:
+  struct DownloadContext {
+    int32_t tab_id = 0;
+    int32_t originating_action_id = kNoOriginatingAction;
+  };
+
+  struct DownloadEmissionState {
+    bool has_emitted = false;
+    download::DownloadItem::DownloadState state =
+        download::DownloadItem::MAX_DOWNLOAD_STATE;
+    int64_t received_bytes = 0;
+    int64_t total_bytes = 0;
+    bool done = false;
+  };
+
+  void EmitDownloadIfNeeded(const download::DownloadItem& item,
+                            const DownloadContext& context,
+                            bool force) {
+    if (!owner_) {
+      return;
+    }
+
+    DownloadEmissionState& emission = download_emissions_[item.GetId()];
+    const bool state_changed = emission.state != item.GetState();
+    const bool total_changed = emission.total_bytes != item.GetTotalBytes();
+    const bool done_changed = emission.done != item.IsDone();
+    const bool progress_delta =
+        item.GetReceivedBytes() < emission.received_bytes ||
+        item.GetReceivedBytes() >=
+            emission.received_bytes + kDownloadProgressEmitBytes;
+    if (!force && emission.has_emitted && !state_changed && !total_changed &&
+        !done_changed && !progress_delta) {
+      return;
+    }
+
+    emission.has_emitted = true;
+    emission.state = item.GetState();
+    emission.received_bytes = item.GetReceivedBytes();
+    emission.total_bytes = item.GetTotalBytes();
+    emission.done = item.IsDone();
+    owner_->EmitDownloadEvent(context.tab_id, context.originating_action_id,
+                              BuildDownloadInfo(item));
+  }
+
+  DownloadContext ContextForItem(const download::DownloadItem& item) const {
+    DownloadContext context;
+    if (!owner_) {
+      return context;
+    }
+    context.tab_id = owner_->FindTabIdForUrl(item.GetTabUrl());
+    context.originating_action_id =
+        context.tab_id == 0 ? kNoOriginatingAction
+                            : owner_->PeekPendingActionForTab(context.tab_id);
+    return context;
+  }
+
+  raw_ptr<SteadAgentControlService> owner_;
+  raw_ptr<content::DownloadManager> manager_ = nullptr;
+  base::flat_set<download::DownloadItem*> observed_items_;
+  base::flat_map<uint32_t, DownloadContext> download_contexts_;
+  base::flat_map<uint32_t, DownloadEmissionState> download_emissions_;
+};
