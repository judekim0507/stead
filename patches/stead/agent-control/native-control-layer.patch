+  if (!listener_ || !render_frame_host_ || !web_contents_ ||
+      !FileSelectionMatchesMode(dialog_mode_, paths.size())) {
+    return false;
+  }
+
+  if (select_file_dialog_) {
+    select_file_dialog_->ListenerDestroyed();
+    select_file_dialog_.reset();
+  }
+
+  if (IsValidProfile(profile_)) {
+    base::FilePath last_directory = paths[0];
+    if (dialog_mode_ != FileChooserParams::Mode::kUploadFolder) {
+      last_directory = last_directory.DirName();
+    }
+    profile_->set_last_selected_directory(last_directory);
+  }
+
+  if (dialog_mode_ == FileChooserParams::Mode::kUploadFolder) {
+    StartNewEnumeration(paths[0], paths[0].BaseName().AsUTF16Unsafe());
+    return true;
+  }
+
+  std::vector<ui::SelectedFileInfo> files =
+      ui::FilePathListToSelectedFileInfoList(paths);
+#if BUILDFLAG(IS_MAC)
+  base::ThreadPool::PostTask(
+      FROM_HERE,
