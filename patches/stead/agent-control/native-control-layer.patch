+void SteadAgentControlService::Screenshot(int32_t tab_id,
+                                          mojom::NodeRefPtr ref,
+                                          ScreenshotCallback callback) {
+  const int32_t action_id = NextActionId();
+  const TabEventState event_state = browser_control_->GetTabEventState(tab_id);
+  const bool blocked_by_taint =
+      ref && ref->frame ? IsFrameTainted(*ref->frame)
+                        : IsAnyFrameTainted(tab_id);
+  if (event_state.found && blocked_by_taint) {
+    FinishScreenshot(tab_id, action_id, std::move(callback),
+                     MakeReadResult(false, kSecretTainted,
+                                    "Frame is secret-tainted.",
+                                    "secret_taint"),
+                     std::nullopt);
+    return;
+  }
+  browser_control_->Screenshot(tab_id, action_id, CancelEpochForTab(tab_id),
+                               std::move(ref), std::move(callback));
+}
+
+void SteadAgentControlService::Eval(mojom::FrameRefPtr frame,
+                                    const std::string& js,
+                                    EvalCallback callback) {
+  const int32_t action_id = NextActionId();
+  const int32_t tab_id = frame ? frame->tab_id : 0;
+  const mojom::ActionClass action_class = mojom::ActionClass::kEval;
+  const std::string operation = "Eval";
+  auto finish = [&](mojom::ActionResultPtr result,
+                    std::optional<std::string> json_result = std::nullopt) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result), std::move(json_result));
+  };
+
+  if (!frame) {
+    finish(MakeResult(action_id, false, kTargetMissing,
+                      "Frame ref was missing.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true));
+    return;
+  }
+
+  if (js.empty()) {
+    finish(MakeResult(action_id, false, kEvalScriptEmpty,
+                      "Eval script was empty.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false));
+    return;
+  }
+
+  if (js.size() > kMaxEvalScriptBytes) {
+    finish(MakeResult(action_id, false, kEvalScriptTooLarge,
+                      "Eval script exceeded the broker input cap.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false));
+    return;
+  }
+
+  const TabEventState event_state = browser_control_->GetTabEventState(tab_id);
+  if (!event_state.found) {
+    finish(MakeResult(action_id, false, kTabMissing, "Tab was not found.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true));
+    return;
+  }
+
+  if (IsFrameTainted(*frame)) {
+    finish(MakeResult(action_id, false, kSecretTainted,
+                      "Frame is secret-tainted.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false, "secret_taint"));
+    return;
+  }
+
+  mojom::ActionResultPtr gate =
+      MaybeGateAction(action_id, tab_id, action_class, operation,
+                      EvalApprovalScope(*frame, js));
+  if (gate) {
+    finish(std::move(gate));
+    return;
+  }
+
+  pending_action_by_tab_[tab_id] = action_id;
+  SchedulePendingActionClear(tab_id, action_id);
+  EmitEvent(mojom::ControlEventType::kActionDispatched, tab_id,
+            frame->frame_token, action_id, event_state.url, event_state.title,
+            kEvalDispatched, operation);
+  browser_control_->Eval(std::move(frame), action_id, CancelEpochForTab(tab_id),
+                         js, std::move(callback));
+}
+
+void SteadAgentControlService::Navigate(int32_t tab_id,
+                                        const GURL& target_url,
+                                        NavigateCallback callback) {
+  const int32_t action_id = NextActionId();
+  const bool is_file_access = target_url.is_valid() &&
+                              IsFileNavigation(target_url);
+  const mojom::ActionClass action_class =
+      is_file_access ? mojom::ActionClass::kFileAccess
+                     : mojom::ActionClass::kNavigation;
+  const std::string operation =
+      is_file_access ? "NavigateFile" : "Navigate";
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result));
+  };
+
+  if (!target_url.is_valid()) {
+    finish(MakeResult(action_id, false, kInvalidUrl, "URL is invalid.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false));
+    return;
+  }
+
+  // Allow only ordinary web navigations by default. Local files are supported
+  // but confirmation-gated; eval-like and internal schemes stay blocked until
+  // they have dedicated broker policy.
+  if (!IsHttpOrHttpsNavigation(target_url) &&
+      !IsFileNavigation(target_url)) {
+    finish(MakeResult(action_id, false, kBlockedScheme,
+                      "URL scheme is not allowed for agent navigation.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false));
+    return;
+  }
+
+  const TabEventState event_state =
+      browser_control_->GetTabEventState(tab_id);
+  if (!event_state.found) {
+    finish(MakeResult(action_id, false, kTabMissing, "Tab was not found.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true));
+    return;
+  }
+
+  mojom::ActionResultPtr gate =
+      MaybeGateAction(action_id, tab_id, action_class, operation,
+                      target_url.spec());
+  if (gate) {
+    finish(std::move(gate));
+    return;
+  }
+
+  pending_action_by_tab_[tab_id] = action_id;
+  mojom::ActionResultPtr result =
+      browser_control_->Navigate(tab_id, action_id, target_url);
+  if (!result->ok) {
+    pending_action_by_tab_.erase(tab_id);
+  } else {
+    SchedulePendingActionClear(tab_id, action_id);
+    EmitEvent(mojom::ControlEventType::kActionDispatched, tab_id,
+              event_state.frame_token, action_id, target_url.spec(),
+              event_state.title, kNavigationStarted, operation);
+  }
+
+  finish(std::move(result));
+}
+
+void SteadAgentControlService::OpenTab(const GURL& target_url,
+                                       bool agent_owned,
+                                       OpenTabCallback callback) {
+  const int32_t action_id = NextActionId();
+  const bool is_file_access = target_url.is_valid() &&
+                              IsFileNavigation(target_url);
+  const mojom::ActionClass action_class =
+      is_file_access ? mojom::ActionClass::kFileAccess
+                     : mojom::ActionClass::kNavigation;
+  const std::string operation =
+      agent_owned ? "OpenAgentTab" : "OpenTab";
+  auto finish = [&](mojom::ActionResultPtr result, int32_t opened_tab_id) {
+    RecordAudit(*result, opened_tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result), opened_tab_id);
+  };
+
+  if (!target_url.is_valid()) {
+    finish(MakeResult(action_id, false, kInvalidUrl, "URL is invalid.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false),
+           0);
+    return;
+  }
+
+  if (!IsHttpOrHttpsNavigation(target_url) &&
+      !IsFileNavigation(target_url)) {
+    finish(MakeResult(action_id, false, kBlockedScheme,
+                      "URL scheme is not allowed for agent tab creation.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/false),
+           0);
+    return;
+  }
+
+  mojom::ActionResultPtr gate =
+      MaybeGateAction(action_id, /*tab_id=*/0, action_class, operation,
+                      target_url.spec());
+  if (gate) {
+    finish(std::move(gate), 0);
+    return;
+  }
+
+  int32_t opened_tab_id = 0;
+  mojom::ActionResultPtr result = browser_control_->OpenTab(
+      action_id, target_url, agent_owned, &opened_tab_id);
+  if (result->ok && opened_tab_id != 0) {
+    pending_action_by_tab_[opened_tab_id] = action_id;
+    SchedulePendingActionClear(opened_tab_id, action_id);
+    const TabEventState event_state =
+        browser_control_->GetTabEventState(opened_tab_id);
+    EmitEvent(mojom::ControlEventType::kTabOpened, opened_tab_id,
+              event_state.frame_token, action_id, target_url.spec(),
+              event_state.title, kTabOpened, operation);
+  }
+
+  finish(std::move(result), opened_tab_id);
+}
+
+void SteadAgentControlService::CloseTab(int32_t tab_id,
+                                        CloseTabCallback callback) {
+  const int32_t action_id = NextActionId();
+  const bool agent_owned = browser_control_->IsAgentOwnedTab(tab_id);
+  const mojom::ActionClass action_class =
+      agent_owned ? mojom::ActionClass::kNavigation
+                  : mojom::ActionClass::kDestructive;
+  const std::string operation = agent_owned ? "CloseAgentTab" : "CloseTab";
+  auto finish = [&](mojom::ActionResultPtr result) {
+    RecordAudit(*result, tab_id, action_class, operation);
+    std::move(callback).Run(std::move(result));
+  };
+
+  const TabEventState event_state = browser_control_->GetTabEventState(tab_id);
+  if (!event_state.found) {
+    finish(MakeResult(action_id, false, kTabMissing, "Tab was not found.",
+                      /*stale=*/false, /*needs_snapshot=*/false,
+                      /*needs_confirmation=*/false,
+                      /*target_missing=*/true));
+    return;
+  }
+
+  mojom::ActionResultPtr gate =
+      MaybeGateAction(action_id, tab_id, action_class, operation,
+                      std::to_string(tab_id));
+  if (gate) {
+    finish(std::move(gate));
+    return;
+  }
+
+  pending_action_by_tab_[tab_id] = action_id;
+  mojom::ActionResultPtr result =
+      browser_control_->CloseTab(tab_id, action_id);
+  if (!result->ok) {
+    pending_action_by_tab_.erase(tab_id);
+  } else {
+    SchedulePendingActionClear(tab_id, action_id);
+    EmitEvent(mojom::ControlEventType::kActionDispatched, tab_id,
+              event_state.frame_token, action_id, event_state.url,
+              event_state.title, kTabCloseAccepted, operation);
+  }
+
+  finish(std::move(result));
+}
