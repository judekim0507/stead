+void SteadAgentControlService::OnFileChooserOpened(
+    FileSelectHelper* helper,
+    content::WebContents* web_contents,
+    content::RenderFrameHost* render_frame_host,
+    const blink::mojom::FileChooserParams& params) {
+  if (!helper || !web_contents ||
+      !SameProfile(Profile::FromBrowserContext(web_contents->GetBrowserContext()),
+                   profile_)) {
+    return;
+  }
+
+  const SessionID tab_session_id =
+      sessions::SessionTabHelper::IdForTab(web_contents);
+  if (!tab_session_id.is_valid()) {
+    return;
+  }
+  const int32_t tab_id = tab_session_id.id();
+  browser_control_->ObserveTab(web_contents, tab_id);
+
+  const auto existing_helper = active_file_chooser_by_helper_.find(helper);
+  if (existing_helper != active_file_chooser_by_helper_.end()) {
+    active_file_choosers_.erase(existing_helper->second);
+    active_file_chooser_by_helper_.erase(existing_helper);
+  }
+  const auto existing_tab = active_file_chooser_by_tab_.find(tab_id);
+  if (existing_tab != active_file_chooser_by_tab_.end()) {
+    const auto chooser = active_file_choosers_.find(existing_tab->second);
+    if (chooser != active_file_choosers_.end()) {
+      active_file_chooser_by_helper_.erase(chooser->second.helper);
+      active_file_choosers_.erase(chooser);
+    }
+    active_file_chooser_by_tab_.erase(existing_tab);
+  }
+
+  const std::string handle =
+      "file-chooser-" + std::to_string(next_file_chooser_id_++);
+  const std::string frame_token =
+      render_frame_host ? render_frame_host->GetAXTreeID().ToString()
+                        : std::string();
+
+  ActiveFileChooserState state;
+  state.tab_id = tab_id;
+  state.helper = helper;
+  state.frame_token = frame_token;
+  state.mode = FileChooserModeToString(params.mode);
+  active_file_choosers_[handle] = state;
+  active_file_chooser_by_helper_[helper] = handle;
+  active_file_chooser_by_tab_[tab_id] = handle;
+
+  EmitFileChooserEvent(tab_id, frame_token,
+                       BuildFileChooserInfo(handle, "opened", params));
+}
