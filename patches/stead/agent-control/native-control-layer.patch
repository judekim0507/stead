+
+void SteadAgentControlService::PopulateNextAuthHintProbe(
+    std::unique_ptr<ListTabsAuthState> state) {
+  if (!state) {
+    return;
+  }
+
+  while (state->next_tab_index < state->tabs.size()) {
+    mojom::TabInfoPtr& tab = state->tabs[state->next_tab_index];
+    const GURL url(tab ? tab->url : std::string());
+    if (!url.is_valid() || !IsHttpOrHttpsNavigation(url) || !profile_) {
+      ++state->next_tab_index;
+      continue;
+    }
+
+    content::StoragePartition* storage_partition =
+        profile_->GetDefaultStoragePartition();
+    if (!storage_partition) {
+      ++state->next_tab_index;
+      continue;
+    }
+
+    network::mojom::CookieManager* cookie_manager =
+        storage_partition->GetCookieManagerForBrowserProcess();
+    if (!cookie_manager) {
+      ++state->next_tab_index;
+      continue;
+    }
+
+    cookie_manager->GetCookieList(
+        url, net::CookieOptions::MakeAllInclusive(),
+        net::CookiePartitionKeyCollection::ContainsAll(),
+        base::BindOnce(&SteadAgentControlService::CompleteAuthHintProbe,
+                       weak_factory_.GetWeakPtr(), std::move(state)));
+    return;
+  }
+
+  std::move(state->callback).Run(std::move(state->tabs));
+}
+
+void SteadAgentControlService::CompleteAuthHintProbe(
+    std::unique_ptr<ListTabsAuthState> state,
+    std::vector<network::mojom::CookieWithAccessResultPtr> cookies,
+    std::vector<network::mojom::CookieWithAccessResultPtr>
+        /*excluded_cookies*/) {
+  if (!state) {
+    return;
+  }
+
+  if (state->next_tab_index < state->tabs.size()) {
+    mojom::TabInfoPtr& tab = state->tabs[state->next_tab_index];
+    if (tab) {
+      tab->likely_authenticated = !cookies.empty();
+    }
+    ++state->next_tab_index;
+  }
+
+  PopulateNextAuthHintProbe(std::move(state));
+}
+
+std::vector<mojom::TabInfoPtr>
+SteadAgentControlService::PrivateBrowserControl::ListTabs() {
+  std::vector<mojom::TabInfoPtr> tabs;
+
+  for (BrowserWindowInterface* window : GetAllBrowserWindowInterfaces()) {
+    if (!window || !SameProfile(window->GetProfile(), broker_->profile_)) {
+      continue;
+    }
+
+    TabStripModel* tab_strip = window->GetTabStripModel();
+    if (!tab_strip) {
+      continue;
+    }
+
+    content::WebContents* active_contents = tab_strip->GetActiveWebContents();
+    for (int index = 0; index < tab_strip->count(); ++index) {
+      content::WebContents* contents = tab_strip->GetWebContentsAt(index);
+      if (!contents) {
+        continue;
+      }
+
+      SessionID tab_id =
+          sessions::SessionTabHelper::IdForTab(contents);
+      if (!tab_id.is_valid()) {
+        continue;
+      }
+
+      EnsureTabObserved(contents, tab_id.id());
+
+      auto tab = mojom::TabInfo::New();
+      tab->tab_id = tab_id.id();
+      tab->url = WebContentsUrl(contents);
+      tab->title = WebContentsTitle(contents);
+      tab->active = contents == active_contents;
+      tab->likely_authenticated = false;
+      tabs.push_back(std::move(tab));
+    }
+  }
+
+  return tabs;
+}
