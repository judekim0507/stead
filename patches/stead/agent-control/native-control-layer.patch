+mojom::ActionResultPtr SteadAgentControlService::PrivateBrowserControl::Key(
+    int32_t tab_id,
+    int32_t action_id,
+    const KeyInfo& key_info,
+    int32_t modifiers) {
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    return broker_->MakeResult(action_id, false, kTabMissing,
+                               "Tab was not found.",
+                               /*stale=*/false, /*needs_snapshot=*/false,
+                               /*needs_confirmation=*/false,
+                               /*target_missing=*/true);
+  }
+
+  content::RenderFrameHost* frame = web_contents->GetFocusedFrame();
+  if (!frame) {
+    frame = web_contents->GetPrimaryMainFrame();
+  }
+  if (!frame || !frame->GetRenderWidgetHost()) {
+    return broker_->MakeResult(
+        action_id, false, kSurfaceUnavailable,
+        "Focused render widget was not available for keyboard input.",
+        /*stale=*/false, /*needs_snapshot=*/true,
+        /*needs_confirmation=*/false, /*target_missing=*/false,
+        /*blocked_by=*/"surface", CurrentSnapshotGeneration(tab_id));
+  }
+
+  content::RenderWidgetHostView* view =
+      web_contents->GetRenderWidgetHostView();
+  if (view) {
+    view->Focus();
+  }
+
+  content::RenderWidgetHost* render_widget_host = frame->GetRenderWidgetHost();
+  input::NativeWebKeyboardEvent key_down(
+      blink::WebInputEvent::Type::kRawKeyDown, modifiers,
+      base::TimeTicks::Now());
+  PopulateNativeKeyEvent(key_info, &key_down);
+  render_widget_host->ForwardKeyboardEvent(key_down);
+
+  if (key_info.send_char) {
+    input::NativeWebKeyboardEvent char_event(
+        blink::WebInputEvent::Type::kChar, modifiers, base::TimeTicks::Now());
+    PopulateNativeKeyEvent(key_info, &char_event);
+    render_widget_host->ForwardKeyboardEvent(char_event);
+  }
+
+  input::NativeWebKeyboardEvent key_up(blink::WebInputEvent::Type::kKeyUp,
+                                       modifiers, base::TimeTicks::Now());
+  PopulateNativeKeyEvent(key_info, &key_up);
+  render_widget_host->ForwardKeyboardEvent(key_up);
+
+  return broker_->MakeResult(
+      action_id, true, kRawKeyEventAccepted,
+      "Raw key accepted for dispatch.",
+      /*stale=*/false, /*needs_snapshot=*/true,
+      /*needs_confirmation=*/false, /*target_missing=*/false,
+      /*blocked_by=*/std::string(), CurrentSnapshotGeneration(tab_id));
+}
+
+mojom::SnapshotPtr
+SteadAgentControlService::PrivateBrowserControl::BuildSnapshotFromBrowserTrees(
+    content::WebContents* web_contents,
+    int32_t tab_id,
+    const mojom::SnapshotOptionsPtr& options,
+    base::TimeTicks start_time) {
+  content::RenderFrameHost* main_frame =
+      web_contents ? web_contents->GetPrimaryMainFrame() : nullptr;
+  if (!main_frame) {
+    return nullptr;
+  }
+
+  const std::string main_frame_token = main_frame->GetAXTreeID().ToString();
+  SnapshotBuildState build_state;
+  if (options) {
+    build_state.max_nodes =
+        options->max_nodes == 0 ? kDefaultMaxSnapshotNodes : options->max_nodes;
+    build_state.include_bounds = options->include_bounds;
+    build_state.include_values = options->include_values;
+  }
+
+  web_contents->ForEachRenderFrameHost(
+      [web_contents, &build_state](content::RenderFrameHost* frame) {
+        if (!FrameBelongsToWebContents(frame, web_contents)) {
+          return;
+        }
+
+        ui::AXTreeManager* manager =
+            ui::AXTreeManager::FromID(frame->GetAXTreeID());
+        ui::AXTree* tree = manager ? manager->ax_tree() : nullptr;
+        if (!tree || !tree->root()) {
+          return;
+        }
+
+        const std::string frame_token = frame->GetAXTreeID().ToString();
+        FrameSnapshotSource source;
+        source.frame = frame;
+        source.manager = manager;
+        source.tree = tree;
+        source.frame_token = frame_token;
+        build_state.frame_sources[frame_token] = source;
+      });
+
+  const auto main_source = build_state.frame_sources.find(main_frame_token);
+  if (main_source == build_state.frame_sources.end()) {
+    return nullptr;
+  }
+
+  const uint32_t generation = CurrentSnapshotGeneration(tab_id) + 1;
+  build_state.visited_frame_tokens.insert(main_frame_token);
+  mojom::AxNodePtr root =
+      BuildAxNode(main_source->second, main_source->second.tree->root(), tab_id,
+                  generation, &build_state);
+  if (!root) {
+    return nullptr;
+  }
+  snapshot_generations_[tab_id] = generation;
+
+  auto snapshot = mojom::Snapshot::New();
+  snapshot->tab_id = tab_id;
+  snapshot->url = WebContentsUrl(web_contents);
+  snapshot->title = WebContentsTitle(web_contents);
+  snapshot->generation = generation;
+  snapshot->node_count = build_state.node_count;
+  snapshot->truncated = build_state.truncated;
+  snapshot->capture_time_us =
+      static_cast<uint64_t>((base::TimeTicks::Now() - start_time)
+                                .InMicroseconds());
+  snapshot->root = std::move(root);
+  auto snapshot_index = std::make_unique<SnapshotIndex>();
+  snapshot_index->generation = generation;
+  snapshot_index->node_keys = std::move(build_state.node_keys);
+  snapshot_index->node_semantics = std::move(build_state.node_semantics);
+  snapshot_indexes_[tab_id] = std::move(snapshot_index);
+  return snapshot;
+}
+
+void SteadAgentControlService::PrivateBrowserControl::CompleteSnapshotAfterWarmup(
+    int32_t tab_id,
+    int32_t action_id,
+    uint64_t cancel_epoch,
+    mojom::SnapshotOptionsPtr options,
+    base::TimeTicks start_time,
+    SteadAgentControlService::GetSnapshotCallback callback,
+    ui::AXTreeUpdate& /*warmup_update*/) {
+  if (broker_->WasCancelledSince(tab_id, cancel_epoch)) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kCancelled,
+                            "Snapshot was cancelled.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false, "cancel"),
+        nullptr);
+    return;
+  }
+
+  content::WebContents* web_contents = FindTabById(tab_id);
+  if (!web_contents) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kTabMissing,
+                            "Tab was not found.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/true),
+        nullptr);
+    return;
+  }
+
+  if (broker_->IsAnyFrameTainted(tab_id)) {
+    if (!options) {
+      options = mojom::SnapshotOptions::New(
+          /*max_nodes=*/0, /*include_bounds=*/true,
+          /*include_values=*/false);
+    } else {
+      options->include_values = false;
+    }
+  }
+
+  mojom::SnapshotPtr snapshot =
+      BuildSnapshotFromBrowserTrees(web_contents, tab_id, options, start_time);
+  if (!snapshot) {
+    broker_->FinishSnapshot(
+        tab_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kSnapshotUnavailable,
+                            "Frame-local accessibility snapshot was unavailable.",
+                            /*stale=*/false, /*needs_snapshot=*/true,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false),
+        nullptr);
+    return;
+  }
+
+  broker_->FinishSnapshot(
+      tab_id, std::move(callback),
+      broker_->MakeResult(action_id, true, kOk, "Snapshot captured.",
+                          /*stale=*/false, /*needs_snapshot=*/false,
+                          /*needs_confirmation=*/false,
+                          /*target_missing=*/false,
+                          /*blocked_by=*/std::string(),
+                          snapshot->generation),
+      std::move(snapshot));
+}
+
+void SteadAgentControlService::PrivateBrowserControl::CompleteEval(
+    int32_t tab_id,
+    int32_t action_id,
+    uint64_t cancel_epoch,
+    const std::string& frame_token,
+    SteadAgentControlService::EvalCallback callback,
+    base::Value value) {
+  if (broker_->WasCancelledSince(tab_id, cancel_epoch)) {
+    broker_->FinishEval(
+        tab_id, action_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kCancelled,
+                            "Eval result was cancelled.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false, "cancel"),
+        std::nullopt);
+    return;
+  }
+
+  if (broker_->IsFrameTainted(tab_id, frame_token)) {
+    broker_->FinishEval(
+        tab_id, action_id, std::move(callback),
+        broker_->MakeResult(action_id, false, kSecretTainted,
+                            "Frame became secret-tainted before eval "
+                            "completed.",
+                            /*stale=*/false, /*needs_snapshot=*/false,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false, "secret_taint"),
+        std::nullopt);
+    return;
+  }
+
+  std::optional<std::string> json = base::WriteJson(value);
+  if (!json) {
+    broker_->FinishEval(
+        tab_id, action_id, std::move(callback),
+        broker_->MakeResult(action_id, true, kEvalResultUnserializable,
+                            "Eval completed, but the result could not be "
+                            "serialized to JSON.",
+                            /*stale=*/false, /*needs_snapshot=*/true,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false),
+        std::nullopt);
+    return;
+  }
+
+  if (json->size() > kMaxEvalResultBytes) {
+    broker_->FinishEval(
+        tab_id, action_id, std::move(callback),
+        broker_->MakeResult(action_id, true, kEvalResultTooLarge,
+                            "Eval completed, but the JSON result exceeded "
+                            "the broker return cap.",
+                            /*stale=*/false, /*needs_snapshot=*/true,
+                            /*needs_confirmation=*/false,
+                            /*target_missing=*/false),
+        std::nullopt);
+    return;
+  }
+
+  broker_->FinishEval(
+      tab_id, action_id, std::move(callback),
+      broker_->MakeResult(action_id, true, kEvalCompleted, "Eval completed.",
+                          /*stale=*/false, /*needs_snapshot=*/true,
+                          /*needs_confirmation=*/false,
+                          /*target_missing=*/false),
+      std::move(json));
+}
+
+void SteadAgentControlService::PrivateBrowserControl::CompleteProbeNode(
+    int32_t tab_id,
+    int32_t action_id,
+    uint64_t cancel_epoch,
+    const std::string& frame_token,
+    SteadAgentControlService::ProbeNodeCallback callback,
+    base::Value value) {
+  if (broker_->WasCancelledSince(tab_id, cancel_epoch)) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kCancelled, "Node probe was cancelled.",
+                       "cancel"),
+        nullptr);
+    return;
+  }
+
+  if (broker_->IsFrameTainted(tab_id, frame_token)) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kSecretTainted,
+                       "Frame became secret-tainted before probe completed.",
+                       "secret_taint"),
+        nullptr);
+    return;
+  }
+
+  mojom::NodeProbePtr probe = BuildNodeProbeFromValue(value);
+  if (!probe) {
+    broker_->FinishProbeNode(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kProbeScriptFailed,
+                       "Probe script did not return a valid object.",
+                       "script"),
+        nullptr);
+    return;
+  }
+
+  broker_->FinishProbeNode(
+      tab_id, action_id, std::move(callback),
+      MakeReadResult(true, kProbeCompleted, "Node probe completed."),
+      std::move(probe));
+}
+
+void SteadAgentControlService::PrivateBrowserControl::CompleteScreenshotCopy(
+    int32_t tab_id,
+    int32_t action_id,
+    uint64_t cancel_epoch,
+    const std::string& frame_token,
+    SteadAgentControlService::ScreenshotCallback callback,
+    const content::CopyFromSurfaceResult& copy_result) {
+  if (broker_->WasCancelledSince(tab_id, cancel_epoch)) {
+    broker_->FinishScreenshot(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kCancelled, "Screenshot was cancelled.",
+                       "cancel"),
+        std::nullopt);
+    return;
+  }
+
+  const bool blocked_by_taint =
+      frame_token.empty() ? broker_->IsAnyFrameTainted(tab_id)
+                          : broker_->IsFrameTainted(tab_id, frame_token);
+  if (blocked_by_taint) {
+    broker_->FinishScreenshot(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kSecretTainted,
+                       "Frame became secret-tainted before screenshot "
+                       "completed.",
+                       "secret_taint"),
+        std::nullopt);
+    return;
+  }
+
+  if (!copy_result.has_value()) {
+    broker_->FinishScreenshot(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(
+            false, kScreenshotCopyFailed,
+            "Surface copy failed: " +
+                CopyFromSurfaceErrorToString(copy_result.error()),
+            "surface"),
+        std::nullopt);
+    return;
+  }
+
+  const SkBitmap& bitmap = copy_result->bitmap;
+  if (bitmap.drawsNothing()) {
+    broker_->FinishScreenshot(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kScreenshotEmpty,
+                       "Surface copy returned an empty bitmap.", "surface"),
+        std::nullopt);
+    return;
+  }
+
+  std::optional<std::vector<uint8_t>> png =
+      gfx::PNGCodec::FastEncodeBGRASkBitmap(
+          bitmap, /*discard_transparency=*/false);
+  if (!png) {
+    broker_->FinishScreenshot(
+        tab_id, action_id, std::move(callback),
+        MakeReadResult(false, kScreenshotEncodeFailed,
+                       "Surface bitmap could not be PNG encoded.", "png"),
+        std::nullopt);
+    return;
+  }
+
+  std::optional<mojo_base::BigBuffer> buffer;
+  buffer.emplace(base::span<const uint8_t>(png->data(), png->size()));
+  broker_->FinishScreenshot(
+      tab_id, action_id, std::move(callback),
+      MakeReadResult(true, kScreenshotCaptured, "Screenshot captured."),
+      std::move(buffer));
+}
