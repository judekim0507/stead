+mojom::NodeProbePtr BuildNodeProbeFromValue(const base::Value& value) {
+  const base::DictValue* dict = value.GetIfDict();
+  if (!dict) {
+    return nullptr;
+  }
+
+  auto probe = mojom::NodeProbe::New();
+  probe->found = DictBool(*dict, "found");
+  probe->target_matched = DictBool(*dict, "target_matched");
+  probe->occluded = DictBool(*dict, "occluded");
+  probe->visible = DictBool(*dict, "visible");
+  probe->disabled = DictBool(*dict, "disabled");
+  probe->editable = DictBool(*dict, "editable");
+  probe->tag_name = DictString(*dict, "tag_name");
+  probe->id = DictString(*dict, "id");
+  probe->class_name = DictString(*dict, "class_name");
+  probe->name_attr = DictString(*dict, "name_attr");
+  probe->type_attr = DictString(*dict, "type_attr");
+  probe->role_attr = DictString(*dict, "role_attr");
+  probe->aria_label = DictString(*dict, "aria_label");
+  probe->display = DictString(*dict, "display");
+  probe->visibility = DictString(*dict, "visibility");
+  probe->pointer_events = DictString(*dict, "pointer_events");
+  probe->cursor = DictString(*dict, "cursor");
+  probe->opacity = DictDouble(*dict, "opacity", 1.0);
+  probe->client_rect = gfx::Rect(DictRoundedInt(*dict, "rect_x"),
+                                 DictRoundedInt(*dict, "rect_y"),
+                                 DictRoundedInt(*dict, "rect_width"),
+                                 DictRoundedInt(*dict, "rect_height"));
+  probe->hit_test_stack = DictStringList(*dict, "hit_test_stack");
+  return probe;
+}
+
+std::u16string BuildProbeScript(const NodeSemanticData& data) {
+  const gfx::Rect& bounds = data.bounds;
+  const int center_x = data.has_bounds ? bounds.x() + bounds.width() / 2 : -1;
+  const int center_y = data.has_bounds ? bounds.y() + bounds.height() / 2 : -1;
+  const std::string tag = base::GetQuotedJSONString(data.html_tag);
+  const std::string id = base::GetQuotedJSONString(data.html_id);
+  const std::string name = base::GetQuotedJSONString(data.html_input_name);
+  const std::string class_name = base::GetQuotedJSONString(data.class_name);
+
+  return base::UTF8ToUTF16(base::StringPrintf(
+      R"JS(
+(() => {
+  const x = %d;
+  const y = %d;
+  const hints = {tagName: %s, id: %s, name: %s, className: %s};
+  const clip = (value, limit = 160) => {
+    value = value == null ? '' : String(value);
+    return value.length > limit ? value.slice(0, limit) : value;
+  };
+  const firstClass = (value) => {
+    value = clip(value);
+    return value.split(/\s+/).filter(Boolean)[0] || '';
+  };
+  const hintedClass = firstClass(hints.className);
+  const describe = (el) => {
+    if (!el || !el.tagName) return '';
+    const cls = firstClass(typeof el.className === 'string' ? el.className : '');
+    return clip(el.tagName.toLowerCase() + (el.id ? '#' + el.id : '') +
+        (cls ? '.' + cls : ''), 120);
+  };
+  const matchesHints = (el) => {
+    if (!el || !el.tagName) return false;
+    if (hints.id && el.id === hints.id) return true;
+    let checks = 0;
+    let hits = 0;
+    if (hints.tagName) {
+      checks++;
+      if (el.tagName.toLowerCase() === hints.tagName.toLowerCase()) hits++;
+    }
+    if (hints.name) {
+      checks++;
+      if (el.getAttribute('name') === hints.name) hits++;
+    }
+    if (hintedClass) {
+      checks++;
+      if (el.classList && el.classList.contains(hintedClass)) hits++;
+    }
+    return checks > 0 && hits === checks;
+  };
+  const pushAll = (target, values) => {
+    for (const value of Array.from(values || [])) {
+      if (value && !target.includes(value)) target.push(value);
+      if (target.length >= 128) break;
+    }
+  };
+  const hinted = [];
+  if (hints.id) {
+    const byId = document.getElementById(hints.id);
+    if (byId) hinted.push(byId);
+  }
+  if (hints.name) pushAll(hinted, document.getElementsByName(hints.name));
+  if (hints.tagName) {
+    pushAll(hinted, document.getElementsByTagName(hints.tagName));
+  }
+  if (hintedClass) {
+    pushAll(hinted, document.getElementsByClassName(hintedClass));
+  }
+  const stack = x >= 0 && y >= 0
+      ? Array.from(document.elementsFromPoint(x, y)).slice(0, 8)
+      : [];
+  const targetIndex = stack.findIndex(matchesHints);
+  let el = targetIndex >= 0 ? stack[targetIndex] : null;
+  if (!el) el = hinted.find(matchesHints) || stack[0] || null;
+  const stackIndex = el ? stack.indexOf(el) : -1;
+  const out = {
+    found: !!el,
+    target_matched: !!el && matchesHints(el),
+    occluded: stackIndex > 0,
+    visible: false,
+    disabled: false,
+    editable: false,
+    hit_test_stack: stack.map(describe).filter(Boolean)
+  };
+  if (!el) return out;
+  const style = getComputedStyle(el);
+  const rect = el.getBoundingClientRect();
+  out.visible = rect.width > 0 && rect.height > 0 &&
+      style.display !== 'none' && style.visibility !== 'hidden' &&
+      Number(style.opacity || 1) > 0;
+  out.disabled = !!el.disabled || el.getAttribute('aria-disabled') === 'true';
+  out.editable = !!el.isContentEditable ||
+      /^(INPUT|TEXTAREA|SELECT)$/.test(el.tagName);
+  out.tag_name = clip(el.tagName.toLowerCase());
+  out.id = clip(el.id);
+  out.class_name = clip(typeof el.className === 'string' ? el.className : '');
+  out.name_attr = clip(el.getAttribute('name'));
+  out.type_attr = clip(el.getAttribute('type'));
+  out.role_attr = clip(el.getAttribute('role'));
+  out.aria_label = clip(el.getAttribute('aria-label'));
+  out.display = clip(style.display);
+  out.visibility = clip(style.visibility);
+  out.pointer_events = clip(style.pointerEvents);
+  out.cursor = clip(style.cursor);
+  out.opacity = Number(style.opacity || 1);
+  out.rect_x = Math.round(rect.x);
+  out.rect_y = Math.round(rect.y);
+  out.rect_width = Math.round(rect.width);
+  out.rect_height = Math.round(rect.height);
+  return out;
+})()
+)JS",
+      center_x, center_y, tag.c_str(), id.c_str(), name.c_str(),
+      class_name.c_str()));
+}
