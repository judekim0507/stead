diff --git a/chrome/browser/ui/stead/agent_control/agent_control.mojom b/chrome/browser/ui/stead/agent_control/agent_control.mojom
new file mode 100644
index 0000000000000..4cbb02c943bdb
--- /dev/null
+++ b/chrome/browser/ui/stead/agent_control/agent_control.mojom
@@ -0,0 +1,348 @@
+// Copyright 2026 The Stead Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+module stead.mojom;
+
+import "mojo/public/mojom/base/big_buffer.mojom";
+import "ui/gfx/geometry/mojom/geometry.mojom";
+import "url/mojom/origin.mojom";
+import "url/mojom/url.mojom";
+
+// Stable public frame identity for agent-facing refs.
+//
+// The implementation backs frame_token with a RenderFrameHost AXTreeID string
+// and resolves it back through RenderFrameHost::FromAXTreeID for action/probe
+// routing. Main-frame snapshots are the initial path; the contract already
+// carries the wider OOPIF shape without changing NodeRef.
+struct FrameRef {
+  int32 tab_id;
+  string frame_token;
+  uint32 snapshot_generation;
+};
+
+struct NodeRef {
+  FrameRef frame;
+  int32 ax_node_id;
+};
+
+struct AxNode {
+  NodeRef ref;
+
+  string role;
+  string name;
+
+  bool has_value;
+  string value;
+
+  bool has_checked;
+  string checked;
+
+  bool clickable;
+  bool editable;
+  bool focused;
+  bool disabled;
+
+  // AX tree bounds, not screen coordinates. Coordinate fallback must apply the
+  // frame/view transform before using these for synthetic input.
+  bool has_bounds;
+  gfx.mojom.Rect bounds;
+
+  array<AxNode> children;
+};
+
+struct NodeProbe {
+  bool found;
+  bool target_matched;
+  bool occluded;
+  bool visible;
+  bool disabled;
+  bool editable;
+
+  string tag_name;
+  string id;
+  string class_name;
+  string name_attr;
+  string type_attr;
+  string role_attr;
+  string aria_label;
+
+  string display;
+  string visibility;
+  string pointer_events;
+  string cursor;
+  double opacity;
+
+  gfx.mojom.Rect client_rect;
+  array<string> hit_test_stack;
+};
+
+struct SnapshotOptions {
+  // 0 means the service default. The cap keeps very large AX trees bounded for
+  // model latency and IPC pressure.
+  uint32 max_nodes;
+  bool include_bounds;
+  bool include_values;
+};
+
+struct Snapshot {
+  int32 tab_id;
+  string url;
+  string title;
+  uint32 generation;
+  uint32 node_count;
+  bool truncated;
+  uint64 capture_time_us;
+  AxNode root;
+};
+
+struct TabInfo {
+  int32 tab_id;
+  string url;
+  string title;
+  bool active;
+
+  // Coarse hint only. The model never receives cookies, account labels,
+  // usernames, or credential metadata through tab listing.
+  bool likely_authenticated;
+};
+
+struct CredentialRef {
+  // Opaque Vault handle. It must not encode secret material.
+  string opaque_handle;
+  // Account-selector label. Username/email is allowed here so the agent can
+  // choose between saved accounts; passwords, TOTP codes, cookies, payment
+  // data, and passkey private material are never allowed.
+  string label;
+  string source;
+  bool has_totp;
+  bool has_passkey;
+};
+
+struct ActionResult {
+  int32 action_id;
+
+  // For actions, ok means the browser accepted the request for dispatch. It
+  // does not prove that page state changed; callers should observe events or
+  // re-snapshot when needs_snapshot is true.
+  bool ok;
+  string code;
+  string message;
+
+  bool stale;
+  bool needs_snapshot;
+  bool needs_confirmation;
+  bool target_missing;
+  string blocked_by;
+
+  uint32 new_generation;
+};
+
+struct ReadResult {
+  bool ok;
+  string code;
+  string message;
+  string blocked_by;
+};
+
+enum ControlEventType {
+  kUnknown,
+  kNavigated,
+  kTabOpened,
+  kTabClosed,
+  kPopup,
+  kDownload,
+  kDialog,
+  kPermissionPrompt,
+  kAuthRedirect,
+  kFileChooser,
+  kActionDispatched,
+};
+
+struct EventMeta {
+  int32 event_id;
+  uint64 sequence;
+  int32 tab_id;
+  string frame_token;
+  int32 originating_action_id;
+};
+
+struct DownloadInfo {
+  uint32 download_id;
+  string guid;
+  string state;
+  string url;
+  string original_url;
+  string tab_url;
+  string file_name;
+  string mime_type;
+  int64 received_bytes;
+  int64 total_bytes;
+  bool done;
+};
+
+struct DialogInfo {
+  string type;
+  string state;
+  string message;
+  string default_prompt;
+  string opaque_handle;
+};
+
+struct PermissionPromptInfo {
+  string state;
+  string requesting_origin;
+  string embedding_origin;
+  array<string> request_types;
+  string decision;
+};
+
+struct AuthRedirectInfo {
+  string origin;
+  string provider_hint;
+  string reason;
+};
+
+struct FileChooserInfo {
+  string state;
+  string mode;
+  string title;
+  string default_file_name;
+  array<string> accept_types;
+  bool allow_multiple;
+  bool upload_folder;
+  bool need_local_path;
+  bool use_media_capture;
+  string opaque_handle;
+};
+
+struct ControlEvent {
+  EventMeta meta;
+  ControlEventType type;
+
+  string url;
+  string title;
+  string code;
+  string message;
+  int32 related_tab_id;
+  DownloadInfo? download;
+  DialogInfo? dialog;
+  PermissionPromptInfo? permission_prompt;
+  AuthRedirectInfo? auth_redirect;
+  FileChooserInfo? file_chooser;
+};
+
+interface ControlObserver {
+  OnEvent(ControlEvent event);
+};
+
+enum ActionClass {
+  kReadOnly,
+  kNavigation,
+  kFormEntry,
+  kDestructive,
+  kPayment,
+  kCredential,
+  kFileAccess,
+  kRawInput,
+  kEval,
+};
+
+enum CredentialUsePolicy {
+  // Normal/read/full modes: saved-password use is pre-authorized through the
+  // broker. Locked Vault/passkey ceremonies still require native user presence.
+  kPreauthorized,
+
+  // Ask-first mode: every credential enumeration/fill attempt must surface a
+  // ControlConsole confirmation before the broker proceeds.
+  kAskForApproval,
+};
+
+struct AuditEntry {
+  int32 action_id;
+  uint64 sequence;
+  int32 tab_id;
+  ActionClass action_class;
+  string operation;
+  string code;
+  string message;
+  bool ok;
+};
+
+struct ConfirmationRequest {
+  int32 action_id;
+  int32 tab_id;
+  ActionClass action_class;
+  string operation;
+  string reason;
+};
+
+interface ConsoleObserver {
+  OnAuditEntry(AuditEntry entry);
+  OnConfirmation(ConfirmationRequest request);
+  OnCancelled(int32 tab_id);
+};
+
+// AgentControl is the broker-facing surface. Raw BrowserControl primitives stay
+// private to the broker; WebUI console surfaces must not bind this interface
+// directly unless they are acting as the broker.
+interface AgentControl {
+  Observe(pending_remote<ControlObserver> observer);
+
+  // Read-only perception.
+  ListTabs() => (array<TabInfo> tabs);
+  GetSnapshot(int32 tab_id, SnapshotOptions? options)
+      => (ActionResult result, Snapshot? snapshot);
+  ProbeNode(NodeRef ref) => (ReadResult result, NodeProbe? probe);
+  Screenshot(int32 tab_id, NodeRef? ref)
+      => (ReadResult result, mojo_base.mojom.BigBuffer? png);
+  Eval(FrameRef frame, string js)
+      => (ActionResult result, string? json_result);
+
+  Navigate(int32 tab_id, url.mojom.Url url) => (ActionResult result);
+  OpenTab(url.mojom.Url url, bool agent_owned)
+      => (ActionResult result, int32 tab_id);
+  CloseTab(int32 tab_id) => (ActionResult result);
+  HandleDialog(string opaque_handle, bool accept, string prompt_text)
+      => (ActionResult result);
+  HandleFileChooser(string opaque_handle, array<string> paths)
+      => (ActionResult result);
+
+  // Semantic AX actions. These route through RenderFrameHost AX actions rather
+  // than synthetic input so the first implementation remains observable and
+  // ref/staleness-aware.
+  Focus(NodeRef ref) => (ActionResult result);
+  Click(NodeRef ref) => (ActionResult result);
+  Fill(NodeRef ref, string value) => (ActionResult result);
+  ScrollIntoView(NodeRef ref) => (ActionResult result);
+  ShowContextMenu(NodeRef ref) => (ActionResult result);
+  MouseMove(int32 tab_id, gfx.mojom.Point point) => (ActionResult result);
+  MouseDown(int32 tab_id, gfx.mojom.Point point, int32 button,
+      int32 click_count) => (ActionResult result);
+  MouseUp(int32 tab_id, gfx.mojom.Point point, int32 button,
+      int32 click_count) => (ActionResult result);
+  MouseClick(int32 tab_id, gfx.mojom.Point point, int32 button,
+      int32 click_count) => (ActionResult result);
+  MouseDrag(int32 tab_id, gfx.mojom.Point from, gfx.mojom.Point to,
+      int32 button, int32 steps) => (ActionResult result);
+  Key(int32 tab_id, string key, int32 modifiers) => (ActionResult result);
+  Scroll(int32 tab_id, int32 dx, int32 dy) => (ActionResult result);
+  ListCredentials(int32 tab_id, url.mojom.Origin origin,
+      CredentialUsePolicy policy)
+      => (ReadResult result, array<CredentialRef> credentials);
+  FillCredential(CredentialRef credential, NodeRef username_field,
+      NodeRef password_field, CredentialUsePolicy policy)
+      => (ActionResult result);
+  FillTotp(CredentialRef credential, NodeRef field, CredentialUsePolicy policy)
+      => (ActionResult result);
+  MarkCredentialInjection(FrameRef frame) => (ActionResult result);
+};
+
+// WebUI-facing console surface. It can observe, approve, audit, and cancel, but
+// it has no page-driving methods.
+interface ControlConsole {
+  AddObserver(pending_remote<ConsoleObserver> observer);
+  GetAuditLog(uint32 max_entries) => (array<AuditEntry> entries);
+  RespondToConfirmation(int32 action_id, bool approve);
+  Cancel(int32 tab_id);
+};
