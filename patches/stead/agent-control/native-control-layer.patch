+#include "components/keyed_service/core/keyed_service.h"
+
+namespace stead {
+
+// static
+SteadAgentControlService* SteadAgentControlServiceFactory::GetForProfile(
+    Profile* profile) {
+  if (!profile) {
+    return nullptr;
+  }
+
+  return static_cast<SteadAgentControlService*>(
+      GetInstance()->GetServiceForBrowserContext(profile, /*create=*/true));
+}
+
+// static
+SteadAgentControlServiceFactory* SteadAgentControlServiceFactory::GetInstance() {
+  static base::NoDestructor<SteadAgentControlServiceFactory> instance;
+  return instance.get();
+}
+
+// static
+void SteadAgentControlServiceFactory::BindAgentControl(
+    Profile* profile,
+    mojo::PendingReceiver<mojom::AgentControl> receiver) {
+  SteadAgentControlService* service = GetForProfile(profile);
+  if (!service) {
+    return;
+  }
+  service->Bind(std::move(receiver));
+}
+
+// static
+void SteadAgentControlServiceFactory::BindControlConsole(
+    Profile* profile,
+    mojo::PendingReceiver<mojom::ControlConsole> receiver) {
+  SteadAgentControlService* service = GetForProfile(profile);
+  if (!service) {
+    return;
+  }
+  service->BindConsole(std::move(receiver));
+}
+
+SteadAgentControlServiceFactory::SteadAgentControlServiceFactory()
+    : ProfileKeyedServiceFactory(
+          "SteadAgentControlService",
+          ProfileSelections::BuildForRegularProfile()) {}
+
+SteadAgentControlServiceFactory::~SteadAgentControlServiceFactory() = default;
+
+std::unique_ptr<KeyedService>
+SteadAgentControlServiceFactory::BuildServiceInstanceForBrowserContext(
+    content::BrowserContext* context) const {
+  Profile* profile = Profile::FromBrowserContext(context);
+  if (!profile) {
+    return nullptr;
+  }
+  return std::make_unique<SteadAgentControlService>(profile);
+}
+
+}  // namespace stead
