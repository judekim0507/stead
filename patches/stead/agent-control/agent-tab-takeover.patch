+void SteadAgentControlService::PrivateBrowserControl::EnsureAgentOwnedTabLocked(
+    int32_t tab_id) {
+  if (IsAgentOwnedTab(tab_id)) {
+    broker_->UpdateDriveOverlay(tab_id, /*show=*/true);
+  }
+}
+
+void SteadAgentControlService::PrivateBrowserControl::ReleaseAgentOwnedTab(
+    int32_t tab_id) {
+  if (!agent_owned_tabs_.erase(tab_id)) {
+    return;
+  }
+  agent_input_blocks_.erase(tab_id);
+  content::WebContents* contents = FindTabById(tab_id);
+  if (!contents) {
+    return;
+  }
+  for (BrowserWindowInterface* window : GetAllBrowserWindowInterfaces()) {
+    if (!window || !SameProfile(window->GetProfile(), broker_->profile_)) {
+      continue;
+    }
+    TabStripModel* tab_strip = window->GetTabStripModel();
+    const int index = tab_strip ? tab_strip->GetIndexOfWebContents(contents)
+                                : TabStripModel::kNoTab;
+    if (index != TabStripModel::kNoTab &&
+        tab_strip->GetTabGroupForTab(index).has_value()) {
+      tab_strip->RemoveFromGroup({index});
+      break;
+    }
+  }
+  broker_->UpdateDriveOverlay(tab_id, /*show=*/false);
+}
