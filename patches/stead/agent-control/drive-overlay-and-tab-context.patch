+void SteadAgentControlService::GetActiveTabContext(
+    GetActiveTabContextCallback callback) {
+  Browser* browser = chrome::FindLastActiveWithProfile(profile_);
+  if (!browser || !browser->tab_strip_model()) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+  content::WebContents* contents =
+      browser->tab_strip_model()->GetActiveWebContents();
+  if (!contents) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+  const GURL& url = contents->GetLastCommittedURL();
+  // Context is only meaningful for web pages; WebUI and internal schemes stay
+  // out of the model-facing tab context.
+  if (!url.SchemeIsHTTPOrHTTPS()) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+  const SessionID session_id = sessions::SessionTabHelper::IdForTab(contents);
+  if (!session_id.is_valid()) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+  auto context = mojom::TabContextInfo::New();
+  context->tab_id = session_id.id();
+  context->url = url.spec();
+  context->title = base::UTF16ToUTF8(contents->GetTitle());
+  std::move(callback).Run(std::move(context));
+}
