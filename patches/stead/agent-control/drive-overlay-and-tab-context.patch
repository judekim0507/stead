+void SteadAgentControlService::MarkTabDriving(int32_t tab_id) {
+  const bool was_driving = last_drive_action_by_tab_.contains(tab_id);
+  last_drive_action_by_tab_[tab_id] = base::TimeTicks::Now();
+  if (!was_driving) {
+    for (auto& observer : console_observers_) {
+      observer->OnDrivingStateChanged(tab_id, true);
+    }
+  }
+  // Re-injected on every action (idempotent) so a navigation mid-drive gets
+  // the overlay back on the next action.
+  UpdateDriveOverlay(tab_id, /*show=*/true);
+  base::SequencedTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&SteadAgentControlService::CheckDrivingIdle,
+                     weak_factory_.GetWeakPtr(), tab_id),
+      kDrivingIdleTimeout + base::Milliseconds(50));
+}
+
+void SteadAgentControlService::CheckDrivingIdle(int32_t tab_id) {
+  const auto last = last_drive_action_by_tab_.find(tab_id);
+  if (last == last_drive_action_by_tab_.end()) {
+    return;
+  }
+  if (base::TimeTicks::Now() - last->second >= kDrivingIdleTimeout) {
+    ClearTabDriving(tab_id);
+  }
+  // Otherwise a newer action has already queued its own idle check.
+}
+
+void SteadAgentControlService::ClearTabDriving(int32_t tab_id) {
+  if (last_drive_action_by_tab_.erase(tab_id) == 0) {
+    return;
+  }
+  for (auto& observer : console_observers_) {
+    observer->OnDrivingStateChanged(tab_id, false);
+  }
+  UpdateDriveOverlay(tab_id, /*show=*/false);
+}
+
+void SteadAgentControlService::UpdateDriveOverlay(int32_t tab_id, bool show) {
+  if (!browser_control_) {
+    return;
+  }
+  content::WebContents* web_contents =
+      browser_control_->TabForDriveOverlay(tab_id);
+  if (!web_contents) {
+    return;
+  }
+  content::RenderFrameHost* frame = web_contents->GetPrimaryMainFrame();
+  if (!frame || !frame->IsRenderFrameLive()) {
+    return;
+  }
+  // Write-only injection with no result callback, so a secret-tainted frame
+  // can never leak page state back through this path.
+  frame->ExecuteJavaScriptInIsolatedWorld(
+      base::UTF8ToUTF16(std::string(show ? kDriveOverlayShowScript
+                                         : kDriveOverlayHideScript)),
+      base::NullCallback(), kSteadProbeWorldId);
+}
